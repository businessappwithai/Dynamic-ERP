<!--
  Create View - New Entity Form (Column 3)

  Displays a form for creating new entity records.
  Fields are dynamically generated from sys_field metadata.
  Supports validation and save operations.

  Generated: 2026-03-09T11:47:10.429Z
-->
<mvc:View
  controllerName="hospital-management-system.controller.Create"
  xmlns="sap.uxap"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns:m="sap.m"
  xmlns:f="sap.ui.layout.form"
  xmlns:core="sap.ui.core">

  <ObjectPageLayout
    id="createPage"
    showTitleInHeaderContent="true"
    upperCaseAnchorBar="false"
    showAnchorBarPopover="false"
    busyIndicatorDelay="0">

    <!-- Object Page Header -->
    <headerTitle>
      <ObjectPageDynamicHeaderTitle>
        <!-- Avatar with initials - prevents warning about missing src/initials -->
        <avatar>
          <m:Avatar
            class="sapUiSmallMarginEnd"
            visible="true"
            displayType="Standard"
            initials="HMS" />
        </avatar>

        <expandedHeading>
          <m:Title
            text="{i18n>create.title}"
            wrapping="true" />
        </expandedHeading>
        <snappedHeading>
          <m:Title
            text="{i18n>create.title}"
            wrapping="true" />
        </snappedHeading>

        <actions>
          <!-- Save button -->
          <m:Button
            id="saveButton"
            text="{i18n>create.save}"
            type="Emphasized"
            press=".onSavePress" />

          <!-- Cancel button -->
          <m:Button
            id="cancelButton"
            text="{i18n>create.cancel}"
            press=".onCancelPress" />

          <!-- Close column button -->
          <m:Button
            id="closeButton"
            icon="sap-icon://decline"
            press=".onClosePress"
            type="Transparent" />
        </actions>
      </ObjectPageDynamicHeaderTitle>
    </headerTitle>

    <!-- Header Content -->
    <headerContent>
      <m:FlexBox direction="Column">
        <m:ObjectStatus
          text="{i18n>create.newRecord}"
          state="Information" />
        <m:Text
          text="{view>/entityDisplayName}" />
      </m:FlexBox>
    </headerContent>

    <!-- Sections -->
    <sections>
      <!-- Required Fields Section -->
      <ObjectPageSection
        id="requiredSection"
        title="{i18n>create.section.required}">
        <subSections>
          <ObjectPageSubSection>
            <blocks>
              <f:SimpleForm
                id="requiredForm"
                editable="true"
                layout="ResponsiveGridLayout"
                labelSpanXL="4"
                labelSpanL="4"
                labelSpanM="12"
                labelSpanS="12"
                emptySpanXL="0"
                emptySpanL="0"
                emptySpanM="0"
                emptySpanS="0"
                columnsXL="2"
                columnsL="2"
                columnsM="1"
                singleContainerFullSize="false">

                <!-- Required fields generated by controller -->
                <f:content>
                </f:content>

              </f:SimpleForm>
            </blocks>
          </ObjectPageSubSection>
        </subSections>
      </ObjectPageSection>

      <!-- Optional Fields Section -->
      <ObjectPageSection
        id="optionalSection"
        title="{i18n>create.section.optional}">
        <subSections>
          <ObjectPageSubSection>
            <blocks>
              <f:SimpleForm
                id="optionalForm"
                editable="true"
                layout="ResponsiveGridLayout"
                labelSpanXL="4"
                labelSpanL="4"
                labelSpanM="12"
                labelSpanS="12"
                columnsXL="2"
                columnsL="2"
                columnsM="1">

                <!-- Optional fields generated by controller -->
                <f:content>
                </f:content>

              </f:SimpleForm>
            </blocks>
          </ObjectPageSubSection>
        </subSections>
      </ObjectPageSection>

    </sections>

  </ObjectPageLayout>

</mvc:View>
