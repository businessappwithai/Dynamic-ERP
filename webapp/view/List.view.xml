<!--
  List View - Entity Table (Column 2)

  Displays a growing table of entity records.
  Columns are dynamically generated from sys_field metadata (seq_no_grid order).
  Supports search, filter, sort, and pagination.

  Generated: 2026-03-09T11:47:10.429Z
-->
<mvc:View
  controllerName="hospital-management-system.controller.List"
  xmlns="sap.m"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns:core="sap.ui.core">

  <Page
    id="listPage"
    title="{view>/entityName}"
    showNavButton="true"
    navButtonPress=".onNavBack">

    <customHeader>
      <Bar>
        <contentLeft>
          <Button
            icon="sap-icon://nav-back"
            press=".onNavBack"
            type="Transparent" />
          <Title text="{view>/entityDisplayName}" />
        </contentLeft>
        <contentRight>
          <Button
            id="createButton"
            icon="sap-icon://add"
            text="{i18n>list.create}"
            type="Emphasized"
            press=".onCreatePress" />
        </contentRight>
      </Bar>
    </customHeader>

    <!-- Subheader with search and filter -->
    <subHeader>
      <OverflowToolbar>
        <SearchField
          id="searchField"
          width="40%"
          placeholder="{i18n>list.searchPlaceholder}"
          search=".onSearch"
          liveChange=".onSearch" />

        <ToolbarSpacer />

        <Button
          id="filterButton"
          icon="sap-icon://filter"
          press=".onFilterPress"
          type="Transparent"
          text="{i18n>list.filter}" />

        <Button
          id="sortButton"
          icon="sap-icon://sort"
          press=".onSortPress"
          type="Transparent"
          text="{i18n>list.sort}" />

        <Button
          id="refreshButton"
          icon="sap-icon://refresh"
          press=".onRefresh"
          type="Transparent" />
      </OverflowToolbar>
    </subHeader>

    <content>
      <!-- Growing table with dynamic columns -->
      <Table
        id="entityTable"
        items="{
          path: '{view>/entityPath}',
          parameters: {
            $count: true
          },
          events: {
            dataReceived: '.onDataReceived'
          }
        }"
        growing="true"
        growingThreshold="20"
        growingScrollToLoad="true"
        mode="SingleSelectMaster"
        selectionChange=".onItemSelect"
        busyIndicatorDelay="0">

        <!-- Columns dynamically built from sys_field metadata -->
        <columns>
          <!-- Columns are generated dynamically in controller -->
        </columns>

        <items>
          <ColumnListItem
            type="Navigation"
            press=".onItemPress">
            <!-- Cells are generated dynamically in controller -->
          </ColumnListItem>
        </items>

      </Table>

      <!-- Empty state -->
      <IllustratedMessage
        id="noDataMessage"
        illustrationType="NoSearchResults"
        title="{i18n>list.noData.title}"
        description="{i18n>list.noData.description}"
        visible="{= ${view>/itemCount} === 0 }">
        <additionalContent>
          <Button
            text="{i18n>list.create}"
            press=".onCreatePress"
            type="Emphasized" />
        </additionalContent>
      </IllustratedMessage>

    </content>

    <!-- Info toolbar showing count -->
    <footer>
      <Bar>
        <contentMiddle>
          <Title
            text="{= ${view>/itemCount} + ' ' + ${i18n>list.items} }"
            level="H5" />
        </contentMiddle>
      </Bar>
    </footer>

  </Page>

</mvc:View>
