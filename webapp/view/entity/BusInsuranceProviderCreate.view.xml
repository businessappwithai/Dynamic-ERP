<mvc:View
  controllerName="hospital-management-system.controller.entity.BusInsuranceProviderCreate"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:form="sap.ui.layout.form"
  xmlns:core="sap.ui.core">

  <f:DynamicPage
    headerExpanded="false"
    toggleHeaderOnTitleClick="true"
    busy="{view>/busy}">

    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="Create Bus Insurance Provider" />
        </f:heading>
        <f:actions>
          <Button
            text="Save"
            type="Emphasized"
            icon="sap-icon://save"
            press=".onSavePress" />
          <Button
            text="Cancel"
            press=".onCancelPress" />
        </f:actions>
        <f:navigationActions>
          <Button
            icon="sap-icon://nav-back"
            press=".onNavBack"
            tooltip="Back to List" />
        </f:navigationActions>
      </f:DynamicPageTitle>
    </f:title>

    <f:content>
      <VBox class="sapUiSmallMargin">
        <Panel headerText="General Information" expandable="true">
          <form:SimpleForm
            editable="true"
            layout="ResponsiveGridLayout"
            labelSpanXL="3"
            labelSpanL="3"
            labelSpanM="3"
            labelSpanS="12"
            adjustLabelSpan="false"
            emptySpanXL="4"
            emptySpanL="4"
            emptySpanM="4"
            emptySpanS="0"
            columnsXL="1"
            columnsL="1"
            columnsM="1">
            <Label text="Name" required="true" />
            <Input id="name" value="{view>/formData/name}" />
            <Label text="Contact Person" required="true" />
            <Input id="contact_person" value="{view>/formData/contact_person}" />
            <Label text="Phone" required="true" />
            <Input id="phone" value="{view>/formData/phone}" />
            <Label text="Email" required="true" />
            <Input id="email" value="{view>/formData/email}" />
            <Label text="Address" required="true" />
            <Input id="address" value="{view>/formData/address}" />
            <Label text="Policy Type" required="true" />
            <Input id="policy_type" value="{view>/formData/policy_type}" />
            <Label text="Status" required="true" />
            <Input id="status" value="{view>/formData/status}" />
          </form:SimpleForm>
        </Panel>
      </VBox>
    </f:content>

  </f:DynamicPage>
</mvc:View>
