<mvc:View
  controllerName="hospital-management-system.controller.entity.BusPatientCreate"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:form="sap.ui.layout.form"
  xmlns:core="sap.ui.core">

  <f:DynamicPage
    headerExpanded="false"
    toggleHeaderOnTitleClick="true"
    busy="{view>/busy}">

    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="Create Bus Patient" />
        </f:heading>
        <f:actions>
          <Button
            text="Save"
            type="Emphasized"
            icon="sap-icon://save"
            press=".onSavePress" />
          <Button
            text="Cancel"
            press=".onCancelPress" />
        </f:actions>
        <f:navigationActions>
          <Button
            icon="sap-icon://nav-back"
            press=".onNavBack"
            tooltip="Back to List" />
        </f:navigationActions>
      </f:DynamicPageTitle>
    </f:title>

    <f:content>
      <VBox class="sapUiSmallMargin">
        <Panel headerText="General Information" expandable="true">
          <form:SimpleForm
            editable="true"
            layout="ResponsiveGridLayout"
            labelSpanXL="3"
            labelSpanL="3"
            labelSpanM="3"
            labelSpanS="12"
            adjustLabelSpan="false"
            emptySpanXL="4"
            emptySpanL="4"
            emptySpanM="4"
            emptySpanS="0"
            columnsXL="1"
            columnsL="1"
            columnsM="1">
            <Label text="Uhid" required="true" />
            <Input id="uhid" value="{view>/formData/uhid}" />
            <Label text="Mrn" required="true" />
            <Input id="mrn" value="{view>/formData/mrn}" />
            <Label text="First Name" required="true" />
            <Input id="first_name" value="{view>/formData/first_name}" />
            <Label text="Middle Name" required="true" />
            <Input id="middle_name" value="{view>/formData/middle_name}" />
            <Label text="Last Name" required="true" />
            <Input id="last_name" value="{view>/formData/last_name}" />
            <Label text="Date Of Birth" required="true" />
            <Input id="date_of_birth" value="{view>/formData/date_of_birth}" />
            <Label text="Gender" required="true" />
            <Input id="gender" value="{view>/formData/gender}" />
            <Label text="Blood Group" required="true" />
            <Input id="blood_group" value="{view>/formData/blood_group}" />
            <Label text="Marital Status" required="true" />
            <Input id="marital_status" value="{view>/formData/marital_status}" />
            <Label text="Nationality" required="true" />
            <Input id="nationality" value="{view>/formData/nationality}" />
            <Label text="Email" required="true" />
            <Input id="email" value="{view>/formData/email}" />
            <Label text="Phone" required="true" />
            <Input id="phone" value="{view>/formData/phone}" />
            <Label text="Mobile" required="true" />
            <Input id="mobile" value="{view>/formData/mobile}" />
            <Label text="Address Line1" required="true" />
            <Input id="address_line1" value="{view>/formData/address_line1}" />
            <Label text="City" required="true" />
            <Input id="city" value="{view>/formData/city}" />
            <Label text="State" required="true" />
            <Input id="state" value="{view>/formData/state}" />
            <Label text="Postal Code" required="true" />
            <Input id="postal_code" value="{view>/formData/postal_code}" />
            <Label text="Country" required="true" />
            <Input id="country" value="{view>/formData/country}" />
          </form:SimpleForm>
        </Panel>
      </VBox>
    </f:content>

  </f:DynamicPage>
</mvc:View>
