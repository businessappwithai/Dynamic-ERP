<mvc:View
  controllerName="hospital-management-system.controller.entity.BusLabResultCreate"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:form="sap.ui.layout.form"
  xmlns:core="sap.ui.core">

  <f:DynamicPage
    headerExpanded="false"
    toggleHeaderOnTitleClick="true"
    busy="{view>/busy}">

    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="Create Bus Lab Result" />
        </f:heading>
        <f:actions>
          <Button
            text="Save"
            type="Emphasized"
            icon="sap-icon://save"
            press=".onSavePress" />
          <Button
            text="Cancel"
            press=".onCancelPress" />
        </f:actions>
        <f:navigationActions>
          <Button
            icon="sap-icon://nav-back"
            press=".onNavBack"
            tooltip="Back to List" />
        </f:navigationActions>
      </f:DynamicPageTitle>
    </f:title>

    <f:content>
      <VBox class="sapUiSmallMargin">
        <Panel headerText="General Information" expandable="true">
          <form:SimpleForm
            editable="true"
            layout="ResponsiveGridLayout"
            labelSpanXL="3"
            labelSpanL="3"
            labelSpanM="3"
            labelSpanS="12"
            adjustLabelSpan="false"
            emptySpanXL="4"
            emptySpanL="4"
            emptySpanM="4"
            emptySpanS="0"
            columnsXL="1"
            columnsL="1"
            columnsM="1">
            <Label text="Lab Order Id" required="true" />
            <Input id="lab_order_id" value="{view>/formData/lab_order_id}" />
            <Label text="Test Code" required="true" />
            <Input id="test_code" value="{view>/formData/test_code}" />
            <Label text="Test Name" required="true" />
            <Input id="test_name" value="{view>/formData/test_name}" />
            <Label text="Result Value" required="true" />
            <Input id="result_value" value="{view>/formData/result_value}" />
            <Label text="Unit" required="true" />
            <Input id="unit" value="{view>/formData/unit}" />
            <Label text="Reference Range" required="true" />
            <Input id="reference_range" value="{view>/formData/reference_range}" />
            <Label text="Status" required="true" />
            <Input id="status" value="{view>/formData/status}" />
            <Label text="Performed By" required="true" />
            <Input id="performed_by" value="{view>/formData/performed_by}" />
            <Label text="Resulted At" required="true" />
            <Input id="resulted_at" value="{view>/formData/resulted_at}" />
          </form:SimpleForm>
        </Panel>
      </VBox>
    </f:content>

  </f:DynamicPage>
</mvc:View>
