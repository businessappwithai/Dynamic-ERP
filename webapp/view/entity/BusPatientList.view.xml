<mvc:View
  controllerName="hospital-management-system.controller.entity.BusPatientList"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:semantic="sap.f.semantic"
  xmlns:core="sap.ui.core">

  <semantic:SemanticPage
    headerPinnable="false"
    toggleHeaderOnTitleClick="false"
    busy="{view>/busy}">

    <semantic:titleHeading>
      <VBox>
        <HBox renderBox="true">
          <Text text="{view>/itemCount} of {view>/totalCount}" class="sapMTitleSampleStyle" />
        </HBox>
        <Title text="Patients" />
      </VBox>
    </semantic:titleHeading>

    <semantic:headerContent>
      <HBox alignItems="Center" justifyContent="SpaceBetween" width="100%">
        <VBox>
          <SearchField
            id="quickSearchField"
            placeholder="Quick search in loaded data..."
            search=".onQuickSearch"
            width="20rem" />
        </VBox>
        <HBox>
          <Button
            text="Advanced Search"
            icon="sap-icon://filter"
            type="Transparent"
            press=".onToggleAdvancedSearch" />
          <Button
            icon="sap-icon://refresh"
            type="Transparent"
            press=".onRefresh"
            tooltip="Refresh" />
        </HBox>
      </HBox>

      <Panel
        visible="{view>/advancedSearchVisible}"
        expandable="false"
        width="100%">
        <HBox alignItems="Center" class="sapUiSmallMargin">
          <Select id="advSearchField" width="10rem">
            <core:Item key="uhid" text="Uhid" />
            <core:Item key="mrn" text="Mrn" />
            <core:Item key="first_name" text="First Name" />
            <core:Item key="middle_name" text="Middle Name" />
            <core:Item key="last_name" text="Last Name" />
            <core:Item key="date_of_birth" text="Date Of Birth" />
            <core:Item key="gender" text="Gender" />
            <core:Item key="blood_group" text="Blood Group" />
            <core:Item key="marital_status" text="Marital Status" />
            <core:Item key="nationality" text="Nationality" />
            <core:Item key="passport_number" text="Passport Number" />
            <core:Item key="email" text="Email" />
            <core:Item key="phone" text="Phone" />
            <core:Item key="mobile" text="Mobile" />
            <core:Item key="address_line1" text="Address Line1" />
            <core:Item key="address_line2" text="Address Line2" />
            <core:Item key="city" text="City" />
            <core:Item key="state" text="State" />
            <core:Item key="postal_code" text="Postal Code" />
            <core:Item key="country" text="Country" />
            <core:Item key="emergency_contact_name" text="Emergency Contact Name" />
            <core:Item key="emergency_contact_phone" text="Emergency Contact Phone" />
            <core:Item key="emergency_contact_relation" text="Emergency Contact Relation" />
            <core:Item key="photo_url" text="Photo Url" />
            <core:Item key="biometric_data" text="Biometric Data" />
            <core:Item key="is_vip" text="Is Vip" />
            <core:Item key="is_active" text="Is Active" />
            <core:Item key="registered_at" text="Registered At" />
          </Select>
          <Select id="advSearchOperator" width="8rem" class="sapUiTinyMarginBegin">
            <core:Item key="Contains" text="Contains" />
            <core:Item key="EQ" text="Equals" />
            <core:Item key="StartsWith" text="Starts With" />
            <core:Item key="EndsWith" text="Ends With" />
            <core:Item key="GT" text="Greater Than" />
            <core:Item key="LT" text="Less Than" />
          </Select>
          <Input id="advSearchValue" placeholder="Search value..." width="12rem" class="sapUiTinyMarginBegin"
            submit=".onAdvancedSearch" />
          <Button text="Search" type="Emphasized" press=".onAdvancedSearch" class="sapUiTinyMarginBegin" />
          <Button text="Clear" press=".onClearAdvancedSearch" class="sapUiTinyMarginBegin" />
        </HBox>
      </Panel>
    </semantic:headerContent>

    <semantic:content>
      <Table
        id="entityTable"
        growing="true"
        growingThreshold="20"
        growingScrollToLoad="true"
        mode="SingleSelectMaster"
        selectionChange=".onItemPress"
        noDataText="No Bus Patient records found"
        class="sapUiResponsiveMargin"
        width="auto">
        <headerToolbar>
          <OverflowToolbar>
            <Title text="Bus Patient Records" level="H3" />
            <ToolbarSpacer />
          </OverflowToolbar>
        </headerToolbar>
      </Table>
    </semantic:content>

    <semantic:addAction>
      <semantic:AddAction press=".onCreatePress" />
    </semantic:addAction>

  </semantic:SemanticPage>
</mvc:View>
