<mvc:View
  controllerName="hospital-management-system.controller.entity.BusVitalSignDetail"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:form="sap.ui.layout.form"
  xmlns:core="sap.ui.core">

  <f:DynamicPage
    headerExpanded="true"
    toggleHeaderOnTitleClick="true"
    busy="{view>/busy}">

    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="Bus Vital Sign: {}" />
        </f:heading>
        <f:actions>
          <Button
            text="Edit"
            type="Emphasized"
            icon="sap-icon://edit"
            press=".onEditPress"
            visible="{= !${view>/editable} }" />
          <Button
            text="Save"
            type="Emphasized"
            icon="sap-icon://save"
            press=".onSavePress"
            visible="{view>/editable}" />
          <Button
            text="Cancel"
            press=".onCancelPress"
            visible="{view>/editable}" />
          <Button
            text="Delete"
            type="Reject"
            icon="sap-icon://delete"
            press=".onDeletePress"
            visible="{= !${view>/editable} }" />
        </f:actions>
        <f:navigationActions>
          <Button
            icon="sap-icon://nav-back"
            press=".onNavBack"
            tooltip="Back to List" />
        </f:navigationActions>
      </f:DynamicPageTitle>
    </f:title>

    <f:content>
      <VBox class="sapUiSmallMargin">
        <Panel headerText="General Information" expandable="true" expanded="true">
          <form:SimpleForm
            editable="{view>/editable}"
            layout="ResponsiveGridLayout"
            labelSpanXL="3"
            labelSpanL="3"
            labelSpanM="3"
            labelSpanS="12"
            adjustLabelSpan="false"
            emptySpanXL="4"
            emptySpanL="4"
            emptySpanM="4"
            emptySpanS="0"
            columnsXL="1"
            columnsL="1"
            columnsM="1">
            <Label text="Recorded Date" required="true" />
            <DatePicker value="{path: 'recorded_date'}" editable="{view>/editable}" />
            <Label text="Recorded By" required="true" />
            <Input value="{recorded_by}" editable="{view>/editable}"  />
                        <Label text="Temperature" required="true" />
            <Input value="{temperature}" editable="{view>/editable}" type="Number" />
            <Label text="Pulse" required="true" />
            <Input value="{pulse}" editable="{view>/editable}" type="Number" />
            <Label text="Respiration" required="true" />
            <Input value="{respiration}" editable="{view>/editable}" type="Number" />
            <Label text="Systolic Bp" required="true" />
            <Input value="{systolic_bp}" editable="{view>/editable}" type="Number" />
            <Label text="Diastolic Bp" required="true" />
            <Input value="{diastolic_bp}" editable="{view>/editable}" type="Number" />
            <Label text="Oxygen Saturation" required="true" />
            <Input value="{oxygen_saturation}" editable="{view>/editable}" type="Number" />
            <Label text="Weight" required="true" />
            <Input value="{weight}" editable="{view>/editable}" type="Number" />
            <Label text="Height" required="true" />
            <Input value="{height}" editable="{view>/editable}" type="Number" />
            <Label text="Blood Glucose" required="true" />
            <Input value="{blood_glucose}" editable="{view>/editable}" type="Number" />
            <Label text="Notes" required="true" />
            <TextArea value="{notes}" editable="{view>/editable}" rows="3" width="100%" />
          </form:SimpleForm>
        </Panel>

        <Panel headerText="Audit Information" expandable="true" expanded="false">
          <form:SimpleForm
            editable="false"
            layout="ResponsiveGridLayout"
            labelSpanL="3" labelSpanM="3" labelSpanS="12">
            <Label text="Created At" />
            <Text text="{path: 'created_at', formatter: '.formatDate'}" />
            <Label text="Updated At" />
            <Text text="{path: 'updated_at', formatter: '.formatDate'}" />
          </form:SimpleForm>
        </Panel>
      </VBox>
    </f:content>

  </f:DynamicPage>
</mvc:View>
