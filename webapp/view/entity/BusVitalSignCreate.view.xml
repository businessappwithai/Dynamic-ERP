<mvc:View
  controllerName="hospital-management-system.controller.entity.BusVitalSignCreate"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:form="sap.ui.layout.form"
  xmlns:core="sap.ui.core">

  <f:DynamicPage
    headerExpanded="false"
    toggleHeaderOnTitleClick="true"
    busy="{view>/busy}">

    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="Create Bus Vital Sign" />
        </f:heading>
        <f:actions>
          <Button
            text="Save"
            type="Emphasized"
            icon="sap-icon://save"
            press=".onSavePress" />
          <Button
            text="Cancel"
            press=".onCancelPress" />
        </f:actions>
        <f:navigationActions>
          <Button
            icon="sap-icon://nav-back"
            press=".onNavBack"
            tooltip="Back to List" />
        </f:navigationActions>
      </f:DynamicPageTitle>
    </f:title>

    <f:content>
      <VBox class="sapUiSmallMargin">
        <Panel headerText="General Information" expandable="true">
          <form:SimpleForm
            editable="true"
            layout="ResponsiveGridLayout"
            labelSpanXL="3"
            labelSpanL="3"
            labelSpanM="3"
            labelSpanS="12"
            adjustLabelSpan="false"
            emptySpanXL="4"
            emptySpanL="4"
            emptySpanM="4"
            emptySpanS="0"
            columnsXL="1"
            columnsL="1"
            columnsM="1">
            <Label text="Patient Id" required="true" />
            <Input id="patient_id" value="{view>/formData/patient_id}" />
            <Label text="Encounter Id" required="true" />
            <Input id="encounter_id" value="{view>/formData/encounter_id}" />
            <Label text="Height" required="true" />
            <Input id="height" value="{view>/formData/height}" />
            <Label text="Weight" required="true" />
            <Input id="weight" value="{view>/formData/weight}" />
            <Label text="Temperature" required="true" />
            <Input id="temperature" value="{view>/formData/temperature}" />
            <Label text="Blood Pressure Systolic" required="true" />
            <Input id="blood_pressure_systolic" value="{view>/formData/blood_pressure_systolic}" />
            <Label text="Blood Pressure Diastolic" required="true" />
            <Input id="blood_pressure_diastolic" value="{view>/formData/blood_pressure_diastolic}" />
            <Label text="Pulse Rate" required="true" />
            <Input id="pulse_rate" value="{view>/formData/pulse_rate}" />
            <Label text="Respiratory Rate" required="true" />
            <Input id="respiratory_rate" value="{view>/formData/respiratory_rate}" />
            <Label text="Spo2" required="true" />
            <Input id="spo2" value="{view>/formData/spo2}" />
            <Label text="Recorded At" required="true" />
            <Input id="recorded_at" value="{view>/formData/recorded_at}" />
          </form:SimpleForm>
        </Panel>
      </VBox>
    </f:content>

  </f:DynamicPage>
</mvc:View>
