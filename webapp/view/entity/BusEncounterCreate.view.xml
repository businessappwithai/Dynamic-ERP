<mvc:View
  controllerName="hospital-management-system.controller.entity.BusEncounterCreate"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:form="sap.ui.layout.form"
  xmlns:core="sap.ui.core">

  <f:DynamicPage
    headerExpanded="false"
    toggleHeaderOnTitleClick="true"
    busy="{view>/busy}">

    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="Create Bus Encounter" />
        </f:heading>
        <f:actions>
          <Button
            text="Save"
            type="Emphasized"
            icon="sap-icon://save"
            press=".onSavePress" />
          <Button
            text="Cancel"
            press=".onCancelPress" />
        </f:actions>
        <f:navigationActions>
          <Button
            icon="sap-icon://nav-back"
            press=".onNavBack"
            tooltip="Back to List" />
        </f:navigationActions>
      </f:DynamicPageTitle>
    </f:title>

    <f:content>
      <VBox class="sapUiSmallMargin">
        <Panel headerText="General Information" expandable="true">
          <form:SimpleForm
            editable="true"
            layout="ResponsiveGridLayout"
            labelSpanXL="3"
            labelSpanL="3"
            labelSpanM="3"
            labelSpanS="12"
            adjustLabelSpan="false"
            emptySpanXL="4"
            emptySpanL="4"
            emptySpanM="4"
            emptySpanS="0"
            columnsXL="1"
            columnsL="1"
            columnsM="1">
            <Label text="Patient Id" required="true" />
            <Input id="patient_id" value="{view>/formData/patient_id}" />
            <Label text="Encounter Type" required="true" />
            <Input id="encounter_type" value="{view>/formData/encounter_type}" />
            <Label text="Encounter Date" required="true" />
            <Input id="encounter_date" value="{view>/formData/encounter_date}" />
            <Label text="Encounter Time" required="true" />
            <Input id="encounter_time" value="{view>/formData/encounter_time}" />
            <Label text="Department Id" required="true" />
            <Input id="department_id" value="{view>/formData/department_id}" />
            <Label text="Staff Id" required="true" />
            <Input id="staff_id" value="{view>/formData/staff_id}" />
            <Label text="Chief Complaint" required="true" />
            <Input id="chief_complaint" value="{view>/formData/chief_complaint}" />
            <Label text="Status" required="true" />
            <Input id="status" value="{view>/formData/status}" />
            <Label text="Priority" required="true" />
            <Input id="priority" value="{view>/formData/priority}" />
          </form:SimpleForm>
        </Panel>
      </VBox>
    </f:content>

  </f:DynamicPage>
</mvc:View>
