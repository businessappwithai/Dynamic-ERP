<mvc:View
  controllerName="hospital-management-system.controller.entity.BusPatientDetail"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:uxap="sap.uxap"
  xmlns:f="sap.f"
  xmlns:form="sap.ui.layout.form"
  xmlns:core="sap.ui.core">

  <uxap:ObjectPageLayout
    id="objectPageLayout"
    height="100%"
    showAnchorBar="true"
    showAnchorBarPopover="true"
    busy="{view>/busy}">

    <uxap:headerTitle>
      <uxap:ObjectPageHeader
        id="objectPageHeader"
        objectTitle="{uhid}"
        objectSubtitle="{first_name} {last_name}"
        objectImageURI="{photo_url}"
        objectImageShape="Circle"
        initials="{path: 'first_name', formatter: '.getInitials'}"
        isObjectIconAlwaysVisible="false"
        isObjectTitleAlwaysVisible="false"
        isObjectSubtitleAlwaysVisible="false"
        showPlaceholder="true">

        <uxap:actions>
          <uxap:ObjectPageHeaderActionButton
            text="Edit"
            type="Emphasized"
            icon="sap-icon://edit"
            press=".onEditPress"
            visible="{= !${view>/editable} }" />
          <uxap:ObjectPageHeaderActionButton
            text="Save"
            type="Emphasized"
            icon="sap-icon://save"
            press=".onSavePress"
            visible="{view>/editable}" />
          <uxap:ObjectPageHeaderActionButton
            text="Cancel"
            icon="sap-icon://cancel"
            press=".onCancelPress"
            visible="{view>/editable}" />
          <uxap:ObjectPageHeaderActionButton
            text="Delete"
            type="Reject"
            icon="sap-icon://delete"
            press=".onDeletePress"
            visible="{= !${view>/editable} }" />
          <uxap:ObjectPageHeaderActionButton
            icon="sap-icon://full-screen"
            press=".onFullScreen"
            tooltip="Full Screen" />
          <uxap:ObjectPageHeaderActionButton
            icon="sap-icon://exit-full-screen"
            press=".onExitFullScreen"
            tooltip="Exit Full Screen" />
          <uxap:ObjectPageHeaderActionButton
            icon="sap-icon://nav-back"
            press=".onNavBack"
            tooltip="Back" />
        </uxap:actions>

      </uxap:ObjectPageHeader>
    </uxap:headerTitle>

    <uxap:headerContent>
      <uxap:ObjectPageHeaderContent>
        <uxap:content>
          <!-- Patient Key Information -->
          <HBox>
            <core:Icon src="sap-icon://id-card" size="1.5rem" class="sapUiSmallMarginEnd" />
            <VBox>
              <Label text="Medical Record Number" />
              <Text text="{mrn}" />
            </VBox>
          </HBox>

          <HBox>
            <core:Icon src="sap-icon://calendar" size="1.5rem" class="sapUiSmallMarginEnd" />
            <VBox>
              <Label text="Date of Birth" />
              <Text text="{path: 'date_of_birth', formatter: '.formatDate'}" />
            </VBox>
          </HBox>

          <HBox>
            <core:Icon src="sap-icon://gender" size="1.5rem" class="sapUiSmallMarginEnd" />
            <VBox>
              <Label text="Gender" />
              <Text text="{gender}" />
            </VBox>
          </HBox>

          <HBox>
            <core:Icon src="sap-icon://drops" size="1.5rem" class="sapUiSmallMarginEnd" />
            <VBox>
              <Label text="Blood Group" />
              <Text text="{blood_group}" />
            </VBox>
          </HBox>

          <HBox>
            <core:Icon src="sap-icon://marital-status" size="1.5rem" class="sapUiSmallMarginEnd" />
            <VBox>
              <Label text="Marital Status" />
              <Text text="{marital_status}" />
            </VBox>
          </HBox>

          <HBox>
            <core:Icon src="sap-icon://phone" size="1.5rem" class="sapUiSmallMarginEnd" />
            <VBox>
              <Label text="Phone" />
              <Text text="{phone}" />
            </VBox>
          </HBox>

          <HBox>
            <core:Icon src="sap-icon://mobile" size="1.5rem" class="sapUiSmallMarginEnd" />
            <VBox>
              <Label text="Mobile" />
              <Text text="{mobile}" />
            </VBox>
          </HBox>

          <HBox>
            <core:Icon src="sap-icon://email" size="1.5rem" class="sapUiSmallMarginEnd" />
            <VBox>
              <Label text="Email" />
              <Text text="{email}" />
            </VBox>
          </HBox>
        </uxap:content>
      </uxap:ObjectPageHeaderContent>
    </uxap:headerContent>

    <!-- Personal Information Section -->
    <uxap:sections>
      <uxap:ObjectPageSection title="Personal Information" importance="High">
        <uxap:subSections>
          <uxap:ObjectPageSubSection title="Basic Details">
            <uxap:blocks>
                <form:SimpleForm
                    editable="{view>/editable}"
                    layout="ResponsiveGridLayout"
                    labelSpanXL="3"
                    labelSpanL="3"
                    labelSpanM="3"
                    labelSpanS="12"
                    adjustLabelSpan="false"
                    emptySpanXL="4"
                    emptySpanL="4"
                    emptySpanM="4"
                    emptySpanS="0"
                    columnsXL="2"
                    columnsL="2"
                    columnsM="1">

                    <Label text="UHID" required="true" />
                    <Input value="{uhid}" editable="{view>/editable}" />

                    <Label text="MRN" required="true" />
                    <Input value="{mrn}" editable="{view>/editable}" />

                    <Label text="First Name" required="true" />
                    <Input value="{first_name}" editable="{view>/editable}" />

                    <Label text="Middle Name" required="true" />
                    <Input value="{middle_name}" editable="{view>/editable}" />

                    <Label text="Last Name" required="true" />
                    <Input value="{last_name}" editable="{view>/editable}" />

                    <Label text="Date of Birth" required="true" />
                    <DatePicker
                      value="{path: 'date_of_birth'}"
                      editable="{view>/editable}"
                      displayFormat="yyyy-MM-dd"
                      valueFormat="yyyy-MM-dd" />

                    <Label text="Gender" required="true" />
                    <Input value="{gender}" editable="{view>/editable}" />

                    <Label text="Blood Group" required="true" />
                    <Input value="{blood_group}" editable="{view>/editable}" />

                    <Label text="Marital Status" required="true" />
                    <Input value="{marital_status}" editable="{view>/editable}" />

                    <Label text="Nationality" required="true" />
                    <Input value="{nationality}" editable="{view>/editable}" />

                    <Label text="Passport Number" required="true" />
                    <Input value="{passport_number}" editable="{view>/editable}" />

                    <Label text="Is VIP" required="true" />
                    <CheckBox selected="{is_vip}" enabled="{view>/editable}" />

                    <Label text="Is Active" required="true" />
                    <CheckBox selected="{is_active}" enabled="{view>/editable}" />

                  </form:SimpleForm>
            </uxap:blocks>
          </uxap:ObjectPageSubSection>
        </uxap:subSections>
      </uxap:ObjectPageSection>

      <!-- Contact Information Section -->
      <uxap:ObjectPageSection title="Contact Information" importance="Medium">
        <uxap:subSections>
          <uxap:ObjectPageSubSection title="Address &amp; Contact">
            <uxap:blocks>
                <form:SimpleForm
                    editable="{view>/editable}"
                    layout="ResponsiveGridLayout"
                    labelSpanXL="3"
                    labelSpanL="3"
                    labelSpanM="3"
                    labelSpanS="12"
                    adjustLabelSpan="false"
                    emptySpanXL="4"
                    emptySpanL="4"
                    emptySpanM="4"
                    emptySpanS="0"
                    columnsXL="2"
                    columnsL="2"
                    columnsM="1">

                    <Label text="Email" required="true" />
                    <Input value="{email}" editable="{view>/editable}" />

                    <Label text="Phone" required="true" />
                    <Input value="{phone}" editable="{view>/editable}" />

                    <Label text="Mobile" required="true" />
                    <Input value="{mobile}" editable="{view>/editable}" />

                    <Label text="Address Line 1" required="true" />
                    <Input value="{address_line1}" editable="{view>/editable}" />

                    <Label text="Address Line 2" required="true" />
                    <Input value="{address_line2}" editable="{view>/editable}" />

                    <Label text="City" required="true" />
                    <Input value="{city}" editable="{view>/editable}" />

                    <Label text="State" required="true" />
                    <Input value="{state}" editable="{view>/editable}" />

                    <Label text="Postal Code" required="true" />
                    <Input value="{postal_code}" editable="{view>/editable}" />

                    <Label text="Country" required="true" />
                    <Input value="{country}" editable="{view>/editable}" />

                  </form:SimpleForm>
            </uxap:blocks>
          </uxap:ObjectPageSubSection>
        </uxap:subSections>
      </uxap:ObjectPageSection>

      <!-- Emergency Contact Section -->
      <uxap:ObjectPageSection title="Emergency Contact" importance="Medium">
        <uxap:subSections>
          <uxap:ObjectPageSubSection title="Emergency Details">
            <uxap:blocks>
                <form:SimpleForm
                    editable="{view>/editable}"
                    layout="ResponsiveGridLayout"
                    labelSpanXL="3"
                    labelSpanL="3"
                    labelSpanM="3"
                    labelSpanS="12"
                    adjustLabelSpan="false"
                    emptySpanXL="4"
                    emptySpanL="4"
                    emptySpanM="4"
                    emptySpanS="0"
                    columnsXL="2"
                    columnsL="2"
                    columnsM="1">

                    <Label text="Emergency Contact Name" required="true" />
                    <Input value="{emergency_contact_name}" editable="{view>/editable}" />

                    <Label text="Emergency Contact Phone" required="true" />
                    <Input value="{emergency_contact_phone}" editable="{view>/editable}" />

                    <Label text="Emergency Contact Relation" required="true" />
                    <Input value="{emergency_contact_relation}" editable="{view>/editable}" />

                  </form:SimpleForm>
            </uxap:blocks>
          </uxap:ObjectPageSubSection>
        </uxap:subSections>
      </uxap:ObjectPageSection>

      <!-- Additional Information Section -->
      <uxap:ObjectPageSection title="Additional Information" importance="Low">
        <uxap:subSections>
          <uxap:ObjectPageSubSection title="Other Details">
            <uxap:blocks>
                <form:SimpleForm
                    editable="{view>/editable}"
                    layout="ResponsiveGridLayout"
                    labelSpanXL="3"
                    labelSpanL="3"
                    labelSpanM="3"
                    labelSpanS="12"
                    adjustLabelSpan="false"
                    emptySpanXL="4"
                    emptySpanL="4"
                    emptySpanM="4"
                    emptySpanS="0"
                    columnsXL="2"
                    columnsL="2"
                    columnsM="1">

                    <Label text="Photo URL" required="true" />
                    <Input value="{photo_url}" editable="{view>/editable}" />

                    <Label text="Biometric Data" required="true" />
                    <Input value="{biometric_data}" editable="{view>/editable}" />

                    <Label text="Registered At" required="true" />
                    <DateTimePicker
                      value="{path: 'registered_at'}"
                      editable="{view>/editable}"
                      displayFormat="yyyy-MM-dd HH:mm:ss"
                      valueFormat="yyyy-MM-dd HH:mm:ss" />

                  </form:SimpleForm>
            </uxap:blocks>
          </uxap:ObjectPageSubSection>
        </uxap:subSections>
      </uxap:ObjectPageSection>

      <!-- Audit Information Section -->
      <uxap:ObjectPageSection title="Audit Information" importance="Low">
        <uxap:subSections>
          <uxap:ObjectPageSubSection title="System Information">
            <uxap:blocks>
                <form:SimpleForm
                    editable="false"
                    layout="ResponsiveGridLayout"
                    labelSpanL="3" labelSpanM="3" labelSpanS="12"
                    emptySpanL="4" emptySpanM="4" emptySpanS="0">
                    <Label text="Created At" />
                    <Text text="{path: 'created_at', formatter: '.formatDate'}" />
                    <Label text="Updated At" />
                    <Text text="{path: 'updated_at', formatter: '.formatDate'}" />
                  </form:SimpleForm>
            </uxap:blocks>
          </uxap:ObjectPageSubSection>
        </uxap:subSections>
      </uxap:ObjectPageSection>

      <!-- Related Information - Expandable/Collapsible Child Tabs with Lazy Loading -->
      <uxap:ObjectPageSection title="Related Information" importance="Medium">
        <uxap:subSections>
          <uxap:ObjectPageSubSection>
            <uxap:blocks>
              <!-- Child tabs will be dynamically rendered here -->
              <VBox id="childTabsContainer">
                <Text text="Loading child tabs..." visible="{view>/busy}" />
              </VBox>
            </uxap:blocks>
          </uxap:ObjectPageSubSection>
        </uxap:subSections>
      </uxap:ObjectPageSection>

    </uxap:sections>

  </uxap:ObjectPageLayout>

</mvc:View>
