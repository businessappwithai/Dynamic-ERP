<mvc:View
  controllerName="hospital-management-system.controller.entity.BusPrescriptionDetail"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:form="sap.ui.layout.form"
  xmlns:core="sap.ui.core">

  <f:DynamicPage
    headerExpanded="true"
    toggleHeaderOnTitleClick="true"
    busy="{view>/busy}">

    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="Bus Prescription: {}" />
        </f:heading>
        <f:actions>
          <Button
            text="Edit"
            type="Emphasized"
            icon="sap-icon://edit"
            press=".onEditPress"
            visible="{= !${view>/editable} }" />
          <Button
            text="Save"
            type="Emphasized"
            icon="sap-icon://save"
            press=".onSavePress"
            visible="{view>/editable}" />
          <Button
            text="Cancel"
            press=".onCancelPress"
            visible="{view>/editable}" />
          <Button
            text="Delete"
            type="Reject"
            icon="sap-icon://delete"
            press=".onDeletePress"
            visible="{= !${view>/editable} }" />
        </f:actions>
        <f:navigationActions>
          <Button
            icon="sap-icon://nav-back"
            press=".onNavBack"
            tooltip="Back to List" />
        </f:navigationActions>
      </f:DynamicPageTitle>
    </f:title>

    <f:content>
      <VBox class="sapUiSmallMargin">
        <Panel headerText="General Information" expandable="true" expanded="true">
          <form:SimpleForm
            editable="{view>/editable}"
            layout="ResponsiveGridLayout"
            labelSpanXL="3"
            labelSpanL="3"
            labelSpanM="3"
            labelSpanS="12"
            adjustLabelSpan="false"
            emptySpanXL="4"
            emptySpanL="4"
            emptySpanM="4"
            emptySpanS="0"
            columnsXL="1"
            columnsL="1"
            columnsM="1">
            <Label text="Prescribed Date" required="true" />
            <DatePicker value="{path: 'prescribed_date'}" editable="{view>/editable}" />
            <Label text="Prescribed By" required="true" />
            <Input value="{prescribed_by}" editable="{view>/editable}"  />
                        <Label text="Dosage" required="true" />
            <Input value="{dosage}" editable="{view>/editable}"  />
                        <Label text="Frequency" required="true" />
            <Input value="{frequency}" editable="{view>/editable}"  />
                        <Label text="Route" required="true" />
            <Input value="{route}" editable="{view>/editable}"  />
                        <Label text="Duration Days" required="true" />
            <Input value="{duration_days}" editable="{view>/editable}" type="Number" />
            <Label text="Status" required="true" />
            <Input value="{status}" editable="{view>/editable}"  />
                        <Label text="Notes" required="true" />
            <TextArea value="{notes}" editable="{view>/editable}" rows="3" width="100%" />
          </form:SimpleForm>
        </Panel>

        <Panel headerText="Audit Information" expandable="true" expanded="false">
          <form:SimpleForm
            editable="false"
            layout="ResponsiveGridLayout"
            labelSpanL="3" labelSpanM="3" labelSpanS="12">
            <Label text="Created At" />
            <Text text="{path: 'created_at', formatter: '.formatDate'}" />
            <Label text="Updated At" />
            <Text text="{path: 'updated_at', formatter: '.formatDate'}" />
          </form:SimpleForm>
        </Panel>
      </VBox>
    </f:content>

  </f:DynamicPage>
</mvc:View>
