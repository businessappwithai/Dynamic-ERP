<mvc:View
  controllerName="hospital-management-system.controller.entity.BusVitalSignList"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:semantic="sap.f.semantic"
  xmlns:core="sap.ui.core">

  <semantic:SemanticPage
    headerPinnable="false"
    toggleHeaderOnTitleClick="false"
    busy="{view>/busy}">

    <semantic:titleHeading>
      <VBox>
        <HBox renderBox="true">
          <Text text="{view>/itemCount} of {view>/totalCount}" class="sapMTitleSampleStyle" />
        </HBox>
        <Title text="Vital Signs" />
      </VBox>
    </semantic:titleHeading>

    <semantic:headerContent>
      <HBox alignItems="Center" justifyContent="SpaceBetween" width="100%">
        <VBox>
          <SearchField
            id="quickSearchField"
            placeholder="Quick search in loaded data..."
            search=".onQuickSearch"
            width="20rem" />
        </VBox>
        <HBox>
          <Button
            text="Advanced Search"
            icon="sap-icon://filter"
            type="Transparent"
            press=".onToggleAdvancedSearch" />
          <Button
            icon="sap-icon://refresh"
            type="Transparent"
            press=".onRefresh"
            tooltip="Refresh" />
        </HBox>
      </HBox>

      <Panel
        visible="{view>/advancedSearchVisible}"
        expandable="false"
        width="100%">
        <HBox alignItems="Center" class="sapUiSmallMargin">
          <Select id="advSearchField" width="10rem">
            <core:Item key="recorded_date" text="Recorded Date" />
            <core:Item key="recorded_by" text="Recorded By" />
            <core:Item key="temperature" text="Temperature" />
            <core:Item key="pulse" text="Pulse" />
            <core:Item key="respiration" text="Respiration" />
            <core:Item key="systolic_bp" text="Systolic Bp" />
            <core:Item key="diastolic_bp" text="Diastolic Bp" />
            <core:Item key="oxygen_saturation" text="Oxygen Saturation" />
            <core:Item key="weight" text="Weight" />
            <core:Item key="height" text="Height" />
            <core:Item key="blood_glucose" text="Blood Glucose" />
            <core:Item key="notes" text="Notes" />
          </Select>
          <Select id="advSearchOperator" width="8rem" class="sapUiTinyMarginBegin">
            <core:Item key="Contains" text="Contains" />
            <core:Item key="EQ" text="Equals" />
            <core:Item key="StartsWith" text="Starts With" />
            <core:Item key="EndsWith" text="Ends With" />
            <core:Item key="GT" text="Greater Than" />
            <core:Item key="LT" text="Less Than" />
          </Select>
          <Input id="advSearchValue" placeholder="Search value..." width="12rem" class="sapUiTinyMarginBegin"
            submit=".onAdvancedSearch" />
          <Button text="Search" type="Emphasized" press=".onAdvancedSearch" class="sapUiTinyMarginBegin" />
          <Button text="Clear" press=".onClearAdvancedSearch" class="sapUiTinyMarginBegin" />
        </HBox>
      </Panel>
    </semantic:headerContent>

    <semantic:content>
      <Table
        id="entityTable"
        growing="true"
        growingThreshold="20"
        growingScrollToLoad="true"
        mode="SingleSelectMaster"
        selectionChange=".onItemPress"
        noDataText="No Bus Vital Sign records found"
        class="sapUiResponsiveMargin"
        width="auto">
        <headerToolbar>
          <OverflowToolbar>
            <Title text="Bus Vital Sign Records" level="H3" />
            <ToolbarSpacer />
          </OverflowToolbar>
        </headerToolbar>
      </Table>
    </semantic:content>

    <semantic:addAction>
      <semantic:AddAction press=".onCreatePress" />
    </semantic:addAction>

  </semantic:SemanticPage>
</mvc:View>
