<mvc:View
  controllerName="hospital-management-system.controller.entity.BusDiagnosisCreate"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:form="sap.ui.layout.form"
  xmlns:core="sap.ui.core">

  <f:DynamicPage
    headerExpanded="false"
    toggleHeaderOnTitleClick="true"
    busy="{view>/busy}">

    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="Create Bus Diagnosis" />
        </f:heading>
        <f:actions>
          <Button
            text="Save"
            type="Emphasized"
            icon="sap-icon://save"
            press=".onSavePress" />
          <Button
            text="Cancel"
            press=".onCancelPress" />
        </f:actions>
        <f:navigationActions>
          <Button
            icon="sap-icon://nav-back"
            press=".onNavBack"
            tooltip="Back to List" />
        </f:navigationActions>
      </f:DynamicPageTitle>
    </f:title>

    <f:content>
      <VBox class="sapUiSmallMargin">
        <Panel headerText="General Information" expandable="true">
          <form:SimpleForm
            editable="true"
            layout="ResponsiveGridLayout"
            labelSpanXL="3"
            labelSpanL="3"
            labelSpanM="3"
            labelSpanS="12"
            adjustLabelSpan="false"
            emptySpanXL="4"
            emptySpanL="4"
            emptySpanM="4"
            emptySpanS="0"
            columnsXL="1"
            columnsL="1"
            columnsM="1">
            <Label text="Patient Id" required="true" />
            <Input id="patient_id" value="{view>/formData/patient_id}" />
            <Label text="Encounter Id" required="true" />
            <Input id="encounter_id" value="{view>/formData/encounter_id}" />
            <Label text="Diagnosis Code" required="true" />
            <Input id="diagnosis_code" value="{view>/formData/diagnosis_code}" />
            <Label text="Diagnosis Name" required="true" />
            <Input id="diagnosis_name" value="{view>/formData/diagnosis_name}" />
            <Label text="Diagnosis Type" required="true" />
            <Input id="diagnosis_type" value="{view>/formData/diagnosis_type}" />
            <Label text="Severity" required="true" />
            <Input id="severity" value="{view>/formData/severity}" />
            <Label text="Status" required="true" />
            <Input id="status" value="{view>/formData/status}" />
            <Label text="Diagnosed By" required="true" />
            <Input id="diagnosed_by" value="{view>/formData/diagnosed_by}" />
            <Label text="Diagnosed At" required="true" />
            <Input id="diagnosed_at" value="{view>/formData/diagnosed_at}" />
          </form:SimpleForm>
        </Panel>
      </VBox>
    </f:content>

  </f:DynamicPage>
</mvc:View>
