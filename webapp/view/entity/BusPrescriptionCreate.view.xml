<mvc:View
  controllerName="hospital-management-system.controller.entity.BusPrescriptionCreate"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:form="sap.ui.layout.form"
  xmlns:core="sap.ui.core">

  <f:DynamicPage
    headerExpanded="false"
    toggleHeaderOnTitleClick="true"
    busy="{view>/busy}">

    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="Create Bus Prescription" />
        </f:heading>
        <f:actions>
          <Button
            text="Save"
            type="Emphasized"
            icon="sap-icon://save"
            press=".onSavePress" />
          <Button
            text="Cancel"
            press=".onCancelPress" />
        </f:actions>
        <f:navigationActions>
          <Button
            icon="sap-icon://nav-back"
            press=".onNavBack"
            tooltip="Back to List" />
        </f:navigationActions>
      </f:DynamicPageTitle>
    </f:title>

    <f:content>
      <VBox class="sapUiSmallMargin">
        <Panel headerText="General Information" expandable="true">
          <form:SimpleForm
            editable="true"
            layout="ResponsiveGridLayout"
            labelSpanXL="3"
            labelSpanL="3"
            labelSpanM="3"
            labelSpanS="12"
            adjustLabelSpan="false"
            emptySpanXL="4"
            emptySpanL="4"
            emptySpanM="4"
            emptySpanS="0"
            columnsXL="1"
            columnsL="1"
            columnsM="1">
            <Label text="Patient Id" required="true" />
            <Input id="patient_id" value="{view>/formData/patient_id}" />
            <Label text="Encounter Id" required="true" />
            <Input id="encounter_id" value="{view>/formData/encounter_id}" />
            <Label text="Medication Name" required="true" />
            <Input id="medication_name" value="{view>/formData/medication_name}" />
            <Label text="Dosage" required="true" />
            <Input id="dosage" value="{view>/formData/dosage}" />
            <Label text="Frequency" required="true" />
            <Input id="frequency" value="{view>/formData/frequency}" />
            <Label text="Route" required="true" />
            <Input id="route" value="{view>/formData/route}" />
            <Label text="Prescribed By" required="true" />
            <Input id="prescribed_by" value="{view>/formData/prescribed_by}" />
            <Label text="Prescribed Date" required="true" />
            <Input id="prescribed_date" value="{view>/formData/prescribed_date}" />
            <Label text="Status" required="true" />
            <Input id="status" value="{view>/formData/status}" />
          </form:SimpleForm>
        </Panel>
      </VBox>
    </f:content>

  </f:DynamicPage>
</mvc:View>
