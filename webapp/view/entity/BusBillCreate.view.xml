<mvc:View
  controllerName="hospital-management-system.controller.entity.BusBillCreate"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:form="sap.ui.layout.form"
  xmlns:core="sap.ui.core">

  <f:DynamicPage
    headerExpanded="false"
    toggleHeaderOnTitleClick="true"
    busy="{view>/busy}">

    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="Create Bus Bill" />
        </f:heading>
        <f:actions>
          <Button
            text="Save"
            type="Emphasized"
            icon="sap-icon://save"
            press=".onSavePress" />
          <Button
            text="Cancel"
            press=".onCancelPress" />
        </f:actions>
        <f:navigationActions>
          <Button
            icon="sap-icon://nav-back"
            press=".onNavBack"
            tooltip="Back to List" />
        </f:navigationActions>
      </f:DynamicPageTitle>
    </f:title>

    <f:content>
      <VBox class="sapUiSmallMargin">
        <Panel headerText="General Information" expandable="true">
          <form:SimpleForm
            editable="true"
            layout="ResponsiveGridLayout"
            labelSpanXL="3"
            labelSpanL="3"
            labelSpanM="3"
            labelSpanS="12"
            adjustLabelSpan="false"
            emptySpanXL="4"
            emptySpanL="4"
            emptySpanM="4"
            emptySpanS="0"
            columnsXL="1"
            columnsL="1"
            columnsM="1">
            <Label text="Patient Id" required="true" />
            <Input id="patient_id" value="{view>/formData/patient_id}" />
            <Label text="Encounter Id" required="true" />
            <Input id="encounter_id" value="{view>/formData/encounter_id}" />
            <Label text="Bill Date" required="true" />
            <Input id="bill_date" value="{view>/formData/bill_date}" />
            <Label text="Total Amount" required="true" />
            <Input id="total_amount" value="{view>/formData/total_amount}" />
            <Label text="Amount Paid" required="true" />
            <Input id="amount_paid" value="{view>/formData/amount_paid}" />
            <Label text="Insurance Provider Id" required="true" />
            <Input id="insurance_provider_id" value="{view>/formData/insurance_provider_id}" />
            <Label text="Status" required="true" />
            <Input id="status" value="{view>/formData/status}" />
            <Label text="Due Date" required="true" />
            <Input id="due_date" value="{view>/formData/due_date}" />
          </form:SimpleForm>
        </Panel>
      </VBox>
    </f:content>

  </f:DynamicPage>
</mvc:View>
