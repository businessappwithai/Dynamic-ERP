<!--
  Admin View - Application Dictionary Management

  Allows runtime modification of field ordering via sys_field.seq_no.
  Drag-and-drop reordering of fields for form and grid layouts.
  Master-detail layout: sys_table list on left, sys_field details on right.

  Generated: 2026-03-09T11:47:10.430Z
-->
<mvc:View
  controllerName="hospital-management-system.controller.Admin"
  xmlns="sap.m"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns:dnd="sap.ui.core.dnd"
  xmlns:core="sap.ui.core"
  xmlns:f="sap.f"
  xmlns:l="sap.ui.layout">

  <Page
    id="adminPage"
    title="{i18n>admin.title}"
    showNavButton="true"
    navButtonPress=".onNavBack"
    busy="{view>/busy}">

    <customHeader>
      <Bar>
        <contentLeft>
          <Button
            icon="sap-icon://nav-back"
            press=".onNavBack"
            type="Transparent" />
          <Title text="{i18n>admin.title}" />
        </contentLeft>
        <contentRight>
          <Button
            id="refreshButton"
            icon="sap-icon://refresh"
            press=".onRefreshPress"
            type="Transparent"
            tooltip="Refresh data" />
          <Button
            id="saveButton"
            text="{i18n>admin.save}"
            type="Emphasized"
            press=".onSavePress"
            enabled="{view>/hasChanges}" />
        </contentRight>
      </Bar>
    </customHeader>

    <content>
      <VBox class="sapUiSmallMargin">

        <!-- Overview Statistics -->
        <Panel
          id="overviewPanel"
          headerText="Application Dictionary Overview"
          class="sapUiSmallMarginBottom">
          <content>
            <HBox justifyContent="SpaceAround" class="sapUiSmallMargin">
              <VBox alignItems="Center" class="sapUiSmallMarginEnd">
                <ObjectNumber
                  number="{view>/stats/tableCount}"
                  unit="Tables"
                  state="Information" />
              </VBox>
              <VBox alignItems="Center" class="sapUiSmallMarginEnd">
                <ObjectNumber
                  number="{view>/stats/columnCount}"
                  unit="Columns"
                  state="Information" />
              </VBox>
              <VBox alignItems="Center" class="sapUiSmallMarginEnd">
                <ObjectNumber
                  number="{view>/stats/fieldCount}"
                  unit="Fields"
                  state="Information" />
              </VBox>
              <VBox alignItems="Center">
                <ObjectNumber
                  number="{view>/stats/windowCount}"
                  unit="Windows"
                  state="Information" />
              </VBox>
            </HBox>
          </content>
        </Panel>

        <!-- Instructions -->
        <MessageStrip
          text="{i18n>admin.instructions}"
          type="Information"
          showIcon="true"
          class="sapUiSmallMarginBottom" />

        <!-- Master: sys_table List -->
        <Panel
          id="tableListPanel"
          headerText="Registered Entities (sys_table)"
          class="sapUiSmallMarginBottom">

          <headerToolbar>
            <Toolbar>
              <Title text="Registered Entities (sys_table)" level="H4" />
              <ToolbarSpacer />
              <SearchField
                id="tableSearchField"
                placeholder="Search tables..."
                liveChange=".onTableSearch"
                width="250px" />
            </Toolbar>
          </headerToolbar>

          <Table
            id="sysTableList"
            items="{view>/tables}"
            mode="SingleSelectLeft"
            selectionChange=".onTableSelectionChange"
            growing="true"
            growingThreshold="20"
            class="sapUiSmallMargin">

            <columns>
              <Column width="30%">
                <Text text="Name" />
              </Column>
              <Column width="30%">
                <Text text="Table Name" />
              </Column>
              <Column width="20%" hAlign="Center">
                <Text text="Fields" />
              </Column>
              <Column width="20%" hAlign="Center">
                <Text text="Status" />
              </Column>
            </columns>

            <items>
              <ColumnListItem type="Active">
                <cells>
                  <VBox>
                    <Text text="{name}" class="sapUiSmallMarginBottom" />
                    <Text text="{description}" class="sapThemeLightText" visible="{= !!${description} }" />
                  </VBox>
                  <Text text="{table_name}" />
                  <ObjectNumber number="{fieldCount}" unit="fields" />
                  <ObjectStatus
                    text="{= ${is_active} !== false ? 'Active' : 'Inactive' }"
                    state="{= ${is_active} !== false ? 'Success' : 'None' }" />
                </cells>
              </ColumnListItem>
            </items>

          </Table>

        </Panel>

        <!-- Detail: sys_field List for Selected Table -->
        <Panel
          id="fieldDetailPanel"
          headerText="Field Configuration"
          visible="{= !!${view>/selectedEntity} }"
          class="sapUiSmallMarginBottom">

          <headerToolbar>
            <Toolbar>
              <Title
                text="{= 'Fields for: ' + ${view>/selectedEntityName} }"
                level="H4" />
              <ToolbarSpacer />
              <SegmentedButton
                id="modeSelector"
                selectedKey="{view>/layoutMode}"
                selectionChange=".onModeChange">
                <items>
                  <SegmentedButtonItem
                    key="form"
                    text="{i18n>admin.formLayout}"
                    icon="sap-icon://form" />
                  <SegmentedButtonItem
                    key="grid"
                    text="{i18n>admin.gridLayout}"
                    icon="sap-icon://table-view" />
                </items>
              </SegmentedButton>
            </Toolbar>
          </headerToolbar>

          <content>
            <!-- Field List with Drag & Drop and Move Up/Down -->
            <List
              id="fieldList"
              items="{view>/fields}"
              mode="None"
              class="sapUiSmallMargin">

              <!-- Enable drag and drop -->
              <dragDropConfig>
                <dnd:DragDropInfo
                  sourceAggregation="items"
                  targetAggregation="items"
                  dropPosition="Between"
                  drop=".onFieldDrop" />
              </dragDropConfig>

              <!-- Column-like header for fields -->
              <headerToolbar>
                <Toolbar>
                  <Text text="" width="40px" />
                  <Text text="Field Name" class="sapUiSmallMarginBeginEnd" width="30%" />
                  <Text text="Column" width="25%" />
                  <Text text="Seq No" width="80px" />
                  <Text text="Visible" width="70px" />
                  <ToolbarSpacer />
                  <Text text="Reorder" width="80px" />
                </Toolbar>
              </headerToolbar>

              <CustomListItem
                type="Active">
                <HBox
                  alignItems="Center"
                  justifyContent="SpaceBetween"
                  class="sapUiSmallMargin">

                  <!-- Drag handle -->
                  <VBox width="40px" alignItems="Center">
                    <core:Icon
                      src="sap-icon://menu2"
                      size="1rem"
                      class="sapUiSmallMarginEnd" />
                  </VBox>

                  <!-- Field info -->
                  <VBox class="sapUiSmallMarginBeginEnd" width="30%">
                    <Label
                      text="{display_name}"
                      design="Bold" />
                    <Text
                      text="{column_name} ({data_type})"
                      class="sapUiTinyMarginTop" />
                  </VBox>

                  <!-- Column name -->
                  <VBox width="25%">
                    <Text text="{column_name}" />
                  </VBox>

                  <!-- Editable Sequence number -->
                  <VBox width="80px" alignItems="Center">
                    <Input
                      value="{= ${view>/layoutMode} === 'form' ? ${seq_no} : ${seq_no_grid} }"
                      type="Number"
                      width="70px"
                      change=".onSeqNoChange"
                      textAlign="Center" />
                  </VBox>

                  <!-- Visibility toggle -->
                  <VBox width="70px" alignItems="Center">
                    <CheckBox
                      selected="{= ${view>/layoutMode} === 'form' ? ${is_displayed} : ${is_displayed_grid} }"
                      text=""
                      select=".onVisibilityChange" />
                  </VBox>

                  <!-- Move Up / Move Down buttons -->
                  <HBox width="80px" justifyContent="Center">
                    <Button
                      icon="sap-icon://slim-arrow-up"
                      type="Transparent"
                      press=".onMoveFieldUp"
                      tooltip="Move Up" />
                    <Button
                      icon="sap-icon://slim-arrow-down"
                      type="Transparent"
                      press=".onMoveFieldDown"
                      tooltip="Move Down" />
                  </HBox>

                </HBox>
              </CustomListItem>

            </List>
          </content>

        </Panel>

        <!-- Preview Section -->
        <Panel
          headerText="{i18n>admin.preview}"
          expandable="true"
          expanded="false"
          visible="{= ${view>/fields}.length > 0 }">
          <content>
            <VBox class="sapUiSmallMargin">
              <Text
                text="{i18n>admin.previewDescription}"
                class="sapUiSmallMarginBottom" />
              <List
                id="previewList"
                items="{view>/visibleFields}"
                mode="None"
                showNoData="true"
                noDataText="No visible fields">
                <StandardListItem
                  title="{display_name}"
                  description="{column_name}"
                  info="{= ${view>/layoutMode} === 'form' ? 'seq: ' + ${seq_no} : 'seq: ' + ${seq_no_grid} }"
                  infoState="Information" />
              </List>
            </VBox>
          </content>
        </Panel>

      </VBox>
    </content>

    <footer>
      <Bar>
        <contentLeft>
          <Text
            text="{= 'Entity: ' + ${view>/selectedEntityName} }"
            visible="{= !!${view>/selectedEntity} }" />
        </contentLeft>
        <contentMiddle>
          <Text
            text="{= ${view>/fields}.length + ' ' + ${i18n>admin.fieldsConfigured} }"
            visible="{= ${view>/fields}.length > 0 }" />
        </contentMiddle>
        <contentRight>
          <Text
            text="{= ${view>/hasChanges} ? 'Unsaved changes' : 'All saved' }"
            class="{= ${view>/hasChanges} ? 'sapUiSmallMarginEnd sapThemeHighlight-asColor' : 'sapUiSmallMarginEnd' }" />
        </contentRight>
      </Bar>
    </footer>

  </Page>

</mvc:View>
