<!--
  Entity Menu View - Navigation List
  Displays list of entities for navigation
  Generated: 2026-03-09T11:47:10.430Z
-->
<mvc:View
  controllerName="hospital-management-system.controller.EntityMenu"
  xmlns="sap.m"
  xmlns:mvc="sap.ui.core.mvc">
  <Page
    title="Hospital Management System"
    showNavButton="false">
    <content>
      <List
        id="entityList"
        items="{
          path: 'entityMenu>/entityMenu'
        }">
        <StandardListItem
          title="{entityMenu>name}"
          description="{entityMenu>description}"
          type="Navigation"
          press=".onEntitySelect"/>
      </List>
    </content>
  </Page>
</mvc:View>
