%% Enterprise Hospital Management System (HMS) ERD
%%
%% A comprehensive Hospital Information System covering:
%% - Patient Administration & Master Patient Index (MPI)
%% - Outpatient Department (OPD) Management
%% - Inpatient Department (IPD) & Ward Management
%% - Electronic Medical Record (EMR)
%% - Laboratory Information System (LIS)
%% - Radiology Information System (RIS) & PACS
%% - Pharmacy Management System
%% - Billing & Revenue Cycle Management (RCM)
%% - Procurement & Supply Chain
%% - Staff & Department Management
%%
%% Compliant with: HIPAA, GDPR, HL7 v2.x, FHIR R4, DICOM
%%
%% Use: erdwithai generate -i scripts/hospital-management/hospital.erd.mmd -o ./generated/hospital-app -n hospital-hms -s option1

erDiagram

