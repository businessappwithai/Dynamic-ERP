# Application Configuration
NODE_ENV=development
PORT=3000

# Database Configuration (PostgreSQL)
# Option 1 — single URL (takes precedence):
DATABASE_URL=postgresql://erdwithai:password@127.0.0.1:5432/erdwithai
# Option 2 — individual vars (used when DATABASE_URL is not set):
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=erdwithai
POSTGRES_PASSWORD=
POSTGRES_DATABASE=erdwithai
POSTGRES_POOL_MAX=10

# AI Configuration (Required for AI features)
ANTHROPIC_API_KEY=your-anthropic-api-key

# llama.cpp local server — optional, enables local LLM inference
# Start the server with: llama-server -hf <model-repo>
LLAMA_CPP_BASE_URL=http://127.0.0.1:8080/v1
LLAMA_CPP_MODEL=local
# LLAMA_CPP_API_KEY=not-required

# Mastra.ai Configuration
MASTRA_DATABASE_URL=file:./erdwithai-mastra.db
MASTRA_PORT=4111
MASTRA_LOG_LEVEL=info

# Web Application (TanStack Start — use VITE_ prefix for client-side access)
VITE_APP_URL=http://localhost:3000
VITE_API_URL=http://localhost:3000/api
VITE_MASTRA_URL=http://localhost:4111

# CopilotKit Configuration
COPILOTKIT_API_KEY=

# CORS Configuration
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# Security
SESSION_SECRET=change
JWT_SECRET=change

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Feature Flags
ENABLE_AI_FEATURES=true
ENABLE_DICTIONARY_FEATURES=true
ENABLE_CODE_GENERATION=true
ENABLE_ANALYTICS=false

# Code Generation
DEFAULT_OUTPUT_DIR=./generated
TEMPLATE_DIR=./packages/generator/templates

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=.mermaid,.md,.txt,.json

# ERD Design Auto-Retry Configuration
# Number of automatic retries when ERD validation fails
ERD_DESIGN_AUTO_RETRY_COUNT=3
# Delay between retries in milliseconds
ERD_DESIGN_RETRY_DELAY_MS=2000
