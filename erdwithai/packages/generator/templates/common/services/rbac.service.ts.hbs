/**
 * RBAC (Role-Based Access Control) Service
 *
 * Provides role-based access control for AI Natural Language queries.
 * Manages permissions at three levels:
 * - Table level: Can user access this table?
 * - Row level: Which rows can user see? (RLS)
 * - Field level: Which fields can user see/edit?
 *
 * Generated: {{now}}
 * Project: {{project.name}}
 */

import { Knex } from 'knex';
import {
  RolePermissions,
  TablePermission,
  FieldPermission,
} from '../ai/validators/sql-validator';

// ============================================================================
// Types
// ============================================================================

export interface Role {
  sys_role_id: string;
  name: string;
  description?: string;
  is_active: boolean;
  created_at: Date;
  updated_at: Date;
}

export interface UserRole {
  sys_user_role_id: string;
  sys_user_id: string;
  sys_role_id: string;
  created_at: Date;
}

export interface RoleTableAccess {
  sys_role_table_access_id: string;
  sys_role_id: string;
  table_name: string;
  can_read: boolean;
  can_write: boolean;
  row_filter?: string;
  created_at: Date;
  updated_at: Date;
}

export interface RoleFieldAccess {
  sys_role_field_access_id: string;
  sys_role_id: string;
  sys_field_id: string;
  is_visible: boolean;
  is_editable: boolean;
  created_at: Date;
  updated_at: Date;
}

// ============================================================================
// RBAC Service
// ============================================================================

export class RBACService {
  constructor(private db: Knex) {}

  // ==========================================================================
  // User Permissions
  // ==========================================================================

  /**
   * Get complete permissions for a user
   * Used by AI NL workflow for query validation
   */
  async getUserPermissions(userId: string): Promise<RolePermissions> {
    // Get user's roles
    const userRoles = await this.getUserRoles(userId);
    const roleIds = userRoles.map(r => r.sys_role_id);

    if (roleIds.length === 0) {
      // No roles - return empty permissions
      return {
        userId,
        roles: [],
        tablePermissions: new Map(),
        fieldPermissions: new Map(),
      };
    }

    // Get table permissions (merged across all roles)
    const tablePermissions = await this.getMergedTablePermissions(roleIds);

    // Get field permissions (merged across all roles)
    const fieldPermissions = await this.getMergedFieldPermissions(roleIds);

    return {
      userId,
      roles: userRoles.map(r => r.name),
      tablePermissions,
      fieldPermissions,
    };
  }

  /**
   * Get roles assigned to a user
   */
  async getUserRoles(userId: string): Promise<Role[]> {
    return this.db('sys_user_role')
      .join('sys_role', 'sys_user_role.sys_role_id', 'sys_role.sys_role_id')
      .where('sys_user_role.sys_user_id', userId)
      .where('sys_role.is_active', true)
      .select('sys_role.*');
  }

  /**
   * Get merged table permissions for multiple roles
   * Most permissive permission wins
   */
  private async getMergedTablePermissions(
    roleIds: string[]
  ): Promise<Map<string, TablePermission>> {
    const tablePerms = await this.db('sys_role_table_access')
      .whereIn('sys_role_id', roleIds)
      .select('table_name', 'can_read', 'can_write', 'row_filter');

    const merged = new Map<string, TablePermission>();

    for (const perm of tablePerms) {
      const tableName = perm.table_name.toLowerCase();
      const existing = merged.get(tableName);

      merged.set(tableName, {
        canRead: existing?.canRead || perm.can_read,
        canWrite: existing?.canWrite || perm.can_write,
        // Use most restrictive row filter (intersection)
        rowFilter: this.combineRowFilters(existing?.rowFilter, perm.row_filter),
      });
    }

    return merged;
  }

  /**
   * Get merged field permissions for multiple roles
   * Most permissive permission wins
   */
  private async getMergedFieldPermissions(
    roleIds: string[]
  ): Promise<Map<string, Map<string, FieldPermission>>> {
    const fieldPerms = await this.db('sys_role_field_access')
      .whereIn('sys_role_field_access.sys_role_id', roleIds)
      .join('sys_field', 'sys_role_field_access.sys_field_id', 'sys_field.sys_field_id')
      .join('sys_table', 'sys_field.sys_table_id', 'sys_table.sys_table_id')
      .select(
        'sys_table.table_name',
        'sys_field.column_name',
        'sys_role_field_access.is_visible',
        'sys_role_field_access.is_editable'
      );

    const merged = new Map<string, Map<string, FieldPermission>>();

    for (const perm of fieldPerms) {
      const tableName = perm.table_name.toLowerCase();
      const columnName = perm.column_name.toLowerCase();

      if (!merged.has(tableName)) {
        merged.set(tableName, new Map());
      }

      const tableFields = merged.get(tableName)!;
      const existing = tableFields.get(columnName);

      tableFields.set(columnName, {
        isVisible: existing?.isVisible || perm.is_visible,
        isEditable: existing?.isEditable || perm.is_editable,
      });
    }

    return merged;
  }

  /**
   * Combine row filters from multiple roles
   * Uses AND to combine (intersection of allowed rows)
   */
  private combineRowFilters(filter1?: string, filter2?: string): string | undefined {
    if (!filter1 && !filter2) return undefined;
    if (!filter1) return filter2;
    if (!filter2) return filter1;
    if (filter1 === filter2) return filter1;
    return `(${filter1}) AND (${filter2})`;
  }

  // ==========================================================================
  // Role Management
  // ==========================================================================

  /**
   * Create a new role
   */
  async createRole(role: Omit<Role, 'sys_role_id' | 'created_at' | 'updated_at'>): Promise<Role> {
    const [created] = await this.db('sys_role')
      .insert({
        ...role,
        sys_role_id: this.db.raw('gen_random_uuid()'),
        created_at: new Date(),
        updated_at: new Date(),
      })
      .returning('*');
    return created;
  }

  /**
   * Assign role to user
   */
  async assignRole(userId: string, roleId: string): Promise<void> {
    await this.db('sys_user_role').insert({
      sys_user_role_id: this.db.raw('gen_random_uuid()'),
      sys_user_id: userId,
      sys_role_id: roleId,
      created_at: new Date(),
    });
  }

  /**
   * Remove role from user
   */
  async removeRole(userId: string, roleId: string): Promise<void> {
    await this.db('sys_user_role')
      .where('sys_user_id', userId)
      .where('sys_role_id', roleId)
      .delete();
  }

  // ==========================================================================
  // Table Access Management
  // ==========================================================================

  /**
   * Grant table access to a role
   */
  async grantTableAccess(
    roleId: string,
    tableName: string,
    access: { canRead: boolean; canWrite: boolean; rowFilter?: string }
  ): Promise<void> {
    await this.db('sys_role_table_access')
      .insert({
        sys_role_table_access_id: this.db.raw('gen_random_uuid()'),
        sys_role_id: roleId,
        table_name: tableName,
        can_read: access.canRead,
        can_write: access.canWrite,
        row_filter: access.rowFilter,
        created_at: new Date(),
        updated_at: new Date(),
      })
      .onConflict(['sys_role_id', 'table_name'])
      .merge(['can_read', 'can_write', 'row_filter', 'updated_at']);
  }

  /**
   * Revoke table access from a role
   */
  async revokeTableAccess(roleId: string, tableName: string): Promise<void> {
    await this.db('sys_role_table_access')
      .where('sys_role_id', roleId)
      .where('table_name', tableName)
      .delete();
  }

  // ==========================================================================
  // Field Access Management
  // ==========================================================================

  /**
   * Grant field access to a role
   */
  async grantFieldAccess(
    roleId: string,
    fieldId: string,
    access: { isVisible: boolean; isEditable: boolean }
  ): Promise<void> {
    await this.db('sys_role_field_access')
      .insert({
        sys_role_field_access_id: this.db.raw('gen_random_uuid()'),
        sys_role_id: roleId,
        sys_field_id: fieldId,
        is_visible: access.isVisible,
        is_editable: access.isEditable,
        created_at: new Date(),
        updated_at: new Date(),
      })
      .onConflict(['sys_role_id', 'sys_field_id'])
      .merge(['is_visible', 'is_editable', 'updated_at']);
  }

  /**
   * Revoke field access from a role
   */
  async revokeFieldAccess(roleId: string, fieldId: string): Promise<void> {
    await this.db('sys_role_field_access')
      .where('sys_role_id', roleId)
      .where('sys_field_id', fieldId)
      .delete();
  }

  // ==========================================================================
  // Bulk Operations
  // ==========================================================================

  /**
   * Initialize default permissions for a role
   * Grants read access to all business tables with all fields visible
   */
  async initializeRolePermissions(
    roleId: string,
    options: {
      readAll?: boolean;
      writeAll?: boolean;
      tables?: string[];
    } = { readAll: true, writeAll: false }
  ): Promise<void> {
    // Get all business tables
    const tables = await this.db('sys_table')
      .where('table_name', 'like', 'bus_%')
      .select('sys_table_id', 'table_name');

    const filteredTables = options.tables
      ? tables.filter(t => options.tables!.includes(t.table_name))
      : tables;

    // Grant table access
    for (const table of filteredTables) {
      await this.grantTableAccess(roleId, table.table_name, {
        canRead: options.readAll ?? true,
        canWrite: options.writeAll ?? false,
      });

      // Get all fields for this table
      const fields = await this.db('sys_field')
        .where('sys_table_id', table.sys_table_id)
        .select('sys_field_id');

      // Grant field access
      for (const field of fields) {
        await this.grantFieldAccess(roleId, field.sys_field_id, {
          isVisible: true,
          isEditable: options.writeAll ?? false,
        });
      }
    }
  }
}

// ============================================================================
// Factory Function
// ============================================================================

export function createRBACService(db: Knex): RBACService {
  return new RBACService(db);
}
