/**
 * ANTLR4 SQL Validator
 *
 * IMPORTANT: This validator is for VALIDATION ONLY - not for query execution.
 *
 * It validates:
 * 1. SQL syntax correctness
 * 2. Schema compliance (tables/columns exist)
 * 3. Security (no dangerous operations)
 * 4. Role-based permissions (entity/field access)
 * 5. Query complexity limits
 *
 * After validation passes, Knex.js Query Builder is used directly for execution.
 *
 * Generated: {{now}}
 * Project: {{project.name}}
 */

import { CharStream, CommonTokenStream, AbstractParseTreeVisitor } from 'antlr4ng';
import { SQLLexer } from './generated/SQLLexer';
import { SQLParser, SelectStatementContext } from './generated/SQLParser';
import { SQLVisitor } from './generated/SQLVisitor';

// ============================================================================
// Type Definitions
// ============================================================================

export interface SchemaDefinition {
  tables: Map<string, TableDefinition>;
}

export interface TableDefinition {
  name: string;
  columns: string[];
  allowedOperations: ('select' | 'insert' | 'update' | 'delete')[];
}

/**
 * Role-based permission definition for ANTLR4 validation
 */
export interface RolePermissions {
  userId: string;
  roles: string[];
  tablePermissions: Map<string, TablePermission>;
  fieldPermissions: Map<string, Map<string, FieldPermission>>;
}

export interface TablePermission {
  canRead: boolean;
  canWrite: boolean;
  rowFilter?: string; // Optional RLS condition (e.g., "owner_id = 'user123'")
}

export interface FieldPermission {
  isVisible: boolean;
  isEditable: boolean;
}

export interface SQLValidationError {
  type: 'syntax' | 'security' | 'schema' | 'permission' | 'complexity';
  message: string;
  line?: number;
  column?: number;
}

export interface SQLValidationWarning {
  type: 'performance' | 'suggestion';
  message: string;
}

export interface QueryComplexity {
  score: number;
  tableCount: number;
  joinCount: number;
  filterCount: number;
  hasSubquery: boolean;
  hasAggregation: boolean;
}

export interface SQLValidationResult {
  isValid: boolean;
  errors: SQLValidationError[];
  warnings: SQLValidationWarning[];
  complexity?: QueryComplexity;
  ast?: ParsedSQL;
}

export interface ParsedSQL {
  type: 'select' | 'insert' | 'update' | 'delete' | 'unknown';
  tables: string[];
  columns: string[];
  joins: JoinInfo[];
  filters: FilterInfo[];
  aggregates: AggregateInfo[];
  groupBy?: string[];
  orderBy?: OrderByInfo[];
  limit?: number;
  offset?: number;
  having?: FilterInfo[];
}

export interface JoinInfo {
  type: string;
  table: string;
  leftColumn: string;
  rightColumn: string;
}

export interface FilterInfo {
  field: string;
  operator: string;
  value: unknown;
  connector?: 'AND' | 'OR';
}

export interface AggregateInfo {
  function: string;
  field: string;
  alias?: string;
}

export interface OrderByInfo {
  field: string;
  direction: 'ASC' | 'DESC';
}

// ============================================================================
// Custom Error Listener
// ============================================================================

class SQLErrorListener {
  private errors: SQLValidationError[] = [];

  syntaxError(
    _recognizer: unknown,
    _offendingSymbol: unknown,
    line: number,
    column: number,
    msg: string
  ): void {
    this.errors.push({
      type: 'syntax',
      message: msg,
      line,
      column,
    });
  }

  getErrors(): SQLValidationError[] {
    return this.errors;
  }
}

// ============================================================================
// SQL AST Visitor
// ============================================================================

class SQLAnalyzerVisitor
  extends AbstractParseTreeVisitor<ParsedSQL>
  implements SQLVisitor<ParsedSQL>
{
  private result: ParsedSQL = {
    type: 'unknown',
    tables: [],
    columns: [],
    joins: [],
    filters: [],
    aggregates: [],
  };

  constructor(private schema: SchemaDefinition) {
    super();
  }

  protected defaultResult(): ParsedSQL {
    return this.result;
  }

  visitSelectStatement(ctx: SelectStatementContext): ParsedSQL {
    this.result.type = 'select';

    // Extract table names
    const tableCtx = ctx.tableReference?.();
    if (tableCtx) {
      this.result.tables = this.extractTableNames(tableCtx);
    }

    // Extract columns
    const selectListCtx = ctx.selectList?.();
    if (selectListCtx) {
      this.result.columns = this.extractColumns(selectListCtx);
    }

    // Extract JOINs
    const joinCtx = ctx.joinClause?.();
    if (joinCtx) {
      this.result.joins = this.extractJoins(joinCtx);
    }

    // Extract WHERE filters
    const whereCtx = ctx.whereClause?.();
    if (whereCtx) {
      this.result.filters = this.extractFilters(whereCtx);
    }

    // Extract GROUP BY
    const groupByCtx = ctx.groupByClause?.();
    if (groupByCtx) {
      this.result.groupBy = this.extractGroupBy(groupByCtx);
    }

    // Extract ORDER BY
    const orderByCtx = ctx.orderByClause?.();
    if (orderByCtx) {
      this.result.orderBy = this.extractOrderBy(orderByCtx);
    }

    // Extract LIMIT
    const limitCtx = ctx.limitClause?.();
    if (limitCtx) {
      this.result.limit = this.extractLimit(limitCtx);
    }

    return this.result;
  }

  private extractTableNames(ctx: unknown): string[] {
    // Simplified extraction - actual implementation depends on grammar
    return [];
  }

  private extractColumns(ctx: unknown): string[] {
    return [];
  }

  private extractJoins(ctx: unknown): JoinInfo[] {
    return [];
  }

  private extractFilters(ctx: unknown): FilterInfo[] {
    return [];
  }

  private extractGroupBy(ctx: unknown): string[] {
    return [];
  }

  private extractOrderBy(ctx: unknown): OrderByInfo[] {
    return [];
  }

  private extractLimit(ctx: unknown): number {
    return 100;
  }
}

// ============================================================================
// Main Validator Class
// ============================================================================

/**
 * ANTLR4 SQL Validator
 *
 * IMPORTANT: This validator is for VALIDATION ONLY - query execution uses
 * Knex.js Query Builder directly.
 */
export class ANTLR4SQLValidator {
  private schema: SchemaDefinition;
  private permissions: RolePermissions;
  private maxComplexityScore: number;
  private dangerousKeywords: Set<string>;

  constructor(
    schema: SchemaDefinition,
    permissions: RolePermissions,
    options?: {
      maxComplexityScore?: number;
    }
  ) {
    this.schema = schema;
    this.permissions = permissions;
    this.maxComplexityScore = options?.maxComplexityScore ?? 80;
    this.dangerousKeywords = new Set([
      'DROP', 'TRUNCATE', 'ALTER', 'CREATE', 'GRANT', 'REVOKE',
      'INSERT', 'UPDATE', 'DELETE' // Only SELECT allowed for AI queries
    ]);
  }

  /**
   * Validate SQL string
   *
   * @param sql - SQL string to validate (for validation purposes only)
   * @returns Validation result with errors, warnings, and complexity
   */
  validate(sql: string): SQLValidationResult {
    const errors: SQLValidationError[] = [];
    const warnings: SQLValidationWarning[] = [];

    // Step 1: Check for dangerous keywords
    const dangerousCheck = this.checkDangerousKeywords(sql);
    if (dangerousCheck.length > 0) {
      return {
        isValid: false,
        errors: dangerousCheck,
        warnings: [],
      };
    }

    // Step 2: Parse SQL with ANTLR4
    const inputStream = CharStream.fromString(sql);
    const lexer = new SQLLexer(inputStream);
    const tokenStream = new CommonTokenStream(lexer);
    const parser = new SQLParser(tokenStream);

    // Custom error listener
    const errorListener = new SQLErrorListener();
    parser.removeErrorListeners();
    parser.addErrorListener(errorListener as any);

    // Parse
    const tree = parser.selectStatement();

    // Check for syntax errors
    const syntaxErrors = errorListener.getErrors();
    if (syntaxErrors.length > 0) {
      return {
        isValid: false,
        errors: syntaxErrors,
        warnings: [],
      };
    }

    // Step 3: Semantic Analysis with AST Visitor
    const visitor = new SQLAnalyzerVisitor(this.schema);
    const ast = visitor.visit(tree);

    // Step 4: Schema Validation
    const schemaErrors = this.validateSchema(ast);
    errors.push(...schemaErrors);

    // Step 5: Security Validation
    const securityErrors = this.validateSecurity(ast, sql);
    errors.push(...securityErrors);

    // Step 6: Role-Based Permission Validation
    const permissionErrors = this.validatePermissions(ast);
    errors.push(...permissionErrors);

    // Step 7: Complexity Analysis
    const complexity = this.calculateComplexity(ast);
    if (complexity.score > this.maxComplexityScore) {
      errors.push({
        type: 'complexity',
        message: `Query complexity score (${complexity.score}) exceeds maximum (${this.maxComplexityScore})`,
      });
    }

    // Step 8: Performance Warnings
    const performanceWarnings = this.checkPerformance(ast, complexity);
    warnings.push(...performanceWarnings);

    return {
      isValid: errors.length === 0,
      errors,
      warnings,
      complexity,
      ast,
    };
  }

  private checkDangerousKeywords(sql: string): SQLValidationError[] {
    const errors: SQLValidationError[] = [];
    const upperSQL = sql.toUpperCase();

    for (const keyword of this.dangerousKeywords) {
      // Check for keyword as whole word
      const regex = new RegExp(`\\b${keyword}\\b`, 'i');
      if (regex.test(sql)) {
        errors.push({
          type: 'security',
          message: `Dangerous SQL keyword detected: ${keyword}. Only SELECT queries are allowed.`,
        });
      }
    }

    return errors;
  }

  private validateSchema(ast: ParsedSQL): SQLValidationError[] {
    const errors: SQLValidationError[] = [];

    // Validate tables exist
    for (const tableName of ast.tables) {
      if (!this.schema.tables.has(tableName.toLowerCase())) {
        errors.push({
          type: 'schema',
          message: `Unknown table: '${tableName}'`,
        });
      }
    }

    // Validate columns exist
    for (const column of ast.columns) {
      if (column === '*') continue;

      // Parse table.column format
      const [tableAlias, columnName] = column.includes('.')
        ? column.split('.')
        : [ast.tables[0], column];

      const table = this.schema.tables.get(tableAlias?.toLowerCase());
      if (table && !table.columns.includes(columnName.toLowerCase())) {
        errors.push({
          type: 'schema',
          message: `Unknown column '${columnName}' in table '${tableAlias}'`,
        });
      }
    }

    return errors;
  }

  private validateSecurity(ast: ParsedSQL, sql: string): SQLValidationError[] {
    const errors: SQLValidationError[] = [];

    // Only SELECT is allowed for AI queries
    if (ast.type !== 'select') {
      errors.push({
        type: 'security',
        message: `Only SELECT queries are allowed. Found: ${ast.type.toUpperCase()}`,
      });
    }

    // Check table permissions
    for (const tableName of ast.tables) {
      const table = this.schema.tables.get(tableName.toLowerCase());
      if (table && !table.allowedOperations.includes('select')) {
        errors.push({
          type: 'security',
          message: `SELECT operation not allowed on table '${tableName}'`,
        });
      }
    }

    return errors;
  }

  /**
   * Validate role-based permissions on entities and fields
   * Checks if the user has permission to access the requested tables and columns
   */
  private validatePermissions(ast: ParsedSQL): SQLValidationError[] {
    const errors: SQLValidationError[] = [];

    // Check table-level permissions based on user's roles
    for (const tableName of ast.tables) {
      const tablePermission = this.permissions.tablePermissions.get(tableName.toLowerCase());

      if (!tablePermission) {
        errors.push({
          type: 'permission',
          message: `Access denied: User does not have permission to access table '${tableName}'`,
        });
        continue;
      }

      if (!tablePermission.canRead) {
        errors.push({
          type: 'permission',
          message: `Access denied: User's role does not allow reading from table '${tableName}'`,
        });
      }
    }

    // Check field-level permissions based on user's roles
    for (const column of ast.columns) {
      if (column === '*') {
        // SELECT * - check all fields in referenced tables
        for (const tableName of ast.tables) {
          const fieldPerms = this.permissions.fieldPermissions.get(tableName.toLowerCase());
          if (fieldPerms) {
            for (const [fieldName, fieldPerm] of fieldPerms) {
              if (!fieldPerm.isVisible) {
                errors.push({
                  type: 'permission',
                  message: `Access denied: SELECT * includes hidden field '${tableName}.${fieldName}'. Specify columns explicitly.`,
                });
                break; // One error for SELECT * is enough
              }
            }
          }
        }
        continue;
      }

      // Parse table.column or just column
      const [tableAlias, columnName] = column.includes('.')
        ? column.split('.')
        : [ast.tables[0], column];

      const fieldPerms = this.permissions.fieldPermissions.get(tableAlias?.toLowerCase());
      if (fieldPerms) {
        const fieldPerm = fieldPerms.get(columnName.toLowerCase());
        if (fieldPerm && !fieldPerm.isVisible) {
          errors.push({
            type: 'permission',
            message: `Access denied: User's role does not allow viewing field '${tableAlias}.${columnName}'`,
          });
        }
      }
    }

    // Check filter fields - users shouldn't filter on fields they can't see
    for (const filter of ast.filters) {
      const tableName = filter.field.includes('.')
        ? filter.field.split('.')[0]
        : ast.tables[0];
      const actualFieldName = filter.field.includes('.')
        ? filter.field.split('.')[1]
        : filter.field;

      const fieldPerms = this.permissions.fieldPermissions.get(tableName?.toLowerCase());
      if (fieldPerms) {
        const fieldPerm = fieldPerms.get(actualFieldName.toLowerCase());
        if (fieldPerm && !fieldPerm.isVisible) {
          errors.push({
            type: 'permission',
            message: `Access denied: Cannot filter by hidden field '${tableName}.${actualFieldName}'`,
          });
        }
      }
    }

    return errors;
  }

  private calculateComplexity(ast: ParsedSQL): QueryComplexity {
    const tableCount = ast.tables.length;
    const joinCount = ast.joins.length;
    const filterCount = ast.filters.length;
    const hasSubquery = false; // Would need to detect from AST
    const hasAggregation = ast.aggregates.length > 0;

    // Calculate complexity score
    let score = 0;
    score += tableCount * 10;
    score += joinCount * 15;
    score += filterCount * 5;
    score += hasSubquery ? 20 : 0;
    score += hasAggregation ? 10 : 0;
    score += ast.groupBy ? ast.groupBy.length * 5 : 0;

    return {
      score,
      tableCount,
      joinCount,
      filterCount,
      hasSubquery,
      hasAggregation,
    };
  }

  private checkPerformance(ast: ParsedSQL, complexity: QueryComplexity): SQLValidationWarning[] {
    const warnings: SQLValidationWarning[] = [];

    // Warn about SELECT *
    if (ast.columns.includes('*')) {
      warnings.push({
        type: 'performance',
        message: 'Consider specifying columns explicitly instead of SELECT *',
      });
    }

    // Warn about missing LIMIT
    if (!ast.limit) {
      warnings.push({
        type: 'suggestion',
        message: 'Consider adding LIMIT to prevent large result sets',
      });
    }

    // Warn about high complexity
    if (complexity.score > this.maxComplexityScore * 0.7) {
      warnings.push({
        type: 'performance',
        message: `Query complexity is high (${complexity.score}). Consider simplifying.`,
      });
    }

    return warnings;
  }
}

// ============================================================================
// Helper Function: Build Schema from Database
// ============================================================================

import { Knex } from 'knex';

export async function buildSchemaDefinition(db: Knex): Promise<SchemaDefinition> {
  const tables = new Map<string, TableDefinition>();

  // Get table list from sys_table
  const sysTables = await db('sys_table').select('table_name', 'name');

  for (const sysTable of sysTables) {
    // Get columns from sys_field
    const fields = await db('sys_field')
      .where('sys_table_id', function () {
        this.select('sys_table_id').from('sys_table').where('table_name', sysTable.table_name);
      })
      .select('column_name');

    tables.set(sysTable.table_name.toLowerCase(), {
      name: sysTable.name,
      columns: fields.map((f: { column_name: string }) => f.column_name.toLowerCase()),
      allowedOperations: ['select'], // AI queries only allow SELECT
    });
  }

  return { tables };
}
