/**
 * Data Query Workflow for AI Natural Language Access
 *
 * FLOW:
 * 1. Get user permissions (RBAC)
 * 2. Parse NL to structured intent (Mastra.ai Agent)
 * 3. Validate with ANTLR4 (syntax, schema, permissions)
 * 4. Build query using Knex.js Query Builder DIRECTLY
 * 5. Execute query
 * 6. Format results for CopilotKit display
 *
 * IMPORTANT: This workflow uses Knex.js Query Builder for BOTH Option 1 and Option 2.
 * ANTLR4 is for VALIDATION ONLY - Knex.js builds queries directly from parsed intent.
 *
 * Generated: {{now}}
 * Project: {{project.name}}
 */

import { Workflow, Step } from '@mastra/core';
import { z } from 'zod';
import { Knex } from 'knex';
import {
  ANTLR4SQLValidator,
  buildSchemaDefinition,
  RolePermissions,
} from '../validators/sql-validator';
import {
  KnexQueryBuilder,
  QueryIntent,
  QueryResult,
} from '../query-builder/knex-query-builder';
import { parseNaturalLanguageQuery } from '../agents/data-query-agent';

// ============================================================================
// Workflow Input Schema
// ============================================================================

const workflowInputSchema = z.object({
  query: z.string().describe('Natural language query from user'),
  userId: z.string().describe('ID of the user making the query'),
  sessionId: z.string().describe('Current session ID'),
});

export type WorkflowInput = z.infer<typeof workflowInputSchema>;

// ============================================================================
// Workflow Context
// ============================================================================

interface WorkflowContext {
  db: Knex;
  triggerData: WorkflowInput;
  permissions?: RolePermissions;
  intent?: QueryIntent;
  validatedIntent?: QueryIntent;
  queryResult?: QueryResult;
  auditLog: {
    log: (entry: {
      type: string;
      userId: string;
      query: string;
      errors?: unknown[];
    }) => Promise<void>;
  };
}

// ============================================================================
// Step 1: Get User Permissions from RBAC
// ============================================================================

const validatePermissions = new Step({
  id: 'validate-permissions',
  execute: async ({ context }: { context: WorkflowContext }) => {
    const { userId } = context.triggerData;

    // Load user permissions from RBAC tables
    const permissions = await loadUserPermissions(context.db, userId);

    return { permissions };
  },
});

async function loadUserPermissions(db: Knex, userId: string): Promise<RolePermissions> {
  // Get user's roles
  const userRoles = await db('sys_user_role')
    .join('sys_role', 'sys_user_role.sys_role_id', 'sys_role.sys_role_id')
    .where('sys_user_role.sys_user_id', userId)
    .select('sys_role.sys_role_id', 'sys_role.name');

  const roleIds = userRoles.map(r => r.sys_role_id);

  // Get table permissions for user's roles
  const tablePerms = await db('sys_role_table_access')
    .whereIn('sys_role_id', roleIds)
    .select('table_name', 'can_read', 'can_write', 'row_filter');

  const tablePermissions = new Map<string, { canRead: boolean; canWrite: boolean; rowFilter?: string }>();
  for (const perm of tablePerms) {
    const existing = tablePermissions.get(perm.table_name.toLowerCase());
    // Merge permissions (most permissive wins)
    tablePermissions.set(perm.table_name.toLowerCase(), {
      canRead: existing?.canRead || perm.can_read,
      canWrite: existing?.canWrite || perm.can_write,
      rowFilter: perm.row_filter || existing?.rowFilter,
    });
  }

  // Get field permissions for user's roles
  const fieldPerms = await db('sys_role_field_access')
    .whereIn('sys_role_id', roleIds)
    .join('sys_field', 'sys_role_field_access.sys_field_id', 'sys_field.sys_field_id')
    .join('sys_table', 'sys_field.sys_table_id', 'sys_table.sys_table_id')
    .select(
      'sys_table.table_name',
      'sys_field.column_name',
      'sys_role_field_access.is_visible',
      'sys_role_field_access.is_editable'
    );

  const fieldPermissions = new Map<string, Map<string, { isVisible: boolean; isEditable: boolean }>>();
  for (const perm of fieldPerms) {
    const tableName = perm.table_name.toLowerCase();
    if (!fieldPermissions.has(tableName)) {
      fieldPermissions.set(tableName, new Map());
    }
    const tableFields = fieldPermissions.get(tableName)!;
    const existing = tableFields.get(perm.column_name.toLowerCase());
    // Merge permissions (most permissive wins)
    tableFields.set(perm.column_name.toLowerCase(), {
      isVisible: existing?.isVisible || perm.is_visible,
      isEditable: existing?.isEditable || perm.is_editable,
    });
  }

  return {
    userId,
    roles: userRoles.map(r => r.name),
    tablePermissions,
    fieldPermissions,
  };
}

// ============================================================================
// Step 2: Parse Natural Language into Structured QueryIntent
// ============================================================================

const parseNaturalLanguage = new Step({
  id: 'parse-nl',
  execute: async ({ context }: { context: WorkflowContext }) => {
    const { query, userId, sessionId } = context.triggerData;

    // Mastra.ai agent parses NL to QueryIntent structure
    // This returns entity, operation, filters, etc. - NOT SQL
    const intent = await parseNaturalLanguageQuery(query, { userId, sessionId });

    return { intent };
  },
});

// ============================================================================
// Step 3: Validate with ANTLR4 (Syntax, Schema, Permissions)
// IMPORTANT: ANTLR4 is for VALIDATION ONLY
// ============================================================================

const validateWithANTLR4 = new Step({
  id: 'validate-antlr4',
  execute: async ({ context }: { context: WorkflowContext & { intent: QueryIntent; permissions: RolePermissions } }) => {
    const { intent, permissions } = context;

    // Build schema definition from database
    const schemaDefinition = await buildSchemaDefinition(context.db);

    // Create validator with schema AND permissions
    const validator = new ANTLR4SQLValidator(
      schemaDefinition,
      permissions,
      { maxComplexityScore: 80 }
    );

    // Generate SQL representation for validation purposes
    const sqlForValidation = intentToSQLForValidation(intent);

    // Validate SQL syntax, schema compliance, and role-based permissions
    const validationResult = validator.validate(sqlForValidation);

    if (!validationResult.isValid) {
      // Log validation failure for security audit
      await context.auditLog.log({
        type: 'query_validation_failure',
        userId: context.triggerData.userId,
        query: context.triggerData.query,
        errors: validationResult.errors,
      });

      throw new Error(
        `Query validation failed: ${validationResult.errors.map(e => e.message).join('; ')}`
      );
    }

    // Log warnings if any
    if (validationResult.warnings.length > 0) {
      console.warn('Query validation warnings:', validationResult.warnings);
    }

    return {
      validatedIntent: intent,
      complexity: validationResult.complexity,
    };
  },
});

/**
 * Generate SQL for validation purposes only
 * This generates SQL purely for ANTLR4 validation
 * The actual query execution uses Knex.js Query Builder
 */
function intentToSQLForValidation(intent: QueryIntent): string {
  const table = `bus_${intent.entity.toLowerCase()}`;
  const fields = intent.fields?.join(', ') || '*';
  let sql = `SELECT ${fields} FROM ${table}`;

  if (intent.filters?.length) {
    const conditions = intent.filters.map(f =>
      `${f.field} ${operatorToSQL(f.operator)} ?`
    ).join(' AND ');
    sql += ` WHERE ${conditions}`;
  }

  if (intent.groupBy?.length) {
    sql += ` GROUP BY ${intent.groupBy.join(', ')}`;
  }

  if (intent.orderBy?.length) {
    const orderClauses = intent.orderBy.map(o => `${o.field} ${o.direction.toUpperCase()}`);
    sql += ` ORDER BY ${orderClauses.join(', ')}`;
  }

  if (intent.limit) {
    sql += ` LIMIT ${intent.limit}`;
  }

  return sql;
}

function operatorToSQL(op: string): string {
  const mapping: Record<string, string> = {
    'eq': '=',
    'ne': '!=',
    'gt': '>',
    'lt': '<',
    'gte': '>=',
    'lte': '<=',
    'like': 'LIKE',
    'in': 'IN',
    'between': 'BETWEEN',
    'isNull': 'IS NULL',
    'isNotNull': 'IS NOT NULL',
  };
  return mapping[op] || '=';
}

// ============================================================================
// Step 4: Build Query Using Knex.js Query Builder DIRECTLY
// IMPORTANT: This does NOT convert SQL - it builds Knex queries from intent
// ============================================================================

const buildWithKnexQueryBuilder = new Step({
  id: 'build-knex-query',
  execute: async ({ context }: { context: WorkflowContext & { validatedIntent: QueryIntent; permissions: RolePermissions } }) => {
    const { validatedIntent, permissions } = context;

    // Use Knex.js Query Builder DIRECTLY - NOT SQL conversion
    const knexBuilder = new KnexQueryBuilder(context.db, permissions);
    const queryResult = await knexBuilder.executeQuery(
      validatedIntent,
      context.triggerData.query
    );

    return { queryResult };
  },
});

// ============================================================================
// Step 5: Format Results for CopilotKit Display
// ============================================================================

const formatForCopilotKit = new Step({
  id: 'format-for-copilotkit',
  execute: async ({ context }: { context: WorkflowContext & { queryResult: QueryResult; validatedIntent: QueryIntent } }) => {
    const { queryResult, validatedIntent } = context;

    // Format results for CopilotKit chat display
    const formatted = {
      success: true,
      data: queryResult.data,
      count: queryResult.count,
      entity: validatedIntent.entity,
      query: context.triggerData.query,
      displayHint: queryResult.displayHint,
      executionTimeMs: queryResult.executionTimeMs,
      // Include summary for chat display
      summary: generateResultSummary(queryResult, validatedIntent),
    };

    // Log successful query for analytics
    await context.auditLog.log({
      type: 'query_success',
      userId: context.triggerData.userId,
      query: context.triggerData.query,
    });

    return formatted;
  },
});

function generateResultSummary(result: QueryResult, intent: QueryIntent): string {
  if (intent.operation === 'count') {
    return `Found ${result.count} ${intent.entity} records`;
  }
  if (intent.operation === 'aggregate') {
    return `Aggregation results for ${intent.entity}`;
  }
  return `Showing ${result.data.length} of ${result.count} ${intent.entity} records`;
}

// ============================================================================
// Workflow Definition
// ============================================================================

export const dataQueryWorkflow = new Workflow({
  name: 'data-query',
  triggerSchema: workflowInputSchema,
})
  .step(validatePermissions)
  .step(parseNaturalLanguage)
  .step(validateWithANTLR4)
  .step(buildWithKnexQueryBuilder)
  .step(formatForCopilotKit)
  .commit();

// ============================================================================
// Workflow Execution Helper
// ============================================================================

export interface DataQueryWorkflowResult {
  success: boolean;
  data: Record<string, unknown>[];
  count: number;
  entity: string;
  query: string;
  displayHint: 'table' | 'chart' | 'number';
  executionTimeMs: number;
  summary: string;
}

/**
 * Execute the data query workflow
 */
export async function executeDataQuery(
  db: Knex,
  input: WorkflowInput,
  auditLog: WorkflowContext['auditLog']
): Promise<DataQueryWorkflowResult> {
  const result = await dataQueryWorkflow.execute({
    triggerData: input,
    // Provide context to all steps
    db,
    auditLog,
  } as unknown as WorkflowContext);

  return result as DataQueryWorkflowResult;
}
