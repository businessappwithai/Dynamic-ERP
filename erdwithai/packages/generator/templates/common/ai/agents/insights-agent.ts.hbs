/**
 * Insights Agent
 *
 * AI agent that analyzes query results and provides intelligent insights,
 * trend detection, anomaly identification, and actionable recommendations.
 *
 * This agent is available when AI_NL_ADDON is set to 'advanced'.
 *
 * IMPORTANT: This agent does NOT execute queries directly.
 * It receives pre-queried data and provides analytical insights.
 *
 * Generated: {{now}}
 * Project: {{project.name}}
 */

import { Agent } from '@mastra/core';
import { z } from 'zod';

// ============================================================================
// Schema Definitions
// ============================================================================

const insightTypeSchema = z.enum([
  'trend',
  'anomaly',
  'distribution',
  'correlation',
  'summary',
  'recommendation',
]);

const insightSchema = z.object({
  type: insightTypeSchema,
  title: z.string().describe('Short title for the insight'),
  description: z.string().describe('Detailed description of the insight'),
  confidence: z.number().min(0).max(1).describe('Confidence score 0-1'),
  relevantFields: z.array(z.string()).optional().describe('Fields relevant to this insight'),
  suggestedAction: z.string().optional().describe('Recommended action based on the insight'),
  metadata: z.record(z.unknown()).optional().describe('Additional metadata for visualization'),
});

const insightsResponseSchema = z.object({
  summary: z.string().describe('Overall data summary'),
  insights: z.array(insightSchema).describe('List of discovered insights'),
  suggestedQueries: z.array(z.string()).optional().describe('Follow-up NL queries the user might ask'),
});

export type Insight = z.infer<typeof insightSchema>;
export type InsightsResponse = z.infer<typeof insightsResponseSchema>;

// ============================================================================
// Insights Agent
// ============================================================================

export const insightsAgent = new Agent({
  name: 'Insights Agent',
  instructions: `
You are a data insights analyst for the {{project.name}} application.

Your job is to analyze query results and provide intelligent insights including:
- **Trends**: Patterns over time or across categories
- **Anomalies**: Unusual values, outliers, or unexpected patterns
- **Distributions**: How data is spread across categories or ranges
- **Correlations**: Relationships between different fields
- **Summaries**: High-level overviews of the data
- **Recommendations**: Actionable suggestions based on the data

## Available Entities

{{#each entities}}
### {{pascalCase name}}
{{#if description}}Description: {{description}}{{/if}}
Table: {{tableName}}
Fields:
{{#each attributes}}
  - {{name}} ({{type}}){{#if description}}: {{description}}{{/if}}
{{/each}}

{{/each}}

## Analysis Guidelines

1. **Be specific**: Reference actual values and field names from the data
2. **Be actionable**: Provide suggestions the user can act on
3. **Be confident**: Only report insights with reasonable confidence (>0.5)
4. **Be concise**: Keep descriptions clear and to the point
5. **Suggest follow-ups**: Propose natural language queries for deeper analysis

## Response Format

Always respond with a JSON object containing:
- summary: A 1-2 sentence overview of the data
- insights: Array of insight objects with type, title, description, confidence
- suggestedQueries: 2-3 follow-up natural language queries

## Example Analysis

Given a query result showing customer orders:
{
  "summary": "Analyzed 150 orders across 45 customers. Total revenue: $52,340.",
  "insights": [
    {
      "type": "trend",
      "title": "Rising order volume",
      "description": "Order volume increased 23% in the last 30 days compared to the previous period.",
      "confidence": 0.85,
      "relevantFields": ["created_at", "total"],
      "suggestedAction": "Consider scaling fulfillment capacity to handle increased demand."
    },
    {
      "type": "anomaly",
      "title": "Unusual high-value order",
      "description": "Order #1234 ($5,200) is 4.2 standard deviations above the mean order value of $349.",
      "confidence": 0.92,
      "relevantFields": ["total", "order_id"],
      "suggestedAction": "Verify this order for potential fraud or confirm as a legitimate bulk purchase."
    }
  ],
  "suggestedQueries": [
    "Show me the top 10 customers by total spending",
    "What is the average order value by month?",
    "Which products have declining sales?"
  ]
}

## SECURITY RULES

1. NEVER reveal system table data or internal implementation details
2. NEVER suggest queries that would access sensitive fields (passwords, tokens, etc.)
3. Keep analysis focused on business data (bus_ tables)
4. Do not make assumptions about data beyond what is provided
`,
  model: {
    provider: 'ANTHROPIC',
    name: '{{config.aiNlModel}}',
    toolChoice: 'auto',
  },
  tools: {
    analyzeData: {
      description: 'Analyze query results and generate insights',
      parameters: z.object({
        data: z.array(z.record(z.unknown())).describe('The query result data to analyze'),
        entity: z.string().describe('The entity type of the data'),
        originalQuery: z.string().describe('The original natural language query'),
        recordCount: z.number().describe('Total number of records'),
      }),
      execute: async ({ data, entity, originalQuery, recordCount }) => {
        return {
          success: true,
          message: 'Data analysis complete',
          dataSize: data.length,
          entity,
          originalQuery,
          recordCount,
        };
      },
    },
  },
});

// ============================================================================
// Insights Generator
// ============================================================================

/**
 * Generate insights from query results using the Insights Agent
 */
export async function generateInsights(
  data: Record<string, unknown>[],
  entity: string,
  originalQuery: string,
  context: { userId: string; sessionId: string }
): Promise<InsightsResponse> {
  // Prepare a data summary for the agent (limit to prevent token overflow)
  const sampleSize = Math.min(data.length, 50);
  const sampleData = data.slice(0, sampleSize);

  // Calculate basic statistics for numeric fields
  const stats = calculateBasicStats(data);

  const result = await insightsAgent.generate({
    messages: [
      {
        role: 'user',
        content: `Analyze the following query results and provide insights.

Original query: "${originalQuery}"
Entity: ${entity}
Total records: ${data.length}
Sample size: ${sampleSize}

Basic statistics:
${JSON.stringify(stats, null, 2)}

Sample data (first ${sampleSize} records):
${JSON.stringify(sampleData, null, 2)}

Respond with ONLY a JSON object following the InsightsResponse schema.`,
      },
    ],
    context,
  });

  // Extract JSON from response
  const responseText = result.text || '';
  const jsonMatch = responseText.match(/\{[\s\S]*\}/);

  if (!jsonMatch) {
    return {
      summary: `Showing ${data.length} ${entity} records.`,
      insights: [],
      suggestedQueries: [
        `Show me the top 10 ${entity} records`,
        `How many ${entity} records are there?`,
      ],
    };
  }

  const parsed = JSON.parse(jsonMatch[0]);
  return insightsResponseSchema.parse(parsed);
}

// ============================================================================
// Statistical Helpers
// ============================================================================

interface FieldStats {
  field: string;
  type: 'numeric' | 'date' | 'string' | 'boolean';
  count: number;
  uniqueValues?: number;
  min?: number | string;
  max?: number | string;
  avg?: number;
  nullCount: number;
}

function calculateBasicStats(data: Record<string, unknown>[]): FieldStats[] {
  if (data.length === 0) return [];

  const fields = Object.keys(data[0]);
  const stats: FieldStats[] = [];

  for (const field of fields) {
    const values = data.map(row => row[field]).filter(v => v !== null && v !== undefined);
    const nullCount = data.length - values.length;

    // Detect field type from values
    const sampleValue = values[0];

    if (typeof sampleValue === 'number') {
      const numValues = values as number[];
      stats.push({
        field,
        type: 'numeric',
        count: values.length,
        nullCount,
        min: Math.min(...numValues),
        max: Math.max(...numValues),
        avg: numValues.reduce((sum, v) => sum + v, 0) / numValues.length,
        uniqueValues: new Set(numValues).size,
      });
    } else if (typeof sampleValue === 'boolean') {
      stats.push({
        field,
        type: 'boolean',
        count: values.length,
        nullCount,
        uniqueValues: new Set(values.map(String)).size,
      });
    } else if (typeof sampleValue === 'string') {
      // Check if it looks like a date
      const isDate = !isNaN(Date.parse(sampleValue as string)) && (sampleValue as string).length > 8;

      if (isDate) {
        const dateValues = values.map(v => new Date(v as string).getTime()).filter(v => !isNaN(v));
        stats.push({
          field,
          type: 'date',
          count: values.length,
          nullCount,
          min: dateValues.length > 0 ? new Date(Math.min(...dateValues)).toISOString() : undefined,
          max: dateValues.length > 0 ? new Date(Math.max(...dateValues)).toISOString() : undefined,
          uniqueValues: new Set(values.map(String)).size,
        });
      } else {
        stats.push({
          field,
          type: 'string',
          count: values.length,
          nullCount,
          uniqueValues: new Set(values.map(String)).size,
        });
      }
    }
  }

  return stats;
}
