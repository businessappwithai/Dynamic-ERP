{
  "name": "{{kebabCase project.name}}",
  "version": "{{project.version}}",
  "description": "{{project.description}} — TanStack Start frontend over a live erpclaw-gateway. No generated backend or database: @erdwithai/erpclaw-client is the entire data layer.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port {{config.port}}",
    "build": "vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "codegen:erp": "erpclaw-codegen --base-url $VITE_ERP_GATEWAY_URL --token-env ERP_GATEWAY_TOKEN --out-dir src/generated"
  },
  "dependencies": {
    "@erdwithai/erpclaw-client": "{{erpclawClientDependencySpecifier}}",
    "@tanstack/react-router": "1.169.2",
    "@tanstack/react-start": "1.167.65",
    "@tanstack/react-query": "^5.71.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/router-plugin": "1.167.35",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.7.0",
    "vite": "^8.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.1.0"
  }
}
