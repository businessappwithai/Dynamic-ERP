{
  "$schema": "https://sap.github.io/ui5-tooling/schema/ui5lint.json",
  "version": "1.0",
  "rules": {
    "no-globals": "error",
    "no-deprecated-api": "warn",
    "no-direct-datatype-access": "error",
    "no-pseudo-modules": "error",
    "async-component-flags": "error"
  },
  "excludes": ["node_modules/**", "dist/**", "build/**"]
}
