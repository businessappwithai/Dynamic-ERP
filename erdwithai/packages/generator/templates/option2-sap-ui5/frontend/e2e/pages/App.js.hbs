/**
 * App Page Object for {{project.name}}
 * Generated by ERDwithAI
 */

sap.ui.define([
  'sap/ui/test/Opa5',
  'sap/ui/test/actions/Press'
], function (Opa5, Press) {
  'use strict';

  const sViewName = 'App';

  Opa5.createPageObjects({
    onTheApp: {

      actions: {
        iNavigateTo: function (sEntityName) {
          return this.waitFor({
            id: 'shell--header',
            viewName: sViewName,
            actions: new Press(),
            errorMessage: `Did not find shell header`
          }).and({
            controlType: 'sap.m.StandardListItem',
            viewName: sViewName,
            matchers: new Opa5.Matchers.Properties({
              title: sEntityName
            }),
            actions: new Press(),
            errorMessage: `Did not find ${sEntityName} list item`
          });
        },

        iNavigateToHome: function () {
          return this.waitFor({
            id: 'homeButton',
            viewName: sViewName,
            actions: new Press(),
            errorMessage: 'Did not find home button'
          });
        }
      },

      assertions: {
        iShouldSeeThePage: function (sPageName) {
          return this.waitFor({
            controlType: 'sap.m.Page',
            matchers: function (oPage) {
              return oPage.getTitle() === sPageName;
            },
            success: function () {
              Opa5.assert.ok(true, `Was able to view the ${sPageName} page`);
            },
            errorMessage: `Did not reach the ${sPageName} page`
          });
        },

        theURLShouldContain: function (sHash) {
          return this.waitFor({
            success: function () {
              Opa5.assert.ok(
                Opa5.getHash().indexOf(sHash) > -1,
                `The hash should contain "${sHash}"`
              );
            },
            errorMessage: `The hash does not contain "${sHash}"`
          });
        },

        iShouldSeeAllEntityLinks: function () {
          return this.waitFor({
            controlType: 'sap.m.StandardListItem',
            viewName: sViewName,
            matchers: function (oListItem) {
              const aValidTitles = [
                {{#each entities}}
                '{{name}}',
                {{/each}}
              ];
              const sTitle = oListItem.getTitle();
              return aValidTitles.indexOf(sTitle) > -1;
            },
            success: function (aListItems) {
              Opa5.assert.strictEqual(
                aListItems.length,
                {{entities.length}},
                'Did not see all entity links'
              );
            },
            errorMessage: 'Did not see all entity links in dashboard'
          });
        }
      }
    }
  });
});
