/**
 * Navigation Journey Tests for {{project.name}}
 * Generated by ERDwithAI
 */

sap.ui.define([
  'sap/ui/test/Opa5',
  './pages/App'
], function (Opa5, App) {
  'use strict';

  Opa5.createPageObjects({
    onTheApp: {
      baseClass: App
    }
  });

  QUnit.module('Navigation Journey');

  opaTest('Should navigate to all entities from menu', function (Given) {
    // Navigate to each entity and verify
    {{#each entities}}
    Given.onTheApp.iNavigateTo('{{name}}');
    Then.onTheApp.iShouldSeeThePage('{{name}}');
    Then.onTheApp.theURLShouldContain('{{lowerCase name}}s');

    // Go back to home
    Given.onTheApp.iNavigateToHome();
    {{/each}}
  });

  opaTest('Should display all entities in dashboard', function (Given, When, Then) {
    Given.onTheApp.iNavigateToHome();
    Then.onTheApp.iShouldSeeAllEntityLinks();
  });
});
