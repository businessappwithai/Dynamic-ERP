import { Injectable, NotFoundException } from '@nestjs/common';
import { v4 as uuidv4 } from 'uuid';
import { DatabaseService } from '../../database/database.service';

@Injectable()
export class SysValRuleService {
  constructor(private readonly db: DatabaseService) {}

  async findAll(options: { page?: number; limit?: number } = {}) {
    const { page = 1, limit = 100 } = options;
    const offset = (page - 1) * limit;

    const [data, countResult] = await Promise.all([
      this.db.kysely
        .selectFrom('sys_val_rule')
        .selectAll()
        .where('is_active', '=', true)
        .orderBy('name', 'asc')
        .limit(limit)
        .offset(offset)
        .execute(),
      this.db.kysely
        .selectFrom('sys_val_rule')
        .select((eb) => eb.fn.countAll().as('count'))
        .where('is_active', '=', true)
        .executeTakeFirst(),
    ]);

    return {
      data,
      meta: {
        total: Number(countResult?.count || 0),
        page,
        pageSize: limit,
        totalPages: Math.ceil(Number(countResult?.count || 0) / limit),
      },
    };
  }

  async findById(id: string) {
    const rule = await this.db.kysely
      .selectFrom('sys_val_rule')
      .selectAll()
      .where('sys_val_rule_id', '=', id)
      .executeTakeFirst();
    if (!rule) {
      throw new NotFoundException(`SysValRule with ID ${id} not found`);
    }
    return rule;
  }

  async create(data: any) {
    const now = new Date();
    const id = uuidv4();

    const newRecord = {
      sys_val_rule_id: id,
      ...data,
      type: data.type || 'S',
      entity_type: data.entity_type || 'D',
      is_active: data.is_active !== false,
      created_at: now,
      updated_at: now,
      created_by: '',
      updated_by: '',
    };

    await this.db.kysely.insertInto('sys_val_rule').values(newRecord).execute();
    return this.findById(id);
  }

  async update(id: string, data: any) {
    const updated = { ...data, updated_at: new Date(), updated_by: '' };
    await this.db.kysely
      .updateTable('sys_val_rule')
      .set(updated)
      .where('sys_val_rule_id', '=', id)
      .execute();
    return this.findById(id);
  }

  async delete(id: string) {
    await this.findById(id);
    await this.db.kysely
      .updateTable('sys_val_rule')
      .set({ is_active: false, deleted_at: new Date() })
      .where('sys_val_rule_id', '=', id)
      .execute();
    return { deleted: true };
  }
}
