/**
 * Auth Service
 *
 * Handles authentication and user management.
 *
 * Generated: {{now}}
 */

import { Injectable, UnauthorizedException, ConflictException } from '@nestjs/common';
import { JwtService } from '@nestjs/jwt';
import { ConfigService } from '@nestjs/config';
import { DatabaseService } from '../../database/database.service';
import * as bcrypt from 'bcrypt';
import { v4 as uuidv4 } from 'uuid';

export interface RegisterDto {
  name: string;
  email: string;
  password: string;
}

export interface LoginDto {
  email: string;
  password: string;
}

export interface JwtPayload {
  sub: string;
  email: string;
  name: string;
}

@Injectable()
export class AuthService {
  constructor(
    private jwtService: JwtService,
    private configService: ConfigService,
    private databaseService: DatabaseService,
  ) {}

  /**
   * Register a new user
   */
  async register(registerDto: RegisterDto) {
    const { name, email, password } = registerDto;

    // Check if user already exists
    const existingUser = await this.databaseService.kysely
      .selectFrom('sys_user')
      .selectAll()
      .where('email', '=', email)
      .executeTakeFirst();

    if (existingUser) {
      throw new ConflictException('User with this email already exists');
    }

    // Hash password
    const hashedPassword = await bcrypt.hash(password, 10);

    const newUserId = uuidv4();

    // Create user
    await this.databaseService.kysely.insertInto('sys_user').values({
      sys_user_id: newUserId,
      name,
      email,
      password_hash: hashedPassword,
      is_active: true,
      is_locked: false,
      created_at: new Date(),
      updated_at: new Date(),
    } as any).execute();

    // Get created user
    const user = await this.databaseService.kysely
      .selectFrom('sys_user')
      .selectAll()
      .where('sys_user_id', '=', newUserId)
      .executeTakeFirst();

    // Generate token
    return this.generateToken(user);
  }

  /**
   * Login user
   */
  async login(loginDto: LoginDto) {
    const { email, password } = loginDto;

    // Find user
    const user = await this.databaseService.kysely
      .selectFrom('sys_user')
      .selectAll()
      .where('email', '=', email)
      .executeTakeFirst();

    if (!user) {
      throw new UnauthorizedException('Invalid credentials');
    }

    // Check if user is active
    if (!user.is_active) {
      throw new UnauthorizedException('User account is inactive');
    }

    // Check if user is locked
    if (user.is_locked) {
      throw new UnauthorizedException('User account is locked');
    }

    // Verify password
    const isPasswordValid = await bcrypt.compare(password, user.password_hash);
    if (!isPasswordValid) {
      throw new UnauthorizedException('Invalid credentials');
    }

    // Update last login
    await this.databaseService.kysely
      .updateTable('sys_user')
      .set({
        last_login: new Date(),
        updated_at: new Date(),
      } as any)
      .where('sys_user_id', '=', user.sys_user_id)
      .execute();

    // Generate token
    return this.generateToken(user);
  }

  /**
   * Validate user for JWT strategy
   */
  async validateUser(userId: string) {
    const user = await this.databaseService.kysely
      .selectFrom('sys_user')
      .selectAll()
      .where('sys_user_id', '=', userId)
      .where('is_active', '=', true)
      .executeTakeFirst();

    if (!user) {
      return null;
    }

    // Get user roles
    const roleRows = await this.databaseService.kysely
      .selectFrom('sys_user_roles')
      .innerJoin('sys_role', 'sys_user_roles.role_id', 'sys_role.sys_role_id')
      .select('sys_role.name')
      .where('sys_user_roles.user_id', '=', userId)
      .where('sys_role.is_active', '=', true)
      .execute();

    const roles = roleRows.map((r: any) => r.name);

    return {
      sys_user_id: user.sys_user_id,
      email: user.email,
      name: user.name,
      roles,
    };
  }

  /**
   * Generate JWT token
   */
  private async generateToken(user: any): Promise<{ access_token: string; user: any }> {
    const payload: JwtPayload = {
      sub: user.sys_user_id,
      email: user.email,
      name: user.name,
    };

    const access_token = this.jwtService.sign(payload);

    // Get user roles
    const roles = await this.databaseService.kysely
      .selectFrom('sys_user_roles')
      .innerJoin('sys_role', 'sys_user_roles.role_id', 'sys_role.sys_role_id')
      .select(['sys_role.sys_role_id', 'sys_role.name'])
      .where('sys_user_roles.user_id', '=', user.sys_user_id)
      .where('sys_role.is_active', '=', true)
      .execute();

    return {
      access_token,
      user: {
        sys_user_id: user.sys_user_id,
        email: user.email,
        name: user.name,
        roles,
      },
    };
  }

  /**
   * Change password
   */
  async changePassword(userId: string, oldPassword: string, newPassword: string) {
    const user = await this.databaseService.kysely
      .selectFrom('sys_user')
      .selectAll()
      .where('sys_user_id', '=', userId)
      .executeTakeFirst();

    if (!user) {
      throw new UnauthorizedException('User not found');
    }

    // Verify old password
    const isPasswordValid = await bcrypt.compare(oldPassword, user.password_hash);
    if (!isPasswordValid) {
      throw new UnauthorizedException('Invalid current password');
    }

    // Hash new password
    const hashedPassword = await bcrypt.hash(newPassword, 10);

    // Update password
    await this.databaseService.kysely
      .updateTable('sys_user')
      .set({
        password_hash: hashedPassword,
        updated_at: new Date(),
      } as any)
      .where('sys_user_id', '=', userId)
      .execute();

    return { message: 'Password changed successfully' };
  }
}
