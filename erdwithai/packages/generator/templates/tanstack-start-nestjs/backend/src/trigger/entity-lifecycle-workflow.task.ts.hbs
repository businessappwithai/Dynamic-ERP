/**
 * Entity Lifecycle Workflow - Trigger.dev v3 Task
 *
 * Fired (non-blocking) after every entity CREATE/UPDATE/DELETE by
 * WorkflowService.trigger(). Loads the entity, evaluates the active JDM rule
 * for its entity/operation (if any) via the real GoRules zen-engine, applies
 * any resulting mutations back to the entity row, and records the outcome on
 * both sys_workflow_runs and the entity's own workflow_status column.
 *
 * Related-entity loading is a known simplification: it currently returns an
 * empty relations object rather than eagerly loading FK-related rows, since
 * that needs per-entity FK metadata this generic task doesn't have. A rule
 * that only inspects `entity` fields works today; one that needs `relations`
 * does not yet.
 *
 * Generated: {{now}}
 * Project: {{project.name}}
 */

import { task } from '@trigger.dev/sdk/v3';
import { ZenEngine } from '@gorules/zen-engine';
import { Kysely, PostgresDialect } from 'kysely';
import { Pool } from 'pg';

// Standalone connection: this task runs in Trigger.dev's own worker process,
// outside the NestJS DI graph DatabaseService/DatabaseModule are wired into.
let _db: Kysely<any> | null = null;
function getDb(): Kysely<any> {
  if (!_db) {
    _db = new Kysely<any>({
      dialect: new PostgresDialect({ pool: new Pool({ connectionString: process.env.DATABASE_URL }) }),
    });
  }
  return _db;
}

let _engine: ZenEngine | null = null;
function getEngine(): ZenEngine {
  if (!_engine) {
    _engine = new ZenEngine();
  }
  return _engine;
}

interface WorkflowPayload {
  workflowRunId: string;
  entityName: string;
  entityId: string;
  operation: 'create' | 'update' | 'delete';
  userId?: string;
}

export const entityLifecycleWorkflow = task({
  id: 'entity-lifecycle-workflow',
  retry: {
    maxAttempts: 3,
    minTimeoutInMs: 2_000,
    maxTimeoutInMs: 8_000,
    factor: 2,
  },
  run: async (payload: WorkflowPayload) => {
    const db = getDb();

    try {
      const { entity, relations } = await loadEntityWithContext(db, payload.entityName, payload.entityId);

      const rule = await db
        .selectFrom('sys_rule_definitions')
        .selectAll()
        .where('entity_name', '=', payload.entityName)
        .where('operation', '=', payload.operation.toUpperCase())
        .where('is_active', '=', true)
        .executeTakeFirst();

      const mutations = rule
        ? await evaluateRules(getEngine(), rule.jdm_content, { ...entity, _relations: relations })
        : null;

      if (mutations && Object.keys(mutations).length > 0) {
        await db
          .updateTable(payload.entityName as any)
          .set(mutations as any)
          .where('id' as any, '=', payload.entityId)
          .execute();
      }

      await db
        .updateTable('sys_workflow_runs' as any)
        .set({
          status: 'success',
          result: JSON.stringify(mutations ?? {}),
          completed_at: new Date(),
          updated_at: new Date(),
        } as any)
        .where('id' as any, '=', payload.workflowRunId)
        .execute();

      await db
        .updateTable(payload.entityName as any)
        .set({ workflow_status: 'success' } as any)
        .where('id' as any, '=', payload.entityId)
        .execute();

      return { success: true, workflowRunId: payload.workflowRunId, mutationsApplied: mutations };
    } catch (error) {
      const message = error instanceof Error ? error.message : String(error);

      await db
        .updateTable('sys_workflow_runs' as any)
        .set({ status: 'error', error_message: message, completed_at: new Date(), updated_at: new Date() } as any)
        .where('id' as any, '=', payload.workflowRunId)
        .execute();

      await db
        .updateTable(payload.entityName as any)
        .set({ workflow_status: 'error' } as any)
        .where('id' as any, '=', payload.entityId)
        .execute();

      // Re-throw so Trigger.dev's own retry policy (above) applies -- this
      // task's job is to record the failure, not to swallow it.
      throw error;
    }
  },
});

/**
 * Evaluates a JDM rule against an entity, returning the mutation object the
 * decision produced (empty if the rule produced no output or failed).
 */
async function evaluateRules(
  engine: ZenEngine,
  jdmContent: string,
  context: Record<string, unknown>
): Promise<Record<string, unknown>> {
  try {
    const decision = engine.createDecision(JSON.parse(jdmContent));
    const result = await decision.evaluate(context);
    return (result?.result && typeof result.result === 'object') ? (result.result as Record<string, unknown>) : {};
  } catch (error) {
    console.error('[Workflow] Rule evaluation error:', error);
    return {};
  }
}

/**
 * Loads the entity row. See the module doc comment: relation loading is not
 * yet implemented (always returns `{}`).
 */
async function loadEntityWithContext(
  db: Kysely<any>,
  entityName: string,
  entityId: string
): Promise<{ entity: Record<string, unknown>; relations: Record<string, unknown> }> {
  const entity = await db.selectFrom(entityName as any).selectAll().where('id' as any, '=', entityId).executeTakeFirst();
  return { entity: (entity as Record<string, unknown>) ?? {}, relations: {} };
}
