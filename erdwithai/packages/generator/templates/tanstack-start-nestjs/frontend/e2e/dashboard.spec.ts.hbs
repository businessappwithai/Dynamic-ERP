import { test, expect } from '@playwright/test';

/**
 * E2E Tests for {{project.name}} Dashboard
 * Generated by ERDwithAI
 *
 * Tests the main application dashboard, navigation, and core features
 */

test.describe('Dashboard E2E Tests', () => {
  test.beforeEach(async ({ page }) => {
    // Navigate to the application
    await page.goto('/dashboard', { waitUntil: 'networkidle' });
  });

  test('should load dashboard successfully', async ({ page }) => {
    // Check that we're on the dashboard page
    await expect(page).toHaveTitle(/Dashboard|CRM|{{project.name}}/i);

    // Check for main dashboard elements
    const mainContent = page.locator('main');
    await expect(mainContent).toBeVisible();
  });

  test('should display entity overview cards', async ({ page }) => {
    // Look for entity cards on dashboard
    const cards = page.locator('[class*="card"]');
    const visibleCards = await cards.filter({ hasText: /Count|Total|Records/i }).count();

    expect(visibleCards).toBeGreaterThanOrEqual(0);
  });

  test('should have working navigation', async ({ page }) => {
    // Check for navigation elements
    const nav = page.locator('nav, [role="navigation"]');
    await expect(nav).toBeVisible();

    // Look for navigation links
    const links = nav.locator('a, button');
    const linkCount = await links.count();

    expect(linkCount).toBeGreaterThan(0);
  });

  test('should load without JavaScript errors', async ({ page }) => {
    let jsErrors: string[] = [];

    page.on('console', msg => {
      if (msg.type() === 'error') {
        jsErrors.push(msg.text());
      }
    });

    await page.reload();

    // Allow some console errors but check for critical ones
    const criticalErrors = jsErrors.filter(err =>
      !err.includes('Network') && !err.includes('401') && !err.includes('404')
    );

    expect(criticalErrors.length).toBe(0);
  });

  test('should have proper styling applied', async ({ page }) => {
    // Check that body has background color (Swiss Clean Design)
    const body = page.locator('body');
    const bgColor = await body.evaluate((el) =>
      window.getComputedStyle(el).backgroundColor
    );

    // Swiss Clean Design uses light backgrounds
    expect(bgColor).toBeTruthy();
  });

  test('should support responsive design', async ({ page, context }) => {
    // Test mobile viewport
    const mobileContext = await context.newPage();
    await mobileContext.setViewportSize({ width: 375, height: 667 });
    await mobileContext.goto('/dashboard');

    const mainContent = mobileContext.locator('main');
    await expect(mainContent).toBeVisible();

    await mobileContext.close();
  });
});

test.describe('Authentication E2E Tests', () => {
  test('should have auth-protected routes', async ({ page }) => {
    try {
      // Attempt to access protected route without auth
      await page.goto('/dashboard');

      // Should be redirected to login or show error
      const isOnDashboard = page.url().includes('dashboard');

      // If not authenticated, should see login elements or be redirected
      if (!isOnDashboard) {
        const loginForm = page.locator('form, [class*="login"], [class*="auth"]');
        expect(await loginForm.count()).toBeGreaterThanOrEqual(0);
      }
    } catch (_e) {
      // Expected if not authenticated
      expect(true).toBe(true);
    }
  });
});

test.describe('Performance E2E Tests', () => {
  test('should load dashboard within acceptable time', async ({ page }) => {
    const startTime = Date.now();

    await page.goto('/dashboard', { waitUntil: 'networkidle' });

    const loadTime = Date.now() - startTime;

    // Dashboard should load within 5 seconds
    expect(loadTime).toBeLessThan(5000);
  });

  test('should handle navigation without lag', async ({ page }) => {
    await page.goto('/dashboard', { waitUntil: 'networkidle' });

    // Click on a navigation element if available
    const navLink = page.locator('a, button').first();

    if (await navLink.isVisible()) {
      const startTime = Date.now();
      await navLink.click().catch(() => {});
      const clickTime = Date.now() - startTime;

      // Navigation should respond within 500ms
      expect(clickTime).toBeLessThan(500);
    }
  });
});
