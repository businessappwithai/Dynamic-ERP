<core:FragmentDefinition
  xmlns:core="sap.ui.core"
  xmlns="sap.m"
  xmlns:f="sap.ui.layout.form"
  xmlns:u="sap.ui.unified">
  <Dialog
    id="childRecordDialog"
    title="{= ${dialog>/mode} === 'create' ? 'New ' + ${dialog>/tabName} : 'Edit ' + ${dialog>/tabName} }"
    busy="{dialog>/busy}"
    class="sapUiPopupWithPadding">

    <content>
      <f:SimpleForm
        editable="true"
        layout="ResponsiveGridLayout"
        labelSpanXL="3"
        labelSpanL="3"
        labelSpanM="3"
        labelSpanS="12"
        adjustLabelSpan="false"
        emptySpanXL="4"
        emptySpanL="4"
        emptySpanM="4"
        emptySpanS="0"
        columnsXL="1"
        columnsL="1"
        columnsM="1">

        {{#each dialogFields}}
        <Label text="{{display_name}}" {{#if is_mandatory}}required="true"{{/if}} />
        {{#if (eq ../fieldType "boolean")}}
        <CheckBox
          id="{{../fieldNamePrefix}}_{{column_name}}"
          selected="{dialog>/data/{{column_name}}}"
          editable="{{#if (eq column_name ../parentColumnName)}}false{{else}}true{{/if}}" />
        {{else if (eq ../fieldType "date")}}
        <DatePicker
          id="{{../fieldNamePrefix}}_{{column_name}}"
          value="{dialog>/data/{{column_name}}}"
          editable="{{#if (eq column_name ../parentColumnName)}}false{{else}}true{{/if}}"
          displayFormat="yyyy-MM-dd"
          valueFormat="yyyy-MM-dd"
          placeholder="Select date" />
        {{else if (eq ../fieldType "datetime")}}
        <DateTimePicker
          id="{{../fieldNamePrefix}}_{{column_name}}"
          value="{dialog>/data/{{column_name}}}"
          editable="{{#if (eq column_name ../parentColumnName)}}false{{else}}true{{/if}}"
          displayFormat="yyyy-MM-dd HH:mm"
          valueFormat="yyyy-MM-dd HH:mm"
          placeholder="Select date and time" />
        {{else if (eq ../fieldType "text")}}
        <TextArea
          id="{{../fieldNamePrefix}}_{{column_name}}"
          value="{dialog>/data/{{column_name}}}"
          editable="{{#if (eq column_name ../parentColumnName)}}false{{else}}true{{/if}}"
          placeholder="{{display_name}}"
          rows="3" />
        {{else}}
        <Input
          id="{{../fieldNamePrefix}}_{{column_name}}"
          value="{dialog>/data/{{column_name}}}"
          editable="{{#if (eq column_name ../parentColumnName)}}false{{else}}true{{/if}}"
          placeholder="{{display_name}}" />
        {{/if}}
        {{/each}}

      </f:SimpleForm>
    </content>

    <beginButton>
      <Button
        text="Save"
        type="Emphasized"
        press=".onSaveChildRecord" />
    </beginButton>

    <endButton>
      <Button
        text="Cancel"
        press=".onCancelChildRecord" />
    </endButton>
  </Dialog>
</core:FragmentDefinition>
