{{!--
  {{pascalCase entity.name}} Detail View

  CRITICAL FIXES APPLIED:
  - All property bindings use PascalCase (backend returns PascalCase properties)
  - All bindings include targetType: 'any' to avoid FormatException with OData V4 Raw type
  - Audit fields use PascalCase: CreatedAt, UpdatedAt (not created_at, updated_at)

  Generated: {{now}}
--}}
<mvc:View
  controllerName="{{kebabCase project.name}}.controller.entity.{{pascalCase entity.name}}Detail"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:form="sap.ui.layout.form"
  xmlns:core="sap.ui.core">

  <f:DynamicPage
    height="100%"
    headerExpanded="true"
    toggleHeaderOnTitleClick="true"
    busy="{view>/busy}">

    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="{{entity.displayName}}: { {{~#each entity.attributes~}} {{~#if this.isIdentifier~}} {path: '{{pascalCase this.name}}', targetType: 'any'} {{~/if~}} {{~/each~}} }" />
        </f:heading>
        <f:actions>
          <Button
            text="Edit"
            type="Emphasized"
            icon="sap-icon://edit"
            press=".onEditPress"
            visible="{= !${view>/editable} }" />
          <Button
            text="Save"
            type="Emphasized"
            icon="sap-icon://save"
            press=".onSavePress"
            visible="{view>/editable}" />
          <Button
            text="Cancel"
            press=".onCancelPress"
            visible="{view>/editable}" />
          <Button
            text="Delete"
            type="Reject"
            icon="sap-icon://delete"
            press=".onDeletePress"
            visible="{= !${view>/editable} }" />
        </f:actions>
        <f:navigationActions>
          <Button
            icon="sap-icon://nav-back"
            press=".onNavBack"
            tooltip="Back to List" />
        </f:navigationActions>
      </f:DynamicPageTitle>
    </f:title>

    <f:content>
      <VBox class="sapUiSmallMargin">
        {{!-- General Information Section --}}
        <Panel headerText="General Information" expandable="true" expanded="true">
          <form:SimpleForm
            editable="{view>/editable}"
            layout="ResponsiveGridLayout"
            labelSpanXL="3"
            labelSpanL="3"
            labelSpanM="3"
            labelSpanS="12"
            adjustLabelSpan="false"
            emptySpanXL="4"
            emptySpanL="4"
            emptySpanM="4"
            emptySpanS="0"
            columnsXL="1"
            columnsL="1"
            columnsM="1">
            {{#each entity.attributes}}
            {{#unless (isExcludedField this.name)}}
            <Label text="{{this.displayName}}" {{#if this.required}}required="true"{{/if}} />
            {{#if (eq this.type "boolean")}}
            <CheckBox selected="{path: '{{pascalCase this.name}}', targetType: 'any'}" enabled="{view>/editable}" />
            {{else if (eq this.type "date")}}
            <DatePicker
              value="{
                path: '{{pascalCase this.name}}',
                type: 'sap.ui.model.type.Date',
                targetType: 'any'
              }"
              displayFormat="yyyy-MM-dd"
              valueFormat="yyyy-MM-dd"
              editable="{view>/editable}" />
            {{else if (eq this.type "datetime")}}
            <DateTimePicker
              value="{
                path: '{{pascalCase this.name}}',
                type: 'sap.ui.model.type.DateTime',
                targetType: 'any'
              }"
              displayFormat="yyyy-MM-dd HH:mm:ss"
              valueFormat="yyyy-MM-dd HH:mm:ss"
              editable="{view>/editable}" />
            {{else if (eq this.type "text")}}
            <TextArea
              value="{path: '{{pascalCase this.name}}', targetType: 'any'}"
              editable="{view>/editable}"
              rows="3"
              width="100%" />
            {{else if (eq this.type "integer")}}
            <Input
              value="{path: '{{pascalCase this.name}}', targetType: 'any'}"
              editable="{view>/editable}"
              type="Number" />
            {{else if (eq this.type "decimal")}}
            <Input
              value="{
                path: '{{pascalCase this.name}}',
                type: 'sap.ui.model.type.Float',
                targetType: 'any'
              }"
              editable="{view>/editable}"
              type="Number" />
            {{else}}
            <Input
              value="{path: '{{pascalCase this.name}}', targetType: 'any'}"
              editable="{view>/editable}"
              {{#if (eq this.name entity.primaryKey)}}enabled="false"{{/if}} />
            {{/if}}
            {{/unless}}
            {{/each}}
          </form:SimpleForm>
        </Panel>

        {{!-- Audit Information Section --}}
        <Panel headerText="Audit Information" expandable="true" expanded="false">
          <form:SimpleForm
            editable="false"
            layout="ResponsiveGridLayout"
            labelSpanL="3" labelSpanM="3" labelSpanS="12">
            <Label text="Created At" />
            <Text text="{path: 'CreatedAt', targetType: 'any', formatter: '.formatDate'}" />
            <Label text="Updated At" />
            <Text text="{path: 'UpdatedAt', targetType: 'any', formatter: '.formatDate'}" />
          </form:SimpleForm>
        </Panel>
      </VBox>
    </f:content>

  </f:DynamicPage>
</mvc:View>
