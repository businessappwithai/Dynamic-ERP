<!--
  Master View - Entity Menu (Column 1)

  Displays a list of available business entities from $metadata.
  Clicking an entity navigates to the List view (Column 2).

  Generated: {{now}}
-->
<mvc:View
  controllerName="{{kebabCase project.name}}.controller.Master"
  xmlns="sap.m"
  xmlns:mvc="sap.ui.core.mvc">

  <Page
    id="masterPage"
    title="{{project.name}}"
    showNavButton="false">

    <customHeader>
      <Bar>
        <contentLeft>
          <Title text="{{project.name}}" />
        </contentLeft>
        <contentRight>
          <Button
            icon="sap-icon://settings"
            press=".onAdminPress"
            tooltip="{i18n>admin.tooltip}" />
        </contentRight>
      </Bar>
    </customHeader>

    <content>
      <!-- Search field for filtering entities -->
      <SearchField
        id="entitySearch"
        liveChange=".onEntitySearch"
        width="100%"
        placeholder="{i18n>master.searchPlaceholder}" />

      <!-- Entity list dynamically populated from $metadata -->
      <List
        id="entityList"
        items="{
          path: '/entities',
          sorter: { path: 'name', descending: false }
        }"
        mode="SingleSelectMaster"
        selectionChange=".onEntitySelect">

        <items>
          <StandardListItem
            title="{name}"
            description="{description}"
            type="Navigation"
            icon="{= ${isSystem} ? 'sap-icon://it-host' : 'sap-icon://table-view' }" />
        </items>

      </List>

      <!-- Empty state when no entities -->
      <IllustratedMessage
        id="noEntitiesMessage"
        illustrationType="NoData"
        title="{i18n>master.noEntities.title}"
        description="{i18n>master.noEntities.description}"
        visible="false" />

    </content>

    <footer>
      <Bar>
        <contentMiddle>
          <Text text="v{{project.version}}" />
        </contentMiddle>
      </Bar>
    </footer>

  </Page>

</mvc:View>
