{{!-- {{pascalCase entity.name}} Create View --}}
<mvc:View
  controllerName="{{kebabCase project.name}}.controller.entity.{{pascalCase entity.name}}Create"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:form="sap.ui.layout.form"
  xmlns:core="sap.ui.core">

  <Page
    title="Create {{entity.displayName}}"
    showNavButton="true"
    navButtonPress=".onNavBack"
    busy="{view>/busy}">

    <content>
      <form:SimpleForm
        editable="true"
        layout="ResponsiveGridLayout"
        labelSpanXL="3"
        labelSpanL="3"
        labelSpanM="3"
        labelSpanS="12"
        adjustLabelSpan="false"
        emptySpanXL="4"
        emptySpanL="4"
        emptySpanM="4"
        emptySpanS="0"
        columnsXL="1"
        columnsL="1"
        columnsM="1"
        class="sapUiSmallMargin">

        <core:Title text="{{entity.displayName}} Details" />

        {{#each entity.attributes}}
        {{#unless (isExcludedField this.name)}}
        {{#unless (eq this.name entity.primaryKey)}}
        <Label text="{{this.displayName}}" {{#if this.required}}required="true"{{/if}} />
        {{#if (eq this.type "boolean")}}
        <CheckBox selected="{view>/formData/{{this.name}}}" />
        {{else if (eq this.type "date")}}
        <DatePicker value="{view>/formData/{{this.name}}}" />
        {{else if (eq this.type "datetime")}}
        <DateTimePicker value="{view>/formData/{{this.name}}}" />
        {{else if (eq this.type "text")}}
        <TextArea value="{view>/formData/{{this.name}}}" rows="3" width="100%" {{#if this.required}}required="true"{{/if}} />
        {{else if (eq this.type "integer")}}
        <Input value="{view>/formData/{{this.name}}}" type="Number" />
        {{else if (eq this.type "decimal")}}
        <Input value="{view>/formData/{{this.name}}}" type="Number" />
        {{else}}
        <Input value="{view>/formData/{{this.name}}}" {{#if this.required}}required="true"{{/if}} />
        {{/if}}
        {{/unless}}
        {{/unless}}
        {{/each}}

      </form:SimpleForm>
    </content>

    <footer>
      <OverflowToolbar>
        <ToolbarSpacer />
        <Button text="Create" type="Emphasized" press=".onSavePress" />
        <Button text="Cancel" press=".onCancelPress" />
      </OverflowToolbar>
    </footer>

  </Page>
</mvc:View>
