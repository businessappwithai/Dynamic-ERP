{{!--
  {{pascalCase entity.name}} List View - Column 2

  CRITICAL FIXES APPLIED:
  - Table columns and items are generated dynamically in the controller
  - Controller uses getSelectedItem() for proper navigation (see EntityList.controller)
  - All dynamic bindings use PascalCase property names and targetType: 'any'

  Generated: {{now}}
--}}
<mvc:View
  controllerName="{{kebabCase project.name}}.controller.entity.{{pascalCase entity.name}}List"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:semantic="sap.f.semantic"
  xmlns:core="sap.ui.core">

  <semantic:SemanticPage
    headerPinnable="false"
    toggleHeaderOnTitleClick="false"
    busy="{view>/busy}">

    <semantic:titleHeading>
      <VBox>
        <HBox renderBox="true">
          <Text text="{view>/itemCount} of {view>/totalCount}" class="sapMTitleSampleStyle" />
        </HBox>
        <Title text="{{entity.displayName}}s" />
      </VBox>
    </semantic:titleHeading>

    <semantic:headerContent>
      <HBox alignItems="Center" justifyContent="SpaceBetween" width="100%">
        <VBox>
          {{!-- Quick Search (client-side) --}}
          <SearchField
            id="quickSearchField"
            placeholder="Quick search in loaded data..."
            search=".onQuickSearch"
            width="20rem" />
        </VBox>
        <HBox>
          <Button
            text="Advanced Search"
            icon="sap-icon://filter"
            type="Transparent"
            press=".onToggleAdvancedSearch" />
          <Button
            icon="sap-icon://refresh"
            type="Transparent"
            press=".onRefresh"
            tooltip="Refresh" />
        </HBox>
      </HBox>

      {{!-- Advanced Search Panel (server-side) --}}
      <Panel
        visible="{view>/advancedSearchVisible}"
        expandable="false"
        width="100%">
        <HBox alignItems="Center" class="sapUiSmallMargin">
          <Select id="advSearchField" width="10rem">
            {{#each entity.attributes}}
            {{#unless (isExcludedField this.name)}}
            <core:Item key="{{this.name}}" text="{{this.displayName}}" />
            {{/unless}}
            {{/each}}
          </Select>
          <Select id="advSearchOperator" width="8rem" class="sapUiTinyMarginBegin">
            <core:Item key="Contains" text="Contains" />
            <core:Item key="EQ" text="Equals" />
            <core:Item key="StartsWith" text="Starts With" />
            <core:Item key="EndsWith" text="Ends With" />
            <core:Item key="GT" text="Greater Than" />
            <core:Item key="LT" text="Less Than" />
          </Select>
          <Input id="advSearchValue" placeholder="Search value..." width="12rem" class="sapUiTinyMarginBegin"
            submit=".onAdvancedSearch" />
          <Button text="Search" type="Emphasized" press=".onAdvancedSearch" class="sapUiTinyMarginBegin" />
          <Button text="Clear" press=".onClearAdvancedSearch" class="sapUiTinyMarginBegin" />
        </HBox>
      </Panel>
    </semantic:headerContent>

    <semantic:content>
      <Table
        id="entityTable"
        growing="true"
        growingThreshold="20"
        growingScrollToLoad="true"
        mode="SingleSelectMaster"
        selectionChange=".onItemPress"
        noDataText="No {{entity.displayName}} records found"
        class="sapUiResponsiveMargin"
        width="auto">
        <headerToolbar>
          <OverflowToolbar>
            <Title text="{{entity.displayName}} Records" level="H3" />
            <ToolbarSpacer />
          </OverflowToolbar>
        </headerToolbar>
      </Table>
    </semantic:content>

    <semantic:addAction>
      <semantic:AddAction press=".onCreatePress" />
    </semantic:addAction>

    <semantic:navigationAction>
      <semantic:FullScreenAction press=".onNavBack" />
    </semantic:navigationAction>

  </semantic:SemanticPage>
</mvc:View>
