<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>OPA5 Integration Tests - {{project.name}}</title>

    <script
        id="sap-ui-bootstrap"
        src="https://ui5.sap.com/resources/sap-ui-core.js"
        data-sap-ui-theme="{{config.theme}}"
        data-sap-ui-resource-roots='{
            "{{project.name}}": "../../",
            "test": "./"
        }'
        data-sap-ui-async="true"
        data-sap-ui-on-init="module:test/integration/opaTests.qunit"
        data-sap-ui-compat-version="edge"
        data-sap-ui-frame-options="trusted">
    </script>

    <link rel="stylesheet" type="text/css" href="https://ui5.sap.com/resources/sap/ui/thirdparty/qunit-2.css">

    <script src="https://ui5.sap.com/resources/sap/ui/thirdparty/qunit-2.js"></script>
    <script src="https://ui5.sap.com/resources/sap/ui/qunit/qunit-junit.js"></script>
</head>
<body>
    <div id="qunit"></div>
    <div id="qunit-fixture"></div>
</body>
</html>
