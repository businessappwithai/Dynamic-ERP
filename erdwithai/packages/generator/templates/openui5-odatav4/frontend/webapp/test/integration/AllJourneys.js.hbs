/**
 * All OPA5 Journeys for {{project.name}}
 * Generated by ERDwithAI
 *
 * Aggregates all test journeys including CRUD operations
 */

sap.ui.define([
    "sap/ui/test/Opa5",
    "./NavigationJourney",
    {{#each entities}}
    "./{{pascalCase name}}CRUDJourney"{{#unless @last}},{{/unless}}
    {{/each}}
], function (Opa5, NavigationJourney{{#each entities}}, {{pascalCase name}}CRUDJourney{{/each}}) {
    "use strict";

    return {
        run: function () {
            // Run navigation tests
            QUnit.module("Navigation Journey");
            NavigationJourney.run();

            {{#each entities}}
            // Run {{name}} CRUD tests
            QUnit.module("{{pascalCase name}} CRUD Journey");
            {{pascalCase name}}CRUDJourney.run();

            {{/each}}
        }
    };
});
