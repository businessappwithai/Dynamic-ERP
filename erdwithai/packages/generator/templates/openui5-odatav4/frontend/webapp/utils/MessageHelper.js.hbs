/**
 * MessageHelper - Professional Message Toast Utility
 *
 * Provides centralized message toast functionality with proper configuration
 * and consistent behavior across the application.
 *
 * Usage:
 *   MessageHelper.showSuccess("Record saved successfully");
 *   MessageHelper.showError("Error saving record");
 *   MessageHelper.showInfo("Loading data...");
 *   MessageHelper.showWarning("Please check your input");
 */
sap.ui.define([
  "sap/m/MessageToast",
  "sap/ui/core/Popup"
], function(MessageToast, Popup) {
  "use strict";

  var MessageHelper = {

    /**
     * Default configuration for all message toasts
     * Using proper sap.ui.core.Popup.Dock enum values
     */
    _getDefaultConfig: function() {
      return {
        duration: 3000,           // 3 seconds
        width: "15em",             // Responsive width
        closeOnBrowserNavigation: true,
        my: Popup.Dock.CenterBottom,
        at: Popup.Dock.CenterBottom
      };
    },

    /**
     * Show success message (green)
     * @param {string} sMessage - Message text to display
     * @param {int} iDuration - Optional duration in milliseconds
     */
    showSuccess: function(sMessage, iDuration) {
      if (!sMessage) {
        return;
      }
      var oConfig = this._getDefaultConfig();
      if (iDuration) {
        oConfig.duration = iDuration;
      }
      MessageToast.show(sMessage, oConfig);
    },

    /**
     * Show error message (red)
     * @param {string} sMessage - Error message to display
     * @param {int} iDuration - Optional duration in milliseconds
     */
    showError: function(sMessage, iDuration) {
      if (!sMessage) {
        return;
      }
      var oConfig = this._getDefaultConfig();
      if (iDuration) {
        oConfig.duration = iDuration;
      }
      // Use longer duration for errors
      oConfig.duration = oConfig.duration * 1.5;
      MessageToast.show(sMessage, oConfig);
    },

    /**
     * Show info message (blue)
     * @param {string} sMessage - Info message to display
     * @param {int} iDuration - Optional duration in milliseconds
     */
    showInfo: function(sMessage, iDuration) {
      if (!sMessage) {
        return;
      }
      var oConfig = this._getDefaultConfig();
      if (iDuration) {
        oConfig.duration = iDuration;
      }
      MessageToast.show(sMessage, oConfig);
    },

    /**
     * Show warning message (yellow)
     * @param {string} sMessage - Warning message to display
     * @param {int} iDuration - Optional duration in milliseconds
     */
    showWarning: function(sMessage, iDuration) {
      if (!sMessage) {
        return;
      }
      var oConfig = this._getDefaultConfig();
      if (iDuration) {
        oConfig.duration = iDuration;
      }
      MessageToast.show(sMessage, oConfig);
    },

    /**
     * Show message with custom options
     * @param {string} sMessage - Message text to display
     * @param {object} oCustomConfig - Custom configuration options
     */
    show: function(sMessage, oCustomConfig) {
      if (!sMessage) {
        return;
      }
      var oConfig = this._getDefaultConfig();
      if (oCustomConfig) {
        // Merge custom config with defaults
        for (var sKey in oCustomConfig) {
          if (oCustomConfig.hasOwnProperty(sKey)) {
            oConfig[sKey] = oCustomConfig[sKey];
          }
        }
      }
      MessageToast.show(sMessage, oConfig);
    }
  };

  return MessageHelper;
});
