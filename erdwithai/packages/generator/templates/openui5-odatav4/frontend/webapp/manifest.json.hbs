{
  "_version": "2.0.0",
  "sap.app": {
    "id": "{{kebabCase project.name}}",
    "type": "application",
    "title": "{{project.name}}",
    "description": "{{project.description}}",
    "applicationVersion": {
      "version": "{{project.version}}"
    },
    "dataSources": {
      "mainService": {
        "uri": "{{config.baseUrl}}/odata/",
        "type": "OData",
        "settings": {
          "odataVersion": "4.0",
          "localUri": "localService/metadata.xml"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "sap-icon://table-view"
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.136.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.f": {},
        "sap.uxap": {},
        "sap.ui.layout": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "{{kebabCase project.name}}.i18n.i18n"
        }
      },
      "fcl": {
        "type": "sap.ui.model.json.JSONModel",
        "settings": {
          "initialLayout": "OneColumn"
        },
        "preload": true
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.f.routing.Router",
        "viewType": "XML",
        "path": "{{kebabCase project.name}}.view",
        "controlId": "layout",
        "controlAggregation": "beginColumnPages",
        "transition": "slide"
      },
      "routes": [
        {
          "pattern": "",
          "name": "main",
          "target": ["entityMenu"]
        }{{#each entities}},
        {
          "pattern": "{{camelCase this.name}}",
          "name": "{{camelCase this.name}}List",
          "target": ["entityMenu", "{{camelCase this.name}}List"]
        },
        {
          "pattern": "{{camelCase this.name}}/{ {{camelCase this.name}}Key}",
          "name": "{{camelCase this.name}}Detail",
          "target": ["entityMenu", "{{camelCase this.name}}List", "{{camelCase this.name}}Detail"]
        }{{/each}},
        {{#each entities}}
        {
          "pattern": "entity/{{this.tableName}}",
          "name": "{{camelCase this.originalName}}ListRoute",
          "target": ["master", "entity.{{pascalCase this.originalName}}List"]
        },
        {
          "pattern": "entity/{{this.tableName}}/{id}",
          "name": "{{camelCase this.originalName}}DetailRoute",
          "target": ["master", "entity.{{pascalCase this.originalName}}List", "entity.{{pascalCase this.originalName}}Detail"]
        },
        {
          "pattern": "entity/{{this.tableName}}/create",
          "name": "{{camelCase this.originalName}}CreateRoute",
          "target": ["master", "entity.{{pascalCase this.originalName}}Create"]
        }{{#unless @last}},{{/unless}}
        {{/each}}
      ],
      "targets": {
        "entityMenu": {
          "name": "EntityMenu",
          "controlAggregation": "beginColumnPages",
          "level": 1
        },
        {{#each entities}}
        "{{camelCase this.name}}List": {
          "name": "{{pascalCase this.name}}List",
          "controlAggregation": "midColumnPages",
          "level": 2
        },
        "{{camelCase this.name}}Detail": {
          "name": "{{pascalCase this.name}}Detail",
          "controlAggregation": "endColumnPages",
          "level": 3
        }{{#unless @last}},{{/unless}}
        {{/each}},
        {{#each entities}}
        "entity.{{pascalCase this.originalName}}List": {
          "viewId": "entity.{{pascalCase this.originalName}}List",
          "viewName": "entity.{{pascalCase this.originalName}}List",
          "controlAggregation": "midColumnPages"
        },
        "entity.{{pascalCase this.originalName}}Detail": {
          "viewId": "entity.{{pascalCase this.originalName}}Detail",
          "viewName": "entity.{{pascalCase this.originalName}}Detail",
          "controlAggregation": "endColumnPages"
        },
        "entity.{{pascalCase this.originalName}}Create": {
          "viewId": "entity.{{pascalCase this.originalName}}Create",
          "viewName": "entity.{{pascalCase this.originalName}}Create",
          "controlAggregation": "endColumnPages"
        }{{#unless @last}},{{/unless}}
        {{/each}}
      }
    },
    "rootView": {
      "viewName": "{{kebabCase project.name}}.view.App",
      "type": "XML",
      "id": "layout"
    }
  }
}
