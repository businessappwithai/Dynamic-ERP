/**
 * {{pascalCase entity.name}} Create Controller
 *
 * Handles creation of new {{entity.displayName}} records.
 * Form fields generated from sys_field metadata.
 *
 * Generated: {{now}}
 */
sap.ui.define([
  "sap/ui/core/mvc/Controller",
  "sap/ui/model/json/JSONModel",
  "sap/m/MessageToast",
  "sap/m/MessageBox"
], function(Controller, JSONModel, MessageToast, MessageBox) {
  "use strict";

  return Controller.extend("{{kebabCase project.name}}.controller.entity.{{pascalCase entity.name}}Create", {

    onInit: function() {
      var oViewModel = new JSONModel({
        busy: false,
        entityName: "{{entity.tableName}}",
        entityDisplayName: "{{entity.displayName}}",
        entitySetName: "{{tableToEntitySet entity.tableName}}",
        formData: {}
      });
      this.getView().setModel(oViewModel, "view");

      this.getOwnerComponent().getRouter()
        .getRoute("{{camelCase entity.name}}Create")
        .attachPatternMatched(this._onRouteMatched, this);
    },

    _onRouteMatched: function() {
      // Reset form data
      this.getView().getModel("view").setProperty("/formData", {
        {{#each entity.attributes}}
        {{#unless (isExcludedField this.name)}}
        {{#unless (eq this.name entity.primaryKey)}}
        {{this.name}}: {{#if (eq this.type "boolean")}}false{{else if (eq this.type "integer")}}0{{else if (eq this.type "decimal")}}0{{else}}""{{/if}},
        {{/unless}}
        {{/unless}}
        {{/each}}
      });
    },

    onSavePress: function() {
      var oView = this.getView();
      var oViewModel = oView.getModel("view");
      var oFormData = oViewModel.getProperty("/formData");
      var sEntitySet = oViewModel.getProperty("/entitySetName");

      // Basic validation
      {{#each entity.attributes}}
      {{#if this.required}}
      {{#unless (eq this.name entity.primaryKey)}}
      {{#unless (isExcludedField this.name)}}
      if (!oFormData.{{this.name}} && oFormData.{{this.name}} !== 0 && oFormData.{{this.name}} !== false) {
        MessageBox.error("{{this.displayName}} is required");
        return;
      }
      {{/unless}}
      {{/unless}}
      {{/if}}
      {{/each}}

      oViewModel.setProperty("/busy", true);

      var oModel = this.getOwnerComponent().getModel();
      var oListBinding = oModel.bindList("/" + sEntitySet);
      var oContext = oListBinding.create(oFormData);

      oContext.created().then(function() {
        oViewModel.setProperty("/busy", false);
        MessageToast.show("{{entity.displayName}} created successfully");
        this.onNavBack();
      }.bind(this)).catch(function(oError) {
        oViewModel.setProperty("/busy", false);
        MessageBox.error("Failed to create: " + (oError.message || "Unknown error"));
      });
    },

    onCancelPress: function() {
      this.onNavBack();
    },

    onNavBack: function() {
      this.getOwnerComponent().getRouter().navTo("{{camelCase entity.name}}List");
    }
  });
});
