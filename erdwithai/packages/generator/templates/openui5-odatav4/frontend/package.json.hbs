{
  "name": "{{kebabCase project.name}}-ui5",
  "version": "{{project.version}}",
  "description": "{{project.description}} - OpenUI5 Frontend",
  "scripts": {
    "start": "ui5 serve --port 8080 --open index.html",
    "dev": "ui5 serve --port 8080",
    "build": "ui5 build --clean-dest --include-task=generateCachebusterInfo",
    "build:self-contained": "ui5 build self-contained --clean-dest",
    "ts-typecheck": "tsc --noEmit",
    "lint": "bun run lint:ui5 && bun run lint:eslint",
    "lint:ui5": "ui5lint",
    "lint:eslint": "eslint webapp --ext .ts,.xml",
    "lint:fix": "eslint webapp --ext .ts,.xml --fix",
    "test": "karma start",
    "test:ci": "karma start karma-ci.conf.js",
    "validate": "bun run ts-typecheck && bun run lint && bun run build"
  },
  "devDependencies": {
    "@ui5/cli": "^3.8.0",
    "@ui5/linter": "^1.0.0",
    "@openui5/types": "^1.136.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "ui5-tooling-transpile": "^3.11.0",
    "eslint": "^8.57.0",
    "karma": "^6.4.0",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.0",
    "karma-ui5": "^3.0.0"
  },
  "ui5": {
    "dependencies": [
      "@openui5/sap.m",
      "@openui5/sap.ui.core",
      "@openui5/sap.f",
      "@openui5/sap.uxap",
      "@openui5/sap.ui.layout",
      "@openui5/themelib_sap_horizon"
    ]
  }
}
