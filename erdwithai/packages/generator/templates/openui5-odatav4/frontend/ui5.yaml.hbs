# UI5 Tooling Configuration
# Generated: {{now}}

specVersion: "3.0"
metadata:
  name: {{kebabCase project.name}}
type: application

framework:
  name: OpenUI5
  version: "1.136.0"
  libraries:
    - name: sap.m
    - name: sap.ui.core
    - name: sap.f
    - name: sap.uxap
    - name: sap.ui.layout
    - name: themelib_sap_horizon

server:
  customMiddleware:
    # TypeScript transpilation middleware
    - name: ui5-tooling-transpile-middleware
      afterMiddleware: compression
    # Proxy to backend OData service
    - name: fiori-tools-proxy
      afterMiddleware: compression
      configuration:
        ignoreCertError: true
        backend:
          - path: /odata
            url: {{config.baseUrl}}
            destination: backend

builder:
  customTasks:
    # TypeScript transpilation task
    - name: ui5-tooling-transpile-task
      afterTask: replaceVersion
    # Cachebuster task
    - name: ui5-task-cachebuster
      afterTask: generateCachebusterInfo
      configuration:
        hashType: md5

resources:
  configuration:
    propertiesFileSourceEncoding: UTF-8
