# UI5 Linter Configuration
# Generated for: {{project.name}}
# Documentation: https://sap.github.io/ui5-linter/

# Specifies which files to lint
files:
  include:
    - "webapp/**/*.js"
    - "webapp/**/*.xml"
    - "webapp/**/*.json"
  exclude:
    - "webapp/test/**"
    - "webapp/localService/**"
    - "node_modules/**"

# UI5 linter rules configuration
rules:
  # Async component flags
  no-deprecated-api: warning
  no-deprecated-library: error
  no-deprecated-component: error
  no-deprecated-theme: error

  # Best practices - set to warning as type bindings in XML views are valid UI5 patterns
  no-globals: warning
  no-pseudo-modules: error

  # Accessibility
  async-component-flags: error
  prefer-test-starter: warning
