{
  "env": {
    "browser": true,
    "es2021": true
  },
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "globals": {
    "sap": "readonly",
    "jQuery": "readonly"
  },
  "plugins": ["ui5"],
  "extends": ["eslint:recommended"],
  "rules": {
    "no-unused-vars": ["error", { "argsIgnorePattern": "^_" }],
    "no-console": "warn",
    "prefer-const": "error",
    "no-var": "error",
    "eqeqeq": ["error", "always"],
    "curly": ["error", "all"],
    "ui5/no-deprecated-api": "warn"
  },
  "overrides": [
    {
      "files": ["*.xml"],
      "rules": {}
    }
  ]
}
