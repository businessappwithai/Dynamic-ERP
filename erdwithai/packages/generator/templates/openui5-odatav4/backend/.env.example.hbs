# {{project.name}} - OData V4 Backend Configuration

# Server Configuration
PORT={{config.port}}
NODE_ENV=development
ODATA_PATH={{config.odataPath}}

# Database Configuration (switch with DB_TYPE)
DB_TYPE=sqlite
# PostgreSQL settings (used when DB_TYPE=postgresql)
DB_HOST=localhost
DB_PORT=5432
DB_NAME={{snakeCase project.name}}
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_SSL=false
# SQLite settings (used when DB_TYPE=sqlite)
# DB_NAME is also used for SQLite filename path (default: ./data/{{snakeCase project.name}}.db)

# CORS Configuration
CORS_ORIGIN=http://localhost:8080
CORS_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS

# Logging
LOG_LEVEL=debug
LOG_FORMAT=dev

# Security
HELMET_ENABLED=true

# OData Settings
ODATA_MAX_TOP=100
ODATA_DEFAULT_TOP=20
