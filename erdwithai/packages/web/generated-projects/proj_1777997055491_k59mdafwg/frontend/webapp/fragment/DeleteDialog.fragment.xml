<core:FragmentDefinition
  xmlns="sap.m"
  xmlns:core="sap.ui.core">
  <Dialog
    title="Confirm Delete"
    type="Message"
    state="Warning">
    <content>
      <Text text="Are you sure you want to delete this record? This action cannot be undone." />
    </content>
    <beginButton>
      <Button
        text="Delete"
        type="Reject"
        press=".onConfirmDelete" />
    </beginButton>
    <endButton>
      <Button
        text="Cancel"
        press=".onCancelDelete" />
    </endButton>
  </Dialog>
</core:FragmentDefinition>
