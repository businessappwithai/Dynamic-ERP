<!--
  Detail View - Object Page (Column 3)

  Displays entity details using ObjectPageLayout.
  Fields are rendered based on sys_field metadata (seq_no order).
  Supports edit mode, save, and delete operations.

  Generated: 2026-05-06T11:42:08.762Z
-->
<mvc:View
  controllerName="q-a-test-project.controller.Detail"
  xmlns="sap.uxap"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns:m="sap.m"
  xmlns:f="sap.ui.layout.form"
  xmlns:core="sap.ui.core">

  <ObjectPageLayout
    id="objectPage"
    height="100%"
    showTitleInHeaderContent="true"
    upperCaseAnchorBar="false"
    showAnchorBarPopover="false"
    busyIndicatorDelay="0">

    <!-- Object Page Header -->
    <headerTitle>
      <ObjectPageDynamicHeaderTitle>
        <expandedHeading>
          <m:Title
            text="{view>/title}"
            wrapping="true" />
        </expandedHeading>
        <snappedHeading>
          <m:Title
            text="{view>/title}"
            wrapping="true" />
        </snappedHeading>

        <actions>
          <!-- Edit/Display toggle -->
          <m:Button
            id="editButton"
            text="{i18n>detail.edit}"
            type="Emphasized"
            press=".onEditPress"
            visible="{= !${view>/editMode} }" />

          <!-- Save button (edit mode) -->
          <m:Button
            id="saveButton"
            text="{i18n>detail.save}"
            type="Emphasized"
            press=".onSavePress"
            visible="{view>/editMode}" />

          <!-- Cancel button (edit mode) -->
          <m:Button
            id="cancelButton"
            text="{i18n>detail.cancel}"
            press=".onCancelPress"
            visible="{view>/editMode}" />

          <!-- Delete button -->
          <m:Button
            id="deleteButton"
            text="{i18n>detail.delete}"
            type="Reject"
            press=".onDeletePress"
            visible="{= !${view>/editMode} }" />

          <!-- Close column button -->
          <m:Button
            id="closeButton"
            icon="sap-icon://decline"
            press=".onClosePress"
            type="Transparent" />
        </actions>
      </ObjectPageDynamicHeaderTitle>
    </headerTitle>

    <!-- Header Content -->
    <headerContent>
      <m:FlexBox direction="Column">
        <m:ObjectStatus
          text="{view>/status}"
          state="{view>/statusState}" />
        <m:ObjectAttribute
          title="{i18n>detail.created}"
          text="{
            path: 'created_at',
            formatter: '.formatDateTime'
          }" />
        <m:ObjectAttribute
          title="{i18n>detail.updated}"
          text="{
            path: 'updated_at',
            formatter: '.formatDateTime'
          }" />
      </m:FlexBox>
    </headerContent>

    <!-- Sections -->
    <sections>
      <!-- General Section - Fields from sys_field_group 'General' -->
      <ObjectPageSection
        id="generalSection"
        title="{i18n>detail.section.general}">
        <subSections>
          <ObjectPageSubSection>
            <blocks>
              <f:SimpleForm
                id="generalForm"
                editable="{view>/editMode}"
                layout="ResponsiveGridLayout"
                labelSpanXL="4"
                labelSpanL="4"
                labelSpanM="12"
                labelSpanS="12"
                emptySpanXL="0"
                emptySpanL="0"
                emptySpanM="0"
                emptySpanS="0"
                columnsXL="2"
                columnsL="2"
                columnsM="1"
                singleContainerFullSize="false">

                <!-- Fields are dynamically added here from sys_field metadata -->
                <f:content>
                  <!-- Content generated by controller based on seq_no order -->
                </f:content>

              </f:SimpleForm>
            </blocks>
          </ObjectPageSubSection>
        </subSections>
      </ObjectPageSection>

      <!-- Details Section - Fields from sys_field_group 'Details' -->
      <ObjectPageSection
        id="detailsSection"
        title="{i18n>detail.section.details}">
        <subSections>
          <ObjectPageSubSection>
            <blocks>
              <f:SimpleForm
                id="detailsForm"
                editable="{view>/editMode}"
                layout="ResponsiveGridLayout"
                labelSpanXL="4"
                labelSpanL="4"
                labelSpanM="12"
                labelSpanS="12"
                columnsXL="2"
                columnsL="2"
                columnsM="1">

                <f:content>
                  <!-- Content generated by controller -->
                </f:content>

              </f:SimpleForm>
            </blocks>
          </ObjectPageSubSection>
        </subSections>
      </ObjectPageSection>

      <!-- System Section - Audit fields -->
      <ObjectPageSection
        id="systemSection"
        title="{i18n>detail.section.system}"
        visible="{view>/showSystemFields}">
        <subSections>
          <ObjectPageSubSection>
            <blocks>
              <f:SimpleForm
                editable="false"
                layout="ResponsiveGridLayout"
                columnsL="2"
                columnsM="1">

                <f:content>
                  <m:Label text="{i18n>detail.id}" />
                  <m:Text text="{view>/id}" />

                  <m:Label text="{i18n>detail.version}" />
                  <m:Text text="{version}" />

                  <m:Label text="{i18n>detail.createdAt}" />
                  <m:Text text="{
                    path: 'created_at',
                    formatter: '.formatDateTime'
                  }" />

                  <m:Label text="{i18n>detail.updatedAt}" />
                  <m:Text text="{
                    path: 'updated_at',
                    formatter: '.formatDateTime'
                  }" />
                </f:content>

              </f:SimpleForm>
            </blocks>
          </ObjectPageSubSection>
        </subSections>
      </ObjectPageSection>

    </sections>

  </ObjectPageLayout>

</mvc:View>
