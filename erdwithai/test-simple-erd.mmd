erDiagram
    CUSTOMER ||--o{ ORDER : places
    ORDER ||--|{ ORDER_LINE : contains
    ORDER ||--|{ PRODUCT : references
    PRODUCT ||--o{ ORDER_LINE : "is ordered in"

    CUSTOMER {
        number id PK
        string name
        string email
        string phone
        string address
    }

    ORDER {
        number id PK
        number customer_id FK
        date order_date
        string status
        number total_amount
    }

    ORDER_LINE {
        number id PK
        number order_id FK
        number product_id FK
        number quantity
        number unit_price
    }

    PRODUCT {
        number id PK
        string name
        string description
        number price
        number stock_quantity
    }
