%% CRM (Customer Relationship Management) Domain Model
%%
%% This ERD demonstrates a CRM application with:
%% - Contact and company management
%% - Deal/opportunity pipeline
%% - Activity tracking
%% - Task management
%%
%% Use: erdwithai generate -i examples/crm.erd.mmd -o ./generated -n crm-app -s option2

erDiagram

    %% Organizations
    Company {
        string id PK
        string name
        string industry OPTIONAL
        string website OPTIONAL
        string phone OPTIONAL
        string email OPTIONAL
        integer employee_count OPTIONAL
        decimal annual_revenue OPTIONAL
        string status
        string owner_id FK
    }

    Contact {
        string id PK
        string company_id FK OPTIONAL
        string first_name
        string last_name
        string email UK
        string phone OPTIONAL
        string mobile OPTIONAL
        string job_title OPTIONAL
        string department OPTIONAL
        string status
        string lead_source OPTIONAL
        string owner_id FK
    }

    %% Sales Pipeline
    Deal {
        string id PK
        string company_id FK OPTIONAL
        string contact_id FK OPTIONAL
        string name
        decimal amount OPTIONAL
        string currency
        string stage
        integer probability OPTIONAL
        date expected_close_date OPTIONAL
        date actual_close_date OPTIONAL
        string status
        text description OPTIONAL
        string owner_id FK
    }

    DealStage {
        string id PK
        string pipeline_id FK
        string name
        integer sort_order
        integer default_probability
        boolean is_won
        boolean is_lost
    }

    Pipeline {
        string id PK
        string name
        boolean is_default
        boolean is_active
    }

    %% Activities
    Activity {
        string id PK
        string contact_id FK OPTIONAL
        string company_id FK OPTIONAL
        string deal_id FK OPTIONAL
        string activity_type
        string subject
        text description OPTIONAL
        datetime scheduled_at OPTIONAL
        datetime completed_at OPTIONAL
        integer duration_minutes OPTIONAL
        string status
        string owner_id FK
    }

    Note {
        string id PK
        string contact_id FK OPTIONAL
        string company_id FK OPTIONAL
        string deal_id FK OPTIONAL
        text content
        boolean is_pinned
        string author_id FK
    }

    %% Tasks
    Task {
        string id PK
        string contact_id FK OPTIONAL
        string company_id FK OPTIONAL
        string deal_id FK OPTIONAL
        string title
        text description OPTIONAL
        string priority
        string status
        date due_date OPTIONAL
        datetime completed_at OPTIONAL
        string assigned_to FK
        string created_by FK
    }

    %% Email Tracking
    EmailMessage {
        string id PK
        string contact_id FK OPTIONAL
        string deal_id FK OPTIONAL
        string thread_id OPTIONAL
        string subject
        text body_text OPTIONAL
        text body_html OPTIONAL
        string direction
        datetime sent_at OPTIONAL
        datetime received_at OPTIONAL
        datetime opened_at OPTIONAL
        integer open_count
    }

    EmailTemplate {
        string id PK
        string name
        string subject
        text body_html
        text body_text OPTIONAL
        string category OPTIONAL
        boolean is_active
    }

    %% Products and Quotes
    Product {
        string id PK
        string name
        string sku UK
        text description OPTIONAL
        decimal unit_price
        string currency
        boolean is_active
    }

    Quote {
        string id PK
        string deal_id FK
        string quote_number UK
        string status
        date valid_until OPTIONAL
        decimal subtotal
        decimal discount_amount
        decimal tax_amount
        decimal total_amount
        text terms OPTIONAL
        text notes OPTIONAL
    }

    QuoteItem {
        string id PK
        string quote_id FK
        string product_id FK
        string description OPTIONAL
        integer quantity
        decimal unit_price
        decimal discount_percent
        decimal total_price
    }

    %% Users (Sales Team)
    User {
        string id PK
        string email UK
        string first_name
        string last_name
        string role
        string team_id FK OPTIONAL
        boolean is_active
        datetime last_login OPTIONAL
    }

    Team {
        string id PK
        string name
        string manager_id FK OPTIONAL
    }

    %% Relationships
    Company ||--o{ Contact : "employs"
    Company ||--o{ Deal : "has"
    Company ||--o{ Activity : "logged_for"
    Company ||--o{ Note : "has"
    Company ||--o{ Task : "has"

    Contact ||--o{ Deal : "associated_with"
    Contact ||--o{ Activity : "logged_for"
    Contact ||--o{ Note : "has"
    Contact ||--o{ Task : "has"
    Contact ||--o{ EmailMessage : "receives"

    Deal ||--o{ Activity : "logged_for"
    Deal ||--o{ Note : "has"
    Deal ||--o{ Task : "has"
    Deal ||--o{ Quote : "has"
    Deal ||--o{ EmailMessage : "related_to"
    Deal }o--|| DealStage : "in_stage"

    Pipeline ||--o{ DealStage : "has"

    Quote ||--o{ QuoteItem : "contains"
    Product ||--o{ QuoteItem : "quoted_in"

    User ||--o{ Company : "owns"
    User ||--o{ Contact : "owns"
    User ||--o{ Deal : "owns"
    User ||--o{ Activity : "owns"
    User ||--o{ Task : "assigned"
    User ||--o{ Note : "authors"

    Team ||--o{ User : "contains"
    Team ||--|| User : "managed_by"
