%% Simple Blog Domain Model
%%
%% A minimal example for testing the generator
%%
%% Use: erdwithai generate -i examples/simple.erd.mmd -o ./generated -n blog-app

erDiagram

    User {
        string id PK
        string email UK
        string name
        string role
        boolean is_active
    }

    Post {
        string id PK
        string author_id FK
        string title
        string slug UK
        text content
        string status
        datetime published_at OPTIONAL
    }

    Comment {
        string id PK
        string post_id FK
        string author_id FK
        text content
        boolean is_approved
    }

    Tag {
        string id PK
        string name UK
        string slug UK
    }

    PostTag {
        string id PK
        string post_id FK
        string tag_id FK
    }

    User ||--o{ Post : "writes"
    User ||--o{ Comment : "writes"
    Post ||--o{ Comment : "has"
    Post ||--o{ PostTag : "tagged_with"
    Tag ||--o{ PostTag : "applied_to"
