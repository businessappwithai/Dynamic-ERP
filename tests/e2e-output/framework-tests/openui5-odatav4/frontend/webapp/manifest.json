{
  "_version": "2.0.0",
  "sap.app": {
    "id": "openui5-odatav4-test-app",
    "type": "application",
    "title": "openui5-odatav4-test-app",
    "description": "Generated application",
    "applicationVersion": {
      "version": "1.0.0"
    },
    "dataSources": {
      "mainService": {
        "uri": "http://localhost:3020/odata/",
        "type": "OData",
        "settings": {
          "odataVersion": "4.0",
          "localUri": "localService/metadata.xml"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "sap-icon://table-view"
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.136.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.f": {},
        "sap.uxap": {},
        "sap.ui.layout": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "openui5-odatav4-test-app.i18n.i18n"
        }
      },
      "fcl": {
        "type": "sap.ui.model.json.JSONModel",
        "settings": {
          "initialLayout": "OneColumn"
        },
        "preload": true
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.f.routing.Router",
        "viewType": "XML",
        "path": "openui5-odatav4-test-app.view",
        "controlId": "layout",
        "controlAggregation": "beginColumnPages",
        "transition": "slide",
        "async": true
      },
      "routes": [
        {
          "pattern": "",
          "name": "main",
          "target": ["entityMenu"]
        },
        {
          "pattern": "cUSTOMER",
          "name": "cUSTOMERList",
          "target": ["entityMenu", "cUSTOMERList"]
        },
        {
          "pattern": "cUSTOMER/{ cUSTOMERKey}",
          "name": "cUSTOMERDetail",
          "target": ["entityMenu", "cUSTOMERList", "cUSTOMERDetail"]
        },
        {
          "pattern": "oRDER",
          "name": "oRDERList",
          "target": ["entityMenu", "oRDERList"]
        },
        {
          "pattern": "oRDER/{ oRDERKey}",
          "name": "oRDERDetail",
          "target": ["entityMenu", "oRDERList", "oRDERDetail"]
        },
        {
          "pattern": "oRDERITEM",
          "name": "oRDERITEMList",
          "target": ["entityMenu", "oRDERITEMList"]
        },
        {
          "pattern": "oRDERITEM/{ oRDERITEMKey}",
          "name": "oRDERITEMDetail",
          "target": ["entityMenu", "oRDERITEMList", "oRDERITEMDetail"]
        },
        {
          "pattern": "pRODUCT",
          "name": "pRODUCTList",
          "target": ["entityMenu", "pRODUCTList"]
        },
        {
          "pattern": "pRODUCT/{ pRODUCTKey}",
          "name": "pRODUCTDetail",
          "target": ["entityMenu", "pRODUCTList", "pRODUCTDetail"]
        }
      ],
      "targets": {
        "entityMenu": {
          "name": "EntityMenu",
          "controlAggregation": "beginColumnPages",
          "level": 1
        },
        "cUSTOMERList": {
          "name": "CUSTOMERList",
          "controlAggregation": "midColumnPages",
          "level": 2
        },
        "cUSTOMERDetail": {
          "name": "CUSTOMERDetail",
          "controlAggregation": "endColumnPages",
          "level": 3
        },
        "oRDERList": {
          "name": "ORDERList",
          "controlAggregation": "midColumnPages",
          "level": 2
        },
        "oRDERDetail": {
          "name": "ORDERDetail",
          "controlAggregation": "endColumnPages",
          "level": 3
        },
        "oRDERITEMList": {
          "name": "ORDERITEMList",
          "controlAggregation": "midColumnPages",
          "level": 2
        },
        "oRDERITEMDetail": {
          "name": "ORDERITEMDetail",
          "controlAggregation": "endColumnPages",
          "level": 3
        },
        "pRODUCTList": {
          "name": "PRODUCTList",
          "controlAggregation": "midColumnPages",
          "level": 2
        },
        "pRODUCTDetail": {
          "name": "PRODUCTDetail",
          "controlAggregation": "endColumnPages",
          "level": 3
        }
      }
    },
    "rootView": {
      "viewName": "openui5-odatav4-test-app.view.App",
      "type": "XML",
      "id": "layout"
    }
  }
}
