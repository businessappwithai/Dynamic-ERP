<!--
  Admin View - Field Layout Management

  Allows runtime modification of field ordering via sys_field.seq_no.
  Drag-and-drop reordering of fields for form and grid layouts.

  Generated: 2026-02-09T13:00:26.994Z
-->
<mvc:View
  controllerName="openui5-odatav4-test-app.controller.Admin"
  xmlns="sap.m"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns:dnd="sap.ui.core.dnd"
  xmlns:core="sap.ui.core">

  <Page
    id="adminPage"
    title="{i18n>admin.title}"
    showNavButton="true"
    navButtonPress=".onNavBack"
    busy="{view>/busy}">

    <customHeader>
      <Bar>
        <contentLeft>
          <Button
            icon="sap-icon://nav-back"
            press=".onNavBack"
            type="Transparent" />
          <Title text="{i18n>admin.title}" />
        </contentLeft>
        <contentRight>
          <Button
            id="saveButton"
            text="{i18n>admin.save}"
            type="Emphasized"
            press=".onSavePress"
            enabled="{view>/hasChanges}" />
        </contentRight>
      </Bar>
    </customHeader>

    <subHeader>
      <Toolbar>
        <Label text="{i18n>admin.selectEntity}" />
        <Select
          id="entitySelect"
          items="{/entities}"
          selectedKey="{view>/selectedEntity}"
          change=".onEntityChange"
          width="250px">
          <core:Item
            key="{name}"
            text="{name}" />
        </Select>

        <ToolbarSpacer />

        <SegmentedButton
          id="modeSelector"
          selectedKey="{view>/layoutMode}"
          selectionChange=".onModeChange">
          <items>
            <SegmentedButtonItem
              key="form"
              text="{i18n>admin.formLayout}"
              icon="sap-icon://form" />
            <SegmentedButtonItem
              key="grid"
              text="{i18n>admin.gridLayout}"
              icon="sap-icon://table-view" />
          </items>
        </SegmentedButton>
      </Toolbar>
    </subHeader>

    <content>
      <VBox class="sapUiSmallMargin">
        <!-- Instructions -->
        <MessageStrip
          text="{i18n>admin.instructions}"
          type="Information"
          showIcon="true"
          class="sapUiSmallMarginBottom" />

        <!-- Field List with Drag & Drop -->
        <Panel
          headerText="{= ${view>/layoutMode} === 'form' ? ${i18n>admin.formFields} : ${i18n>admin.gridColumns} }">

          <List
            id="fieldList"
            items="{view>/fields}"
            mode="None"
            class="sapUiSmallMargin">

            <!-- Enable drag and drop -->
            <dragDropConfig>
              <dnd:DragDropInfo
                sourceAggregation="items"
                targetAggregation="items"
                dropPosition="Between"
                drop=".onFieldDrop" />
            </dragDropConfig>

            <CustomListItem
              type="Active">
              <HBox
                alignItems="Center"
                justifyContent="SpaceBetween"
                class="sapUiSmallMargin">

                <!-- Drag handle -->
                <VBox width="40px" alignItems="Center">
                  <core:Icon
                    src="sap-icon://menu2"
                    size="1rem"
                    class="sapUiSmallMarginEnd" />
                </VBox>

                <!-- Field info -->
                <VBox class="sapUiSmallMarginBeginEnd" width="100%">
                  <Label
                    text="{display_name}"
                    design="Bold" />
                  <Text
                    text="{column_name} ({data_type})"
                    class="sapUiTinyMarginTop" />
                </VBox>

                <!-- Sequence number -->
                <VBox width="80px" alignItems="Center">
                  <ObjectNumber
                    number="{= ${view>/layoutMode} === 'form' ? ${seq_no} : ${seq_no_grid} }"
                    unit="seq" />
                </VBox>

                <!-- Visibility toggle -->
                <VBox width="100px" alignItems="Center">
                  <CheckBox
                    selected="{= ${view>/layoutMode} === 'form' ? ${is_displayed} : ${is_displayed_grid} }"
                    text="{i18n>admin.visible}"
                    select=".onVisibilityChange" />
                </VBox>

              </HBox>
            </CustomListItem>

          </List>

        </Panel>

        <!-- Preview Section -->
        <Panel
          headerText="{i18n>admin.preview}"
          expandable="true"
          expanded="false">
          <content>
            <Text text="{i18n>admin.previewDescription}" />
          </content>
        </Panel>

      </VBox>
    </content>

    <footer>
      <Bar>
        <contentMiddle>
          <Text
            text="{= ${view>/fields}.length + ' ' + ${i18n>admin.fieldsConfigured} }"
            visible="{= ${view>/fields}.length > 0 }" />
        </contentMiddle>
      </Bar>
    </footer>

  </Page>

</mvc:View>
