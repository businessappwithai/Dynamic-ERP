<!--
  Not Found View

  Displayed when navigation fails or page doesn't exist.

  Generated: 2026-02-09T13:00:26.994Z
-->
<mvc:View
  controllerName="openui5-odatav4-test-app.controller.NotFound"
  xmlns="sap.m"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns:core="sap.ui.core">

  <Page
    id="notFoundPage"
    title="{i18n>notFound.title}"
    showNavButton="true"
    navButtonPress=".onNavBack">
    <content>
      <IllustratedMessage
        illustrationType="sapIllus-PageNotFound"
        title="{i18n>notFound.title}"
        description="{i18n>notFound.description}">
        <additionalContent>
          <Button
            text="{i18n>notFound.link}"
            type="Emphasized"
            press=".onLinkPress" />
        </additionalContent>
      </IllustratedMessage>
    </content>
  </Page>

</mvc:View>
