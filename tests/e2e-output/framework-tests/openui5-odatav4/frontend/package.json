{
  "name": "openui5-odatav4-test-app-ui5",
  "version": "1.0.0",
  "description": "Generated application - OpenUI5 Frontend",
  "scripts": {
    "start": "ui5 serve --port 8080 --open index.html",
    "dev": "ui5 serve --port 8080",
    "build": "ui5 build --clean-dest --include-task=generateCachebusterInfo",
    "build:self-contained": "ui5 build self-contained --clean-dest",
    "lint": "bun run lint:ui5 && bun run lint:eslint",
    "lint:ui5": "ui5lint",
    "lint:eslint": "eslint webapp --ext .js,.xml",
    "lint:fix": "eslint webapp --ext .js,.xml --fix",
    "test": "karma start",
    "test:ci": "karma start karma-ci.conf.js",
    "validate": "bun run lint && bun run build"
  },
  "devDependencies": {
    "@ui5/cli": "^3.8.0",
    "@ui5/linter": "^1.0.0",
    "eslint": "^8.57.0",
    "karma": "^6.4.0",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.0",
    "karma-ui5": "^3.0.0"
  },
  "ui5": {
    "dependencies": [
      "@openui5/sap.m",
      "@openui5/sap.ui.core",
      "@openui5/sap.f",
      "@openui5/sap.uxap",
      "@openui5/sap.ui.layout",
      "@openui5/themelib_sap_horizon"
    ]
  }
}
