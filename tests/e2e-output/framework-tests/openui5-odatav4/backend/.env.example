# openui5-odatav4-test-app - OData V4 Backend Configuration

# Server Configuration
PORT=3020
NODE_ENV=development
ODATA_PATH=/odata

# Database Configuration
DB_TYPE=sqlite
DB_FILE=./data/openui5-odatav4-test-app.db

# CORS Configuration
CORS_ORIGIN=http://localhost:8080
CORS_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS

# Logging
LOG_LEVEL=debug
LOG_FORMAT=dev

# Security
HELMET_ENABLED=true

# OData Settings
ODATA_MAX_TOP=100
ODATA_DEFAULT_TOP=20
