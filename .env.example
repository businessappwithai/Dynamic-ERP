# Application Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/erdwithai
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# AI Configuration (Required for AI features)
ANTHROPIC_API_KEY=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

# Mastra.ai Configuration
MASTRA_DATABASE_URL=file:./erdwithai-mastra.db
MASTRA_PORT=4111
MASTRA_LOG_LEVEL=info

# Web Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_MASTRA_URL=http://localhost:4111

# CopilotKit Configuration
COPILOTKIT_API_KEY=

# CORS Configuration
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# Security
SESSION_SECRET=change
JWT_SECRET=change

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Feature Flags
ENABLE_AI_FEATURES=true
ENABLE_DICTIONARY_FEATURES=true
ENABLE_CODE_GENERATION=true
ENABLE_ANALYTICS=false

# Code Generation
DEFAULT_OUTPUT_DIR=./generated
TEMPLATE_DIR=./packages/generator/templates

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=.mermaid,.md,.txt,.json

# ERD Design Auto-Retry Configuration
# Number of automatic retries when ERD validation fails
ERD_DESIGN_AUTO_RETRY_COUNT=3
# Delay between retries in milliseconds
ERD_DESIGN_RETRY_DELAY_MS=2000
