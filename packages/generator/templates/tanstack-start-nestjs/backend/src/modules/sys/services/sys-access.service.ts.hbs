import { Injectable, NotFoundException } from '@nestjs/common';
import { v4 as uuidv4 } from 'uuid';
import { DatabaseService } from '../../database/database.service';

@Injectable()
export class SysAccessService {
  constructor(private readonly db: DatabaseService) {}

  async findAll(options: { page?: number; limit?: number; roleId?: string; tableId?: string } = {}) {
    const { page = 1, limit = 100, roleId, tableId } = options;
    const offset = (page - 1) * limit;

    const [data, countResult] = await Promise.all([
      this.db.kysely
        .selectFrom('sys_access')
        .selectAll()
        .where('is_active', '=', true)
        .$if(!!roleId, (qb) => qb.where('sys_role_id', '=', roleId!))
        .$if(!!tableId, (qb) => qb.where('sys_table_id', '=', tableId!))
        .orderBy('sys_role_id', 'asc')
        .limit(limit)
        .offset(offset)
        .execute(),
      this.db.kysely
        .selectFrom('sys_access')
        .select((eb) => eb.fn.countAll().as('count'))
        .where('is_active', '=', true)
        .$if(!!roleId, (qb) => qb.where('sys_role_id', '=', roleId!))
        .$if(!!tableId, (qb) => qb.where('sys_table_id', '=', tableId!))
        .executeTakeFirst(),
    ]);

    return {
      data,
      meta: {
        total: Number(countResult?.count || 0),
        page,
        pageSize: limit,
        totalPages: Math.ceil(Number(countResult?.count || 0) / limit),
      },
    };
  }

  async findById(id: string) {
    const access = await this.db.kysely
      .selectFrom('sys_access')
      .selectAll()
      .where('sys_access_id', '=', id)
      .executeTakeFirst();
    if (!access) {
      throw new NotFoundException(`SysAccess with ID ${id} not found`);
    }
    return access;
  }

  async create(data: any) {
    const now = new Date();
    const id = uuidv4();

    const newRecord = {
      sys_access_id: id,
      ...data,
      access_type_table: data.access_type_table || 'R',
      is_read_only: data.is_read_only === true,
      is_exclude: data.is_exclude === true,
      entity_type: data.entity_type || 'D',
      is_active: data.is_active !== false,
      created_at: now,
      updated_at: now,
      created_by: '',
      updated_by: '',
    };

    await this.db.kysely.insertInto('sys_access').values(newRecord).execute();
    return this.findById(id);
  }

  async update(id: string, data: any) {
    const updated = { ...data, updated_at: new Date(), updated_by: '' };
    await this.db.kysely
      .updateTable('sys_access')
      .set(updated)
      .where('sys_access_id', '=', id)
      .execute();
    return this.findById(id);
  }

  async delete(id: string) {
    await this.findById(id);
    await this.db.kysely
      .updateTable('sys_access')
      .set({ is_active: false, deleted_at: new Date() })
      .where('sys_access_id', '=', id)
      .execute();
    return { deleted: true };
  }
}
