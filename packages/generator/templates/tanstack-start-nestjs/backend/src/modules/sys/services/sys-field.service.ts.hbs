/**
 * SysField Service
 *
 * Manages sys_field entities - controls field placement, visibility, and ordering in forms.
 * THIS IS THE CRITICAL SERVICE for runtime UI configuration.
 * Changes to seq_no, is_displayed, etc. immediately affect the UI without code changes.
 *
 * Generated: {{now}}
 */

import { Injectable, NotFoundException, ConflictException } from '@nestjs/common';
import { v4 as uuidv4 } from 'uuid';
import { DatabaseService } from '../../database/database.service';

@Injectable()
export class SysFieldService {
  constructor(private readonly db: DatabaseService) {}

  /**
   * Find all sys_field records with pagination and filtering
   */
  async findAll(options: {
    page?: number;
    limit?: number;
    tabId?: string;
    tableId?: string;
    view?: 'form' | 'grid';
    isActive?: boolean;
  } = {}) {
    const { page = 1, limit = 100, tabId, tableId, view, isActive = true } = options;
    const offset = (page - 1) * limit;

    const [data, countResult] = await Promise.all([
      this.db.kysely
        .selectFrom('sys_field')
        .leftJoin('sys_column', 'sys_column.sys_column_id', 'sys_field.sys_column_id')
        .leftJoin('sys_reference', 'sys_reference.sys_reference_id', 'sys_column.sys_reference_id')
        .selectAll('sys_field')
        .select([
          'sys_column.column_name',
          'sys_column.name as column_display_name',
          'sys_column.data_type',
          'sys_reference.name as reference_name',
          'sys_reference.validation_type',
        ])
        .where('sys_field.is_active', '=', isActive)
        .$if(!!tabId, (qb) => qb.where('sys_field.sys_tab_id', '=', tabId!))
        .$if(!!tableId, (qb) => qb.where('sys_column.sys_table_id', '=', tableId!))
        .$if(view === 'form', (qb) => qb.where('sys_field.is_displayed', '=', true))
        .$if(view === 'grid', (qb) => qb.where('sys_field.is_displayed_grid', '=', true))
        .orderBy(view === 'grid' ? 'sys_field.seq_no_grid' : 'sys_field.seq_no', 'asc')
        .limit(limit)
        .offset(offset)
        .execute(),
      this.db.kysely
        .selectFrom('sys_field')
        .leftJoin('sys_column', 'sys_column.sys_column_id', 'sys_field.sys_column_id')
        .select((eb) => eb.fn.countAll().as('count'))
        .where('sys_field.is_active', '=', isActive)
        .$if(!!tabId, (qb) => qb.where('sys_field.sys_tab_id', '=', tabId!))
        .$if(!!tableId, (qb) => qb.where('sys_column.sys_table_id', '=', tableId!))
        .$if(view === 'form', (qb) => qb.where('sys_field.is_displayed', '=', true))
        .$if(view === 'grid', (qb) => qb.where('sys_field.is_displayed_grid', '=', true))
        .executeTakeFirst(),
    ]);

    return {
      data,
      meta: {
        total: Number(countResult?.count || 0),
        page,
        pageSize: limit,
        totalPages: Math.ceil(Number(countResult?.count || 0) / limit),
      },
    };
  }

  /**
   * Find sys_field by ID
   */
  async findById(id: string) {
    const field = await this.db.kysely
      .selectFrom('sys_field')
      .leftJoin('sys_column', 'sys_column.sys_column_id', 'sys_field.sys_column_id')
      .selectAll('sys_field')
      .select(['sys_column.column_name', 'sys_column.name as column_display_name'])
      .where('sys_field.sys_field_id', '=', id)
      .executeTakeFirst();

    if (!field) {
      throw new NotFoundException(`SysField with ID ${id} not found`);
    }
    return field;
  }

  /**
   * Create new sys_field
   */
  async create(data: {
    sys_tab_id: string;
    sys_column_id: string;
    name?: string;
    description?: string;
    is_displayed?: boolean;
    is_displayed_grid?: boolean;
    is_read_only?: boolean;
    is_mandatory?: boolean;
    seq_no?: number;
    seq_no_grid?: number;
    display_length?: number;
    field_group?: string;
  }) {
    const now = new Date();
    const id = uuidv4();

    const newRecord = {
      sys_field_id: id,
      ...data,
      is_displayed: data.is_displayed !== false,
      is_displayed_grid: data.is_displayed_grid !== false,
      is_read_only: data.is_read_only === true,
      is_mandatory: data.is_mandatory === true,
      seq_no: data.seq_no || 0,
      seq_no_grid: data.seq_no_grid || data.seq_no || 0,
      is_active: true,
      created_at: now,
      updated_at: now,
      created_by: '',
      updated_by: '',
    };

    await this.db.kysely.insertInto('sys_field').values(newRecord).execute();
    return this.findById(id);
  }

  /**
   * Update sys_field
   * This is the key method for runtime UI modification!
   */
  async update(id: string, data: {
    name?: string;
    description?: string;
    is_displayed?: boolean;
    is_displayed_grid?: boolean;
    is_read_only?: boolean;
    is_mandatory?: boolean;
    seq_no?: number;
    seq_no_grid?: number;
    display_length?: number;
    field_group?: string;
  }, version?: number) {
    const field = await this.findById(id);

    // Optimistic locking check
    if (version !== undefined && field.version !== version) {
      throw new ConflictException('Field was modified by another user');
    }

    const updated = {
      ...data,
      version: (field.version || 0) + 1,
      updated_at: new Date(),
      updated_by: '',
    };

    await this.db.kysely
      .updateTable('sys_field')
      .set(updated)
      .where('sys_field_id', '=', id)
      .execute();
    return this.findById(id);
  }

  /**
   * Batch reorder fields
   * Called by the admin interface drag-drop field editor
   */
  async batchReorder(fields: Array<{ id: string; seq_no: number; seq_no_grid?: number }>) {
    await this.db.kysely.transaction().execute(async (trx) => {
      for (const { id, seq_no, seq_no_grid } of fields) {
        const updateData: Record<string, any> = { seq_no, updated_at: new Date(), updated_by: '' };
        if (seq_no_grid !== undefined) {
          updateData.seq_no_grid = seq_no_grid;
        }
        await trx.updateTable('sys_field').set(updateData).where('sys_field_id', '=', id).execute();
      }
    });

    return { success: true, updated: fields.length };
  }

  /**
   * Delete (soft delete) sys_field
   */
  async delete(id: string) {
    await this.findById(id);
    await this.db.kysely
      .updateTable('sys_field')
      .set({ is_active: false, deleted_at: new Date() })
      .where('sys_field_id', '=', id)
      .execute();
    return { deleted: true };
  }
}
