/**
 * SysTable Controller
 *
 * Manages sys_table entities - defines all tables in the Application Dictionary.
 * Part of the Compiere Application Dictionary pattern.
 *
 * Generated: {{now}}
 */

import { Injectable } from '@nestjs/common';
import { v4 as uuidv4 } from 'uuid';
import { DatabaseService } from '../../database/database.service';

@Injectable()
export class SysTableService {
  constructor(private readonly db: DatabaseService) {}

  /**
   * Find all sys_table records with pagination
   */
  async findAll(options: { page?: number; limit?: number; search?: string; isActive?: boolean } = {}) {
    const { page = 1, limit = 100, search, isActive = true } = options;
    const offset = (page - 1) * limit;

    const [data, countResult] = await Promise.all([
      this.db.kysely
        .selectFrom('sys_table')
        .selectAll()
        .where('is_active', '=', isActive)
        .$if(!!search, (qb) =>
          qb.where((eb) =>
            eb.or([
              eb('name', 'like', `%${search}%`),
              eb('table_name', 'like', `%${search}%`),
              eb('description', 'like', `%${search}%`),
            ]),
          ),
        )
        .orderBy('name', 'asc')
        .limit(limit)
        .offset(offset)
        .execute(),
      this.db.kysely
        .selectFrom('sys_table')
        .select((eb) => eb.fn.countAll().as('count'))
        .where('is_active', '=', isActive)
        .$if(!!search, (qb) =>
          qb.where((eb) =>
            eb.or([
              eb('name', 'like', `%${search}%`),
              eb('table_name', 'like', `%${search}%`),
              eb('description', 'like', `%${search}%`),
            ]),
          ),
        )
        .executeTakeFirst(),
    ]);

    return {
      data,
      meta: {
        total: Number(countResult?.count || 0),
        page,
        pageSize: limit,
        totalPages: Math.ceil(Number(countResult?.count || 0) / limit),
      },
    };
  }

  /**
   * Find sys_table by ID
   */
  async findById(id: string) {
    const table = await this.db.kysely
      .selectFrom('sys_table')
      .selectAll()
      .where('sys_table_id', '=', id)
      .executeTakeFirst();
    if (!table) {
      throw new Error(`SysTable with ID ${id} not found`);
    }
    return table;
  }

  /**
   * Find sys_table by table_name
   */
  async findByTableName(tableName: string) {
    const table = await this.db.kysely
      .selectFrom('sys_table')
      .selectAll()
      .where('table_name', '=', tableName)
      .executeTakeFirst();
    if (!table) {
      throw new Error(`Table ${tableName} not found in sys_table`);
    }
    return table;
  }

  /**
   * Create new sys_table
   */
  async create(data: {
    name: string;
    table_name: string;
    description?: string;
    table_type: 'system' | 'business';
    is_view?: boolean;
    access_level?: string;
    windowId?: string;
  }) {
    const now = new Date();
    const id = uuidv4();

    const newRecord = {
      sys_table_id: id,
      ...data,
      is_active: true,
      is_view: data.is_view || false,
      created_at: now,
      updated_at: now,
      created_by: '',
      updated_by: '',
    };

    await this.db.kysely.insertInto('sys_table').values(newRecord).execute();
    return this.findById(id);
  }

  /**
   * Update sys_table
   */
  async update(id: string, data: {
    name?: string;
    description?: string;
    is_active?: boolean;
    access_level?: string;
  }) {
    await this.findById(id);

    const updated = {
      ...data,
      updated_at: new Date(),
    };

    await this.db.kysely
      .updateTable('sys_table')
      .set(updated)
      .where('sys_table_id', '=', id)
      .execute();
    return this.findById(id);
  }

  /**
   * Delete (soft delete) sys_table
   */
  async delete(id: string) {
    await this.findById(id);
    await this.db.kysely
      .updateTable('sys_table')
      .set({ is_active: false, deleted_at: new Date() })
      .where('sys_table_id', '=', id)
      .execute();
    return { deleted: true };
  }

  /**
   * Get columns for a table
   */
  async getColumns(tableId: string) {
    return this.db.kysely
      .selectFrom('sys_column')
      .selectAll()
      .where('sys_table_id', '=', tableId)
      .where('is_active', '=', true)
      .orderBy('seq_no', 'asc')
      .execute();
  }
}
