/**
 * Tabs Management Page - Compiere Application Dictionary
 *
 * Manage sys_tab records: create, edit, configure tabs within windows.
 * Tabs are the sections within a window that display entity data.
 *
 * Swiss Clean Design - Editorial layout with minimalist aesthetic
 */

import { useState } from 'react';
import { createFileRoute, Link, useSearch } from '@tanstack/react-router';
import { useQuery, useMutation, useQueryClient } from '@tanstack/react-query';
import {
  Layers,
  ArrowLeft,
  RefreshCw,
  Plus,
  Pencil,
  X,
  Check,
  AppWindow,
  Table2,
} from 'lucide-react';
import { apiClient, PaginatedResponse } from '@/lib/api-client';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Badge } from '@/components/ui/badge';
import { toast } from 'sonner';

export const Route = createFileRoute('/admin/tabs')({
  validateSearch: (search: Record<string, unknown>): { windowId?: string } => ({
    windowId: (search.windowId as string) || undefined,
  }),
  component: TabsManagementPage,
});

interface SysTab {
  sys_tab_id: string;
  sys_window_id: string;
  sys_table_id: string;
  name: string;
  description?: string;
  seq_no: number;
  tab_level: number;
  is_read_only?: boolean;
  is_advanced_tab?: boolean;
  is_active?: boolean;
  table_name?: string;
  window_name?: string;
}

interface SysWindow {
  sys_window_id: string;
  name: string;
}

interface SysTable {
  sys_table_id: string;
  name: string;
  table_name: string;
}

interface TabFormState {
  name: string;
  description: string;
  sys_window_id: string;
  sys_table_id: string;
  seq_no: number;
  tab_level: number;
  is_read_only: boolean;
  is_advanced_tab: boolean;
  is_active: boolean;
}

function TabForm({
  initial,
  windows,
  tables,
  onSave,
  onCancel,
  saving,
  defaultWindowId,
}: {
  initial?: Partial<TabFormState>;
  windows: SysWindow[];
  tables: SysTable[];
  onSave: (data: TabFormState) => void;
  onCancel: () => void;
  saving: boolean;
  defaultWindowId?: string;
}) {
  const [form, setForm] = useState<TabFormState>({
    name: initial?.name ?? '',
    description: initial?.description ?? '',
    sys_window_id: initial?.sys_window_id ?? defaultWindowId ?? windows[0]?.sys_window_id ?? '',
    sys_table_id: initial?.sys_table_id ?? tables[0]?.sys_table_id ?? '',
    seq_no: initial?.seq_no ?? 10,
    tab_level: initial?.tab_level ?? 0,
    is_read_only: initial?.is_read_only ?? false,
    is_advanced_tab: initial?.is_advanced_tab ?? false,
    is_active: initial?.is_active ?? true,
  });

  return (
    <div className="border-2 border-border p-6 bg-card space-y-4">
      <div className="grid grid-cols-2 gap-4">
        <div>
          <label className="block text-xs font-bold uppercase tracking-wider mb-1">Name *</label>
          <Input
            value={form.name}
            onChange={(e) => setForm((f) => ({ ...f, name: e.target.value }))}
            placeholder="e.g. Customer Details"
            className="rounded-none border-2"
          />
        </div>
        <div>
          <label className="block text-xs font-bold uppercase tracking-wider mb-1">Sequence No</label>
          <Input
            type="number"
            value={form.seq_no}
            onChange={(e) => setForm((f) => ({ ...f, seq_no: parseInt(e.target.value) || 0 }))}
            className="rounded-none border-2"
          />
        </div>
      </div>
      <div className="grid grid-cols-2 gap-4">
        <div>
          <label className="block text-xs font-bold uppercase tracking-wider mb-1">Window *</label>
          <select
            value={form.sys_window_id}
            onChange={(e) => setForm((f) => ({ ...f, sys_window_id: e.target.value }))}
            className="w-full h-10 border-2 border-border bg-background px-3 text-sm"
          >
            <option value="">— Select Window —</option>
            {windows.map((w) => (
              <option key={w.sys_window_id} value={w.sys_window_id}>{w.name}</option>
            ))}
          </select>
        </div>
        <div>
          <label className="block text-xs font-bold uppercase tracking-wider mb-1">Table *</label>
          <select
            value={form.sys_table_id}
            onChange={(e) => setForm((f) => ({ ...f, sys_table_id: e.target.value }))}
            className="w-full h-10 border-2 border-border bg-background px-3 text-sm"
          >
            <option value="">— Select Table —</option>
            {tables.map((t) => (
              <option key={t.sys_table_id} value={t.sys_table_id}>{t.name} ({t.table_name})</option>
            ))}
          </select>
        </div>
      </div>
      <div className="grid grid-cols-2 gap-4">
        <div>
          <label className="block text-xs font-bold uppercase tracking-wider mb-1">Tab Level (0=Header, 1+=Lines)</label>
          <Input
            type="number"
            min="0"
            value={form.tab_level}
            onChange={(e) => setForm((f) => ({ ...f, tab_level: parseInt(e.target.value) || 0 }))}
            className="rounded-none border-2"
          />
        </div>
        <div>
          <label className="block text-xs font-bold uppercase tracking-wider mb-1">Description</label>
          <Input
            value={form.description}
            onChange={(e) => setForm((f) => ({ ...f, description: e.target.value }))}
            placeholder="Optional description"
            className="rounded-none border-2"
          />
        </div>
      </div>
      <div className="flex gap-6">
        <label className="flex items-center gap-2 text-sm">
          <input type="checkbox" checked={form.is_read_only}
            onChange={(e) => setForm((f) => ({ ...f, is_read_only: e.target.checked }))} className="h-4 w-4" />
          Read Only
        </label>
        <label className="flex items-center gap-2 text-sm">
          <input type="checkbox" checked={form.is_advanced_tab}
            onChange={(e) => setForm((f) => ({ ...f, is_advanced_tab: e.target.checked }))} className="h-4 w-4" />
          Advanced Tab
        </label>
        <label className="flex items-center gap-2 text-sm">
          <input type="checkbox" checked={form.is_active}
            onChange={(e) => setForm((f) => ({ ...f, is_active: e.target.checked }))} className="h-4 w-4" />
          Active
        </label>
      </div>
      <div className="flex gap-3 pt-2">
        <Button
          size="sm"
          className="rounded-none bg-black text-white hover:bg-gray-800"
          onClick={() => onSave(form)}
          disabled={saving || !form.name.trim() || !form.sys_window_id || !form.sys_table_id}
        >
          <Check className="h-4 w-4 mr-1" />
          {saving ? 'Saving...' : 'Save'}
        </Button>
        <Button size="sm" variant="outline" className="rounded-none border-2" onClick={onCancel}>
          <X className="h-4 w-4 mr-1" />
          Cancel
        </Button>
      </div>
    </div>
  );
}

function TabsManagementPage() {
  const { windowId: filterWindowId } = useSearch({ from: '/admin/tabs' });
  const queryClient = useQueryClient();
  const [creatingNew, setCreatingNew] = useState(false);
  const [editingId, setEditingId] = useState<string | null>(null);

  const { data: tabsResponse, isLoading: tabsLoading, refetch } = useQuery({
    queryKey: ['admin', 'tabs-mgmt', filterWindowId],
    queryFn: () => apiClient.get<PaginatedResponse<SysTab>>('/api/sys/tabs', {
      limit: 200,
      ...(filterWindowId ? { windowId: filterWindowId } : {}),
    }),
  });

  const { data: windowsResponse } = useQuery({
    queryKey: ['admin', 'windows-list'],
    queryFn: () => apiClient.get<PaginatedResponse<SysWindow>>('/api/sys/windows', { limit: 200 }),
  });

  const { data: tablesResponse } = useQuery({
    queryKey: ['admin', 'tables-list'],
    queryFn: () => apiClient.get<PaginatedResponse<SysTable>>('/api/sys/tables', { limit: 200 }),
  });

  const createMutation = useMutation({
    mutationFn: (data: TabFormState) => apiClient.post<SysTab>('/api/sys/tabs', data),
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: ['admin', 'tabs-mgmt'] });
      queryClient.invalidateQueries({ queryKey: ['admin', 'tabs-all'] });
      setCreatingNew(false);
      toast.success('Tab created');
    },
    onError: () => toast.error('Failed to create tab'),
  });

  const updateMutation = useMutation({
    mutationFn: ({ id, data }: { id: string; data: TabFormState }) =>
      apiClient.patch<SysTab>(`/api/sys/tabs/${id}`, data),
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: ['admin', 'tabs-mgmt'] });
      queryClient.invalidateQueries({ queryKey: ['admin', 'tabs-all'] });
      setEditingId(null);
      toast.success('Tab updated');
    },
    onError: () => toast.error('Failed to update tab'),
  });

  const tabs = tabsResponse?.data ?? [];
  const windows = windowsResponse?.data ?? [];
  const tables = tablesResponse?.data ?? [];

  const windowById: Record<string, SysWindow> = {};
  windows.forEach((w) => { windowById[w.sys_window_id] = w; });

  const tableById: Record<string, SysTable> = {};
  tables.forEach((t) => { tableById[t.sys_table_id] = t; });

  const filterWindow = filterWindowId ? windowById[filterWindowId] : null;

  return (
    <div className="min-h-screen bg-background">
      <header className="border-b-4 border-border bg-background">
        <div className="max-w-7xl mx-auto px-8 py-12">
          <div className="flex items-start justify-between">
            <div className="flex-1">
              <div className="flex items-center gap-3 mb-4">
                <Layers className="h-8 w-8 text-indigo-600" />
                <h1 className="text-6xl font-bold tracking-tight text-foreground font-display">
                  Tabs
                  {filterWindow && (
                    <span className="text-3xl text-muted-foreground font-light ml-4">— {filterWindow.name}</span>
                  )}
                </h1>
              </div>
              <p className="text-xl text-muted-foreground font-light max-w-2xl leading-relaxed">
                Manage tabs within application windows — each tab corresponds to an entity data view
              </p>
            </div>
            <div className="flex gap-3">
              <Button
                variant="outline"
                size="default"
                onClick={() => refetch()}
                disabled={tabsLoading}
                className="border-2 border-border hover:bg-black hover:text-white transition-colors rounded-none"
              >
                <RefreshCw className={`h-4 w-4 mr-2 ${tabsLoading ? 'animate-spin' : ''}`} />
                Refresh
              </Button>
              <Button
                size="default"
                className="rounded-none bg-black text-white hover:bg-gray-800"
                onClick={() => { setCreatingNew(true); setEditingId(null); }}
              >
                <Plus className="h-4 w-4 mr-2" />
                New Tab
              </Button>
            </div>
          </div>
        </div>
      </header>

      <main className="max-w-7xl mx-auto px-8 py-12">
        <div className="mb-8 flex items-center gap-4">
          <Link to="/admin" className="inline-flex items-center text-sm hover:underline">
            <ArrowLeft className="h-4 w-4 mr-2" />
            Back to Admin Dashboard
          </Link>
          {filterWindowId && (
            <>
              <span className="text-muted-foreground">·</span>
              <Link to="/admin/windows" className="inline-flex items-center text-sm hover:underline">
                <AppWindow className="h-4 w-4 mr-1" />
                All Windows
              </Link>
              <span className="text-muted-foreground">·</span>
              <Link to="/admin/tabs" className="text-sm text-muted-foreground hover:underline">
                Show all tabs
              </Link>
            </>
          )}
        </div>

        {/* Stats */}
        <div className="mb-8 text-sm">
          <span><strong>{tabsResponse?.meta?.total ?? 0}</strong> tab{(tabsResponse?.meta?.total ?? 0) !== 1 ? 's' : ''}{filterWindow ? ` in "${filterWindow.name}"` : ''}</span>
        </div>

        {/* New Tab Form */}
        {creatingNew && (
          <div className="mb-6">
            <h3 className="text-sm font-bold uppercase tracking-wider mb-3">New Tab</h3>
            <TabForm
              windows={windows}
              tables={tables}
              defaultWindowId={filterWindowId}
              onSave={(data) => createMutation.mutate(data)}
              onCancel={() => setCreatingNew(false)}
              saving={createMutation.isPending}
            />
          </div>
        )}

        {/* Tabs List */}
        {tabsLoading ? (
          <div className="text-center py-16 text-muted-foreground border-2 border-border">Loading...</div>
        ) : tabs.length === 0 ? (
          <div className="text-center py-16 text-muted-foreground border-2 border-border">No tabs found.</div>
        ) : (
          <div className="border-2 border-border">
            <div className="grid grid-cols-[3rem_1fr_1fr_6rem_6rem_5rem_10rem] gap-0 border-b-2 border-border bg-muted/30">
              <div className="px-3 py-3 text-xs font-bold uppercase tracking-wider text-muted-foreground">Seq</div>
              <div className="px-3 py-3 text-xs font-bold uppercase tracking-wider text-muted-foreground">Tab Name</div>
              <div className="px-3 py-3 text-xs font-bold uppercase tracking-wider text-muted-foreground">Table</div>
              <div className="px-3 py-3 text-xs font-bold uppercase tracking-wider text-muted-foreground text-center">Level</div>
              <div className="px-3 py-3 text-xs font-bold uppercase tracking-wider text-muted-foreground text-center">Status</div>
              <div className="px-3 py-3 text-xs font-bold uppercase tracking-wider text-muted-foreground text-center">Flags</div>
              <div className="px-3 py-3 text-xs font-bold uppercase tracking-wider text-muted-foreground text-right">Actions</div>
            </div>
            {tabs.sort((a, b) => a.seq_no - b.seq_no).map((tab, idx) => {
              const table = tableById[tab.sys_table_id];
              const window_ = windowById[tab.sys_window_id];
              const isEditing = editingId === tab.sys_tab_id;

              if (isEditing) {
                return (
                  <div key={tab.sys_tab_id} className={`px-4 py-4 ${idx > 0 ? 'border-t-2 border-border' : ''}`}>
                    <TabForm
                      initial={tab as Partial<TabFormState>}
                      windows={windows}
                      tables={tables}
                      onSave={(data) => updateMutation.mutate({ id: tab.sys_tab_id, data })}
                      onCancel={() => setEditingId(null)}
                      saving={updateMutation.isPending}
                    />
                  </div>
                );
              }

              return (
                <div
                  key={tab.sys_tab_id}
                  className={`grid grid-cols-[3rem_1fr_1fr_6rem_6rem_5rem_10rem] gap-0 items-center hover:bg-muted/20 transition-colors ${idx > 0 ? 'border-t border-border' : ''}`}
                >
                  <div className="px-3 py-3 text-sm text-muted-foreground font-mono">{tab.seq_no}</div>
                  <div className="px-3 py-3">
                    <div className="font-semibold text-sm">{tab.name}</div>
                    {!filterWindowId && window_ && (
                      <div className="text-xs text-muted-foreground mt-0.5 flex items-center gap-1">
                        <AppWindow className="h-3 w-3" />
                        {window_.name}
                      </div>
                    )}
                    {tab.description && (
                      <div className="text-xs text-muted-foreground mt-0.5">{tab.description}</div>
                    )}
                  </div>
                  <div className="px-3 py-3">
                    {table ? (
                      <div>
                        <div className="text-sm font-medium">{table.name}</div>
                        <code className="text-xs text-muted-foreground">{table.table_name}</code>
                      </div>
                    ) : (
                      <span className="text-xs text-muted-foreground">{tab.sys_table_id.slice(0, 8)}…</span>
                    )}
                  </div>
                  <div className="px-3 py-3 text-center">
                    <Badge variant="outline" className="text-xs">L{tab.tab_level}</Badge>
                  </div>
                  <div className="px-3 py-3 text-center">
                    <Badge variant={tab.is_active !== false ? 'default' : 'secondary'} className="text-xs">
                      {tab.is_active !== false ? 'Active' : 'Inactive'}
                    </Badge>
                  </div>
                  <div className="px-3 py-3 text-center">
                    <div className="flex gap-1 justify-center">
                      {tab.is_read_only && <span title="Read Only" className="text-xs px-1 py-0.5 bg-yellow-100 text-yellow-700 border border-yellow-200">RO</span>}
                      {tab.is_advanced_tab && <span title="Advanced" className="text-xs px-1 py-0.5 bg-blue-100 text-blue-700 border border-blue-200">ADV</span>}
                    </div>
                  </div>
                  <div className="px-3 py-3 text-right">
                    <Button
                      size="sm"
                      variant="ghost"
                      className="rounded-none hover:bg-black hover:text-white text-xs"
                      onClick={() => { setEditingId(tab.sys_tab_id); setCreatingNew(false); }}
                    >
                      <Pencil className="h-3 w-3 mr-1" />
                      Edit
                    </Button>
                  </div>
                </div>
              );
            })}
          </div>
        )}
      </main>
    </div>
  );
}
