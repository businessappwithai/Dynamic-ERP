  AppWindow, Plus, RefreshCw, ChevronRight, Layers,
  LayoutList, Check, X, Pencil, ArrowLeft,
} from 'lucide-react';
import { apiClient } from '@/lib/api-client';
import { type FieldMetadata } from '@/hooks/use-entities';
import { DynamicForm } from '@/components/forms/dynamic-form';
import { Button } from '@/components/ui/button';
import { Badge } from '@/components/ui/badge';
import { Tabs, TabsContent, TabsList, TabsTrigger } from '@/components/ui/tabs';
import { toast } from 'sonner';
import { cn } from '@/lib/utils';

export const Route = createFileRoute('/admin/dictionary')({
  component: ApplicationDictionaryPage,
});

// ============================================================================
// Types
// ============================================================================

interface SysWindow {
  sys_window_id: string;
  name: string;
  description?: string;
  is_active?: boolean;
  help?: string;
  entity_type?: string;
  created_at?: string;
  updated_at?: string;
}

interface SysTab {
  sys_tab_id: string;
  sys_window_id: string;
  name: string;
  description?: string;
  table_name?: string;
  tab_level?: number;
  seq_no?: number;
  is_active?: boolean;
  where_clause?: string;
  order_by_clause?: string;
  created_at?: string;
  updated_at?: string;
}

interface SysField {
  sys_field_id: string;
  sys_tab_id: string;
  name: string;
  column_name?: string;
  seq_no?: number;
  seq_no_grid?: number;
  is_displayed?: boolean;
  is_displayed_grid?: boolean;
  is_mandatory?: boolean;
  is_read_only?: boolean;
  col_span?: number;
  sys_reference_id?: number;
  field_length?: number;
  default_value?: string;
  is_active?: boolean;
}

