// ============================================================================
// Field grid for sys_field (simplified inline table)
// ============================================================================

interface FieldsGridProps {
  tabId: string;
  onFieldSelect?: (field: SysField) => void;
  selectedFieldId?: string;
}

function FieldsGrid({ tabId, onFieldSelect, selectedFieldId }: FieldsGridProps) {
  const queryClient = useQueryClient();

  const { data: fieldsResp, isLoading } = useQuery({
    queryKey: ['sys_fields', tabId],
    queryFn: () => apiClient.get<{ data: SysField[]; total: number }>(`/sys/fields?tabId=${tabId}&limit=200`),
    enabled: !!tabId,
  });

  const updateFieldMutation = useMutation({
    mutationFn: ({ id, data }: { id: string; data: Record<string, unknown> }) =>
      apiClient.patch(`/sys/fields/${id}`, data),
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: ['sys_fields', tabId] });
      toast.success('Field updated');
    },
    onError: () => toast.error('Failed to update field'),
  });

  const fields = fieldsResp?.data ?? [];

  if (isLoading) {
    return <div className="text-sm text-muted-foreground p-4">Loading fields...</div>;
  }

  if (fields.length === 0) {
    return (
      <div className="rounded-md bg-muted p-6 text-center text-sm text-muted-foreground">
        No fields defined for this tab.
      </div>
    );
  }

  return (
    <div className="space-y-2">
      <div className="text-xs text-muted-foreground mb-2">{fields.length} field(s)</div>
      <div className="rounded-md border overflow-hidden">
        <table className="w-full text-sm">
          <thead className="bg-muted/50">
            <tr>
              <th className="text-left px-3 py-2 font-medium text-muted-foreground w-8">Seq</th>
              <th className="text-left px-3 py-2 font-medium text-muted-foreground">Name</th>
              <th className="text-left px-3 py-2 font-medium text-muted-foreground hidden md:table-cell">Column</th>
              <th className="text-left px-3 py-2 font-medium text-muted-foreground hidden lg:table-cell">Ref</th>
              <th className="text-center px-3 py-2 font-medium text-muted-foreground">Disp</th>
              <th className="text-center px-3 py-2 font-medium text-muted-foreground hidden md:table-cell">Grid</th>
              <th className="text-center px-3 py-2 font-medium text-muted-foreground hidden md:table-cell">Mand</th>
            </tr>
          </thead>
          <tbody>
            {fields
              .sort((a, b) => (a.seq_no ?? 0) - (b.seq_no ?? 0))
              .map((field) => (
                <tr
                  key={field.sys_field_id}
                  onClick={() => onFieldSelect?.(field)}
                  className={cn(
                    'border-t cursor-pointer transition-colors',
                    selectedFieldId === field.sys_field_id
                      ? 'bg-primary/10 hover:bg-primary/15'
                      : 'hover:bg-muted/50'
                  )}
                >
                  <td className="px-3 py-2 text-muted-foreground tabular-nums">{field.seq_no}</td>
                  <td className="px-3 py-2 font-medium">{field.name}</td>
                  <td className="px-3 py-2 text-muted-foreground font-mono text-xs hidden md:table-cell">
                    {field.column_name}
                  </td>
                  <td className="px-3 py-2 text-muted-foreground hidden lg:table-cell">
                    {field.sys_reference_id}
                  </td>
                  <td className="px-3 py-2 text-center">
                    {field.is_displayed
                      ? <Check className="h-3.5 w-3.5 text-green-600 mx-auto" />
                      : <X className="h-3.5 w-3.5 text-muted-foreground/50 mx-auto" />}
                  </td>
                  <td className="px-3 py-2 text-center hidden md:table-cell">
                    {field.is_displayed_grid
                      ? <Check className="h-3.5 w-3.5 text-green-600 mx-auto" />
                      : <X className="h-3.5 w-3.5 text-muted-foreground/50 mx-auto" />}
                  </td>
                  <td className="px-3 py-2 text-center hidden md:table-cell">
                    {field.is_mandatory
                      ? <Check className="h-3.5 w-3.5 text-amber-600 mx-auto" />
                      : <X className="h-3.5 w-3.5 text-muted-foreground/50 mx-auto" />}
                  </td>
                </tr>
              ))}
          </tbody>
        </table>
      </div>
    </div>
  );
}

// ============================================================================
// Tab Editor (sub-level: tab form + fields grid)
// ============================================================================

interface TabEditorProps {
  tab: SysTab;
  onClose: () => void;
  onSave: (data: Record<string, unknown>) => Promise<void>;
  isSaving?: boolean;
}

function TabEditor({ tab, onClose, onSave, isSaving }: TabEditorProps) {
  const [selectedField, setSelectedField] = useState<SysField | null>(null);
  const queryClient = useQueryClient();

  const updateFieldMutation = useMutation({
    mutationFn: ({ id, data }: { id: string; data: Record<string, unknown> }) =>
      apiClient.patch(`/sys/fields/${id}`, data),
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: ['sys_fields', tab.sys_tab_id] });
      toast.success('Field updated');
      setSelectedField(null);
    },
    onError: () => toast.error('Failed to update field'),
  });

  return (
    <div className="space-y-4">
      <div className="flex items-center justify-between">
        <div className="flex items-center gap-2 text-sm">
          <button onClick={onClose} className="text-muted-foreground hover:text-foreground flex items-center gap-1">
            <ArrowLeft className="h-3.5 w-3.5" /> Tabs
          </button>
          <ChevronRight className="h-3.5 w-3.5 text-muted-foreground" />
          <span className="font-medium">{tab.name}</span>
          {tab.tab_level === 0 ? (
            <Badge variant="default" className="text-xs">Parent</Badge>
          ) : (
            <Badge variant="secondary" className="text-xs">Child (L{tab.tab_level})</Badge>
          )}
        </div>
      </div>

      <Tabs defaultValue="tab-details">
        <TabsList className="h-8">
          <TabsTrigger value="tab-details" className="text-xs h-7">
            <Layers className="h-3.5 w-3.5 mr-1" />
            Tab Details
          </TabsTrigger>
          <TabsTrigger value="fields" className="text-xs h-7">
            <LayoutList className="h-3.5 w-3.5 mr-1" />
            Fields
          </TabsTrigger>
        </TabsList>

        <TabsContent value="tab-details" className="mt-4">
          <DynamicForm
            fields={SYS_TAB_FIELDS}
            initialData={tab as unknown as Record<string, unknown>}
            onSubmit={onSave}
            isSaving={isSaving}
            mode="edit"
            readOnlyFields={['sys_window_id', 'sys_tab_id']}
          />
        </TabsContent>

        <TabsContent value="fields" className="mt-4">
          <div className="space-y-4">
            <FieldsGrid
              tabId={tab.sys_tab_id}
              onFieldSelect={setSelectedField}
              selectedFieldId={selectedField?.sys_field_id}
            />

            {selectedField && (
              <div className="rounded-md border bg-card p-4 space-y-4">
                <div className="flex items-center justify-between">
                  <div className="flex items-center gap-2">
                    <LayoutList className="h-4 w-4 text-muted-foreground" />
                    <span className="font-medium text-sm">
                      Edit Field: <span className="font-mono">{selectedField.column_name}</span>
                    </span>
                  </div>
                  <button
                    onClick={() => setSelectedField(null)}
                    className="text-muted-foreground hover:text-foreground"
                  >
                    <X className="h-4 w-4" />
                  </button>
                </div>
                <DynamicForm
                  fields={SYS_FIELD_FIELDS}
                  initialData={selectedField as unknown as Record<string, unknown>}
                  onSubmit={async (data) => { await updateFieldMutation.mutateAsync({ id: selectedField.sys_field_id, data }); }}
                  isSaving={updateFieldMutation.isPending}
                  mode="edit"
                  readOnlyFields={['sys_tab_id', 'sys_field_id', 'column_name']}
                />
              </div>
            )}
          </div>
        </TabsContent>
      </Tabs>
    </div>
  );
}

// ============================================================================
// Tabs Panel (child tab of a Window)
// ============================================================================

interface TabsPanelProps {
  windowId: string;
}

function TabsPanel({ windowId }: TabsPanelProps) {
  const [selectedTab, setSelectedTab] = useState<SysTab | null>(null);
  const [creatingTab, setCreatingTab] = useState(false);
  const queryClient = useQueryClient();

  const { data: tabsResp, isLoading } = useQuery({
    queryKey: ['sys_tabs', windowId],
    queryFn: () =>
      apiClient.get<{ data: SysTab[]; total: number }>(
        `/sys/tabs?windowId=${windowId}&limit=200`
      ),
    enabled: !!windowId,
  });

  const createTabMutation = useMutation({
    mutationFn: (data: Record<string, unknown>) =>
      apiClient.post('/sys/tabs', { ...data, sys_window_id: windowId }),
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: ['sys_tabs', windowId] });
      toast.success('Tab created');
      setCreatingTab(false);
    },
    onError: () => toast.error('Failed to create tab'),
  });

  const updateTabMutation = useMutation({
    mutationFn: ({ id, data }: { id: string; data: Record<string, unknown> }) =>
      apiClient.patch(`/sys/tabs/${id}`, data),
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: ['sys_tabs', windowId] });
      toast.success('Tab saved');
    },
    onError: () => toast.error('Failed to save tab'),
  });

  const tabs = tabsResp?.data ?? [];

  if (selectedTab) {
    return (
      <TabEditor
        tab={selectedTab}
        onClose={() => setSelectedTab(null)}
        onSave={async (data) => { await updateTabMutation.mutateAsync({ id: selectedTab.sys_tab_id, data }); }}
        isSaving={updateTabMutation.isPending}
      />
    );
  }

  return (
    <div className="space-y-4">
      <div className="flex items-center justify-between">
        <span className="text-sm text-muted-foreground">{tabs.length} tab(s)</span>
        <Button
          size="sm"
          variant="outline"
          className="h-7 text-xs gap-1"
          onClick={() => setCreatingTab(true)}
        >
          <Plus className="h-3.5 w-3.5" /> New Tab
        </Button>
      </div>

      {/* Create form */}
      {creatingTab && (
        <div className="rounded-md border bg-card p-4 space-y-4">
          <div className="flex items-center justify-between">
            <span className="font-medium text-sm">New Tab</span>
            <button
              onClick={() => setCreatingTab(false)}
              className="text-muted-foreground hover:text-foreground"
            >
              <X className="h-4 w-4" />
            </button>
          </div>
          <DynamicForm
            fields={SYS_TAB_FIELDS}
            initialData={{ is_active: true, tab_level: 0, seq_no: 10 }}
            onSubmit={async (data) => { await createTabMutation.mutateAsync(data); }}
            isSaving={createTabMutation.isPending}
            mode="create"
          />
        </div>
      )}

      {/* Tabs list */}
      {isLoading ? (
        <div className="text-sm text-muted-foreground p-4">Loading tabs...</div>
      ) : tabs.length === 0 ? (
        <div className="rounded-md bg-muted p-6 text-center text-sm text-muted-foreground">
          No tabs defined for this window. Click "New Tab" to add one.
        </div>
      ) : (
        <div className="rounded-md border overflow-hidden">
          <table className="w-full text-sm">
            <thead className="bg-muted/50">
              <tr>
                <th className="text-left px-3 py-2 font-medium text-muted-foreground w-12">Seq</th>
                <th className="text-left px-3 py-2 font-medium text-muted-foreground">Tab Name</th>
                <th className="text-left px-3 py-2 font-medium text-muted-foreground hidden md:table-cell">Table</th>
                <th className="text-center px-3 py-2 font-medium text-muted-foreground w-16">Level</th>
                <th className="text-center px-3 py-2 font-medium text-muted-foreground w-16">Active</th>
                <th className="text-right px-3 py-2 font-medium text-muted-foreground w-20">Action</th>
              </tr>
            </thead>
            <tbody>
              {tabs
                .sort((a, b) => (a.seq_no ?? 0) - (b.seq_no ?? 0))
                .map((tab) => (
                  <tr
                    key={tab.sys_tab_id}
                    className="border-t hover:bg-muted/50 cursor-pointer"
                    onClick={() => setSelectedTab(tab)}
                  >
                    <td className="px-3 py-2 text-muted-foreground tabular-nums">{tab.seq_no}</td>
                    <td className="px-3 py-2 font-medium">
                      <div className="flex items-center gap-2">
                        {tab.name}
                        {tab.tab_level === 0 ? (
                          <Badge variant="default" className="text-xs py-0">Parent</Badge>
                        ) : (
                          <Badge variant="secondary" className="text-xs py-0">Child L{tab.tab_level}</Badge>
                        )}
                      </div>
                    </td>
                    <td className="px-3 py-2 text-muted-foreground font-mono text-xs hidden md:table-cell">
                      {tab.table_name}
                    </td>
                    <td className="px-3 py-2 text-center text-muted-foreground">{tab.tab_level}</td>
                    <td className="px-3 py-2 text-center">
                      {tab.is_active
                        ? <Check className="h-3.5 w-3.5 text-green-600 mx-auto" />
                        : <X className="h-3.5 w-3.5 text-muted-foreground/50 mx-auto" />}
                    </td>
                    <td className="px-3 py-2 text-right">
                      <button
                        onClick={(e) => { e.stopPropagation(); setSelectedTab(tab); }}
                        className="text-xs text-primary hover:underline flex items-center gap-1 ml-auto"
                      >
                        <Pencil className="h-3 w-3" /> Edit
                      </button>
                    </td>
                  </tr>
                ))}
            </tbody>
          </table>
        </div>
      )}
    </div>
  );
}

// ============================================================================
// Window Editor (right panel when a window is selected)
// ============================================================================

interface WindowEditorProps {
  window: SysWindow;
  tabCount: number;
  onSave: (data: Record<string, unknown>) => Promise<void>;
  isSaving?: boolean;
}

function WindowEditor({ window, tabCount, onSave, isSaving }: WindowEditorProps) {
  return (
    <Tabs defaultValue="window-details" className="flex-1 flex flex-col min-h-0">
      <TabsList className="w-full justify-start rounded-none border-b h-10 px-4 shrink-0 bg-muted/30">
        <TabsTrigger value="window-details" className="gap-1.5 text-sm data-[state=active]:bg-background">
          <AppWindow className="h-4 w-4" />
          Window
        </TabsTrigger>
        <TabsTrigger value="tabs" className="gap-1.5 text-sm data-[state=active]:bg-background">
          <Layers className="h-4 w-4" />
          Tab
          {tabCount > 0 && (
            <Badge variant="secondary" className="ml-1 text-xs h-4 px-1.5">{tabCount}</Badge>
          )}
        </TabsTrigger>
      </TabsList>

      <TabsContent value="window-details" className="flex-1 overflow-auto p-4 mt-0">
        <DynamicForm
          fields={SYS_WINDOW_FIELDS}
          initialData={window as unknown as Record<string, unknown>}
          onSubmit={onSave}
          isSaving={isSaving}
          mode="edit"
          readOnlyFields={['sys_window_id']}
        />
      </TabsContent>

      <TabsContent value="tabs" className="flex-1 overflow-auto p-4 mt-0">
        <TabsPanel windowId={window.sys_window_id} />
      </TabsContent>
    </Tabs>
  );
}

// ============================================================================
// Main Page
// ============================================================================

function ApplicationDictionaryPage() {
  const [selectedWindowId, setSelectedWindowId] = useState<string | null>(null);
  const [creatingWindow, setCreatingWindow] = useState(false);
  const queryClient = useQueryClient();

  const { data: windowsResp, isLoading: windowsLoading, refetch } = useQuery({
    queryKey: ['sys_windows'],
    queryFn: () =>
      apiClient.get<{ data: SysWindow[]; total: number }>('/sys/windows?limit=200'),
  });

  const { data: tabCountsResp } = useQuery({
    queryKey: ['sys_tab_counts', selectedWindowId],
    queryFn: () =>
      apiClient.get<{ data: { total: number }[] }>(
        `/sys/tabs?windowId=${selectedWindowId}&limit=1`
      ),
    enabled: !!selectedWindowId,
    select: (data: any) => data?.total ?? 0,
  });

  const createWindowMutation = useMutation({
    mutationFn: (data: Record<string, unknown>) =>
      apiClient.post<SysWindow>('/sys/windows', data),
    onSuccess: (newWindow: any) => {
      queryClient.invalidateQueries({ queryKey: ['sys_windows'] });
      toast.success('Window created');
      setCreatingWindow(false);
      setSelectedWindowId(newWindow?.sys_window_id ?? null);
    },
    onError: () => toast.error('Failed to create window'),
  });

  const updateWindowMutation = useMutation({
    mutationFn: ({ id, data }: { id: string; data: Record<string, unknown> }) =>
      apiClient.patch(`/sys/windows/${id}`, data),
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: ['sys_windows'] });
      toast.success('Window saved');
    },
    onError: () => toast.error('Failed to save window'),
  });

  const windows = windowsResp?.data ?? [];
  const selectedWindow = windows.find((w) => w.sys_window_id === selectedWindowId) ?? null;
  const tabCount = (tabCountsResp as any) ?? 0;

  return (
    <div className="flex h-full overflow-hidden">
      {/* ── Left panel: Window list ─────────────────────────────── */}
      <div className="w-64 shrink-0 border-r flex flex-col bg-muted/20">
        <div className="flex items-center justify-between px-4 py-3 border-b">
          <div className="flex items-center gap-2">
            <AppWindow className="h-4 w-4 text-muted-foreground" />
            <span className="text-sm font-semibold">Windows</span>
            {windows.length > 0 && (
              <Badge variant="outline" className="text-xs h-4 px-1.5">{windows.length}</Badge>
            )}
          </div>
          <div className="flex items-center gap-1">
            <Button
              variant="ghost"
              size="icon"
              className="h-6 w-6"
              onClick={() => refetch()}
              title="Refresh"
            >
              <RefreshCw className="h-3.5 w-3.5" />
            </Button>
            <Button
              variant="ghost"
              size="icon"
              className="h-6 w-6"
              onClick={() => {
                setCreatingWindow(true);
                setSelectedWindowId(null);
              }}
              title="New window"
            >
              <Plus className="h-3.5 w-3.5" />
            </Button>
          </div>
        </div>

        <div className="flex-1 overflow-y-auto py-1">
          {windowsLoading ? (
            <div className="px-4 py-3 text-xs text-muted-foreground">Loading...</div>
          ) : windows.length === 0 ? (
            <div className="px-4 py-3 text-xs text-muted-foreground">No windows defined</div>
          ) : (
            windows.map((win) => (
              <button
                key={win.sys_window_id}
                onClick={() => {
                  setSelectedWindowId(win.sys_window_id);
                  setCreatingWindow(false);
                }}
                className={cn(
                  'w-full text-left px-4 py-2.5 text-sm transition-colors flex items-start gap-2',
                  selectedWindowId === win.sys_window_id
                    ? 'bg-primary/10 text-primary font-medium border-r-2 border-primary'
                    : 'text-foreground hover:bg-muted/60'
                )}
              >
                <AppWindow className="h-4 w-4 mt-0.5 shrink-0 text-muted-foreground" />
                <div className="min-w-0 flex-1">
                  <div className="font-medium truncate">{win.name}</div>
                  {win.description && (
                    <div className="text-xs text-muted-foreground truncate mt-0.5">
                      {win.description}
                    </div>
                  )}
                </div>
                {win.is_active === false && (
                  <Badge variant="outline" className="text-xs shrink-0 opacity-50">off</Badge>
                )}
              </button>
            ))
          )}
        </div>
      </div>

      {/* ── Right panel: Window editor ───────────────────────────── */}
      <div className="flex-1 flex flex-col min-w-0 overflow-hidden">
        {creatingWindow ? (
          /* ── Create new window form ── */
          <div className="flex-1 overflow-auto">
            <div className="border-b px-4 py-3 flex items-center justify-between bg-muted/10">
              <div className="flex items-center gap-2">
                <AppWindow className="h-4 w-4 text-muted-foreground" />
                <span className="font-semibold text-sm">New Window</span>
              </div>
              <button
                onClick={() => setCreatingWindow(false)}
                className="text-muted-foreground hover:text-foreground"
              >
                <X className="h-4 w-4" />
              </button>
            </div>
            <div className="p-4">
              <DynamicForm
                fields={SYS_WINDOW_FIELDS}
                initialData={{ is_active: true }}
                onSubmit={(data) => createWindowMutation.mutateAsync(data)}
                isSaving={createWindowMutation.isPending}
                mode="create"
              />
            </div>
          </div>
        ) : selectedWindow ? (
          /* ── Edit selected window ── */
          <>
            <div className="border-b px-4 py-3 flex items-center gap-2 bg-muted/10 shrink-0">
              <AppWindow className="h-4 w-4 text-muted-foreground" />
              <span className="font-semibold text-sm">{selectedWindow.name}</span>
              {selectedWindow.is_active === false && (
                <Badge variant="outline" className="opacity-50 text-xs">Inactive</Badge>
              )}
            </div>
            <WindowEditor
              window={selectedWindow}
              tabCount={tabCount}
              onSave={async (data) => { await updateWindowMutation.mutateAsync({ id: selectedWindow.sys_window_id, data }); }}
              isSaving={updateWindowMutation.isPending}
            />
          </>
        ) : (
          /* ── Empty state ── */
          <div className="flex-1 flex items-center justify-center">
            <div className="text-center space-y-3">
              <AppWindow className="h-12 w-12 text-muted-foreground/40 mx-auto" />
              <div>
                <p className="font-medium text-muted-foreground">Application Dictionary</p>
                <p className="text-sm text-muted-foreground/70 mt-1">
                  Select a window from the list, or click <span className="text-primary">+</span> to create one
                </p>
              </div>
            </div>
          </div>
        )}
      </div>
    </div>
  );
}
