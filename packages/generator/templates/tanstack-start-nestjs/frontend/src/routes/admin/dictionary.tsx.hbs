/**
 * Application Dictionary - Compiere-style admin
 *
 * Window/Tab paradigm:
 *   Left panel  = master list of sys_window records
 *   Right panel = selected window with nested tabs:
 *     Tab 0 "Window"  = parent form (DynamicForm for sys_window)
 *     Tab 1 "Tab (N)" = child grid  (sys_tab records for this window)
 *       Clicking a tab row expands:
 *         Sub-tab 0 "Tab Details" = tab form (DynamicForm for sys_tab)
 *         Sub-tab 1 "Fields (N)"  = grandchild grid (sys_field records for this tab)
 *           Clicking a field row expands:
 *             Inline field form (DynamicForm for sys_field)
 */

import { useState } from 'react';
import { createFileRoute } from '@tanstack/react-router';
import { useQuery, useMutation, useQueryClient } from '@tanstack/react-query';
