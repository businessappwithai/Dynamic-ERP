/**
 * Windows Management Page - Compiere Application Dictionary
 *
 * Manage sys_window records: create, edit, view tabs.
 * Windows are the top-level containers that group tabs (entity views).
 *
 * Swiss Clean Design - Editorial layout with minimalist aesthetic
 */

import { useState } from 'react';
import { createFileRoute, Link } from '@tanstack/react-router';
import { useQuery, useMutation, useQueryClient } from '@tanstack/react-query';
import {
  AppWindow,
  ArrowLeft,
  RefreshCw,
  Plus,
  Pencil,
  ChevronRight,
  X,
  Check,
} from 'lucide-react';
import { apiClient, PaginatedResponse } from '@/lib/api-client';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Badge } from '@/components/ui/badge';
import { toast } from 'sonner';

export const Route = createFileRoute('/admin/windows')({
  component: WindowsManagementPage,
});

interface SysWindow {
  sys_window_id: string;
  name: string;
  description?: string;
  window_type?: string;
  is_active?: boolean;
  created_at?: string;
  updated_at?: string;
}

interface SysTab {
  sys_tab_id: string;
  sys_window_id: string;
  name: string;
  seq_no: number;
  tab_level: number;
  is_active?: boolean;
}

interface WindowFormState {
  name: string;
  description: string;
  window_type: string;
  is_active: boolean;
}

function WindowForm({
  initial,
  onSave,
  onCancel,
  saving,
}: {
  initial?: Partial<WindowFormState>;
  onSave: (data: WindowFormState) => void;
  onCancel: () => void;
  saving: boolean;
}) {
  const [form, setForm] = useState<WindowFormState>({
    name: initial?.name ?? '',
    description: initial?.description ?? '',
    window_type: initial?.window_type ?? 'M',
    is_active: initial?.is_active ?? true,
  });

  return (
    <div className="border-2 border-border p-6 bg-card space-y-4">
      <div className="grid grid-cols-2 gap-4">
        <div>
          <label className="block text-xs font-bold uppercase tracking-wider mb-1">Name *</label>
          <Input
            value={form.name}
            onChange={(e) => setForm((f) => ({ ...f, name: e.target.value }))}
            placeholder="e.g. Customer Window"
            className="rounded-none border-2"
          />
        </div>
        <div>
          <label className="block text-xs font-bold uppercase tracking-wider mb-1">Window Type</label>
          <select
            value={form.window_type}
            onChange={(e) => setForm((f) => ({ ...f, window_type: e.target.value }))}
            className="w-full h-10 border-2 border-border bg-background px-3 text-sm"
          >
            <option value="M">M — Maintain</option>
            <option value="T">T — Transaction</option>
            <option value="Q">Q — Query</option>
          </select>
        </div>
      </div>
      <div>
        <label className="block text-xs font-bold uppercase tracking-wider mb-1">Description</label>
        <Input
          value={form.description}
          onChange={(e) => setForm((f) => ({ ...f, description: e.target.value }))}
          placeholder="Optional description"
          className="rounded-none border-2"
        />
      </div>
      <div className="flex items-center gap-2">
        <input
          type="checkbox"
          id="win-active"
          checked={form.is_active}
          onChange={(e) => setForm((f) => ({ ...f, is_active: e.target.checked }))}
          className="h-4 w-4"
        />
        <label htmlFor="win-active" className="text-sm">Active</label>
      </div>
      <div className="flex gap-3 pt-2">
        <Button
          size="sm"
          className="rounded-none bg-black text-white hover:bg-gray-800"
          onClick={() => onSave(form)}
          disabled={saving || !form.name.trim()}
        >
          <Check className="h-4 w-4 mr-1" />
          {saving ? 'Saving...' : 'Save'}
        </Button>
        <Button size="sm" variant="outline" className="rounded-none border-2" onClick={onCancel}>
          <X className="h-4 w-4 mr-1" />
          Cancel
        </Button>
      </div>
    </div>
  );
}

function WindowsManagementPage() {
  const queryClient = useQueryClient();
  const [creatingNew, setCreatingNew] = useState(false);
  const [editingId, setEditingId] = useState<string | null>(null);
  const [expandedId, setExpandedId] = useState<string | null>(null);

  const { data: windowsResponse, isLoading, refetch } = useQuery({
    queryKey: ['admin', 'windows-mgmt'],
    queryFn: () => apiClient.get<PaginatedResponse<SysWindow>>('/sys/windows', { limit: 200 }),
  });

  const { data: tabsResponse } = useQuery({
    queryKey: ['admin', 'tabs-all'],
    queryFn: () => apiClient.get<PaginatedResponse<SysTab>>('/sys/tabs', { limit: 500 }),
  });

  const createMutation = useMutation({
    mutationFn: (data: WindowFormState) => apiClient.post<SysWindow>('/sys/windows', data),
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: ['admin', 'windows-mgmt'] });
      setCreatingNew(false);
      toast.success('Window created');
    },
    onError: () => toast.error('Failed to create window'),
  });

  const updateMutation = useMutation({
    mutationFn: ({ id, data }: { id: string; data: WindowFormState }) =>
      apiClient.patch<SysWindow>(`/sys/windows/${id}`, data),
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: ['admin', 'windows-mgmt'] });
      setEditingId(null);
      toast.success('Window updated');
    },
    onError: () => toast.error('Failed to update window'),
  });

  const windows = windowsResponse?.data ?? [];
  const allTabs = tabsResponse?.data ?? [];

  const tabsByWindow: Record<string, SysTab[]> = {};
  allTabs.forEach((tab) => {
    if (!tabsByWindow[tab.sys_window_id]) tabsByWindow[tab.sys_window_id] = [];
    tabsByWindow[tab.sys_window_id].push(tab);
  });

  return (
    <div className="min-h-screen bg-background">
      <header className="border-b-4 border-border bg-background">
        <div className="max-w-7xl mx-auto px-8 py-12">
          <div className="flex items-start justify-between">
            <div className="flex-1">
              <div className="flex items-center gap-3 mb-4">
                <AppWindow className="h-8 w-8 text-purple-600" />
                <h1 className="text-6xl font-bold tracking-tight text-foreground font-display">
                  Windows
                </h1>
              </div>
              <p className="text-xl text-muted-foreground font-light max-w-2xl leading-relaxed">
                Manage application windows — the top-level containers that define entity screens
              </p>
            </div>
            <div className="flex gap-3">
              <Button
                variant="outline"
                size="default"
                onClick={() => refetch()}
                disabled={isLoading}
                className="border-2 border-border hover:bg-black hover:text-white transition-colors rounded-none"
              >
                <RefreshCw className={`h-4 w-4 mr-2 ${isLoading ? 'animate-spin' : ''}`} />
                Refresh
              </Button>
              <Button
                size="default"
                className="rounded-none bg-black text-white hover:bg-gray-800"
                onClick={() => { setCreatingNew(true); setEditingId(null); }}
              >
                <Plus className="h-4 w-4 mr-2" />
                New Window
              </Button>
            </div>
          </div>
        </div>
      </header>

      <main className="max-w-7xl mx-auto px-8 py-12">
        <div className="mb-8">
          <Link to="/admin" className="inline-flex items-center text-sm hover:underline">
            <ArrowLeft className="h-4 w-4 mr-2" />
            Back to Admin Dashboard
          </Link>
        </div>

        {/* Stats */}
        <div className="mb-8 flex gap-6 text-sm">
          <span><strong>{windowsResponse?.meta?.total ?? 0}</strong> windows</span>
          <span><strong>{tabsResponse?.meta?.total ?? 0}</strong> tabs total</span>
        </div>

        {/* New Window Form */}
        {creatingNew && (
          <div className="mb-6">
            <h3 className="text-sm font-bold uppercase tracking-wider mb-3">New Window</h3>
            <WindowForm
              onSave={(data) => createMutation.mutate(data)}
              onCancel={() => setCreatingNew(false)}
              saving={createMutation.isPending}
            />
          </div>
        )}

        {/* Windows List */}
        {isLoading ? (
          <div className="text-center py-16 text-muted-foreground border-2 border-border">Loading...</div>
        ) : windows.length === 0 ? (
          <div className="text-center py-16 text-muted-foreground border-2 border-border">No windows found.</div>
        ) : (
          <div className="border-2 border-border">
            {windows.map((win, idx) => {
              const winTabs = (tabsByWindow[win.sys_window_id] ?? []).sort((a, b) => a.seq_no - b.seq_no);
              const isExpanded = expandedId === win.sys_window_id;
              const isEditing = editingId === win.sys_window_id;

              return (
                <div key={win.sys_window_id} className={idx > 0 ? 'border-t-2 border-border' : ''}>
                  {isEditing ? (
                    <div className="px-6 py-4">
                      <WindowForm
                        initial={win as Partial<WindowFormState>}
                        onSave={(data) => updateMutation.mutate({ id: win.sys_window_id, data })}
                        onCancel={() => setEditingId(null)}
                        saving={updateMutation.isPending}
                      />
                    </div>
                  ) : (
                    <div className="px-6 py-4 flex items-center gap-4 hover:bg-muted/20 transition-colors">
                      <button
                        onClick={() => setExpandedId(isExpanded ? null : win.sys_window_id)}
                        className="flex items-center gap-4 flex-1 text-left"
                      >
                        <ChevronRight
                          className={`h-5 w-5 flex-shrink-0 text-muted-foreground transition-transform ${isExpanded ? 'rotate-90' : ''}`}
                        />
                        <div className="flex-1">
                          <div className="flex items-center gap-3 mb-0.5">
                            <span className="font-bold text-lg">{win.name}</span>
                            {win.window_type && (
                              <code className="text-xs px-2 py-0.5 bg-gray-100 text-gray-700 font-mono">{win.window_type}</code>
                            )}
                            <Badge variant={win.is_active !== false ? 'default' : 'secondary'} className="text-xs">
                              {win.is_active !== false ? 'Active' : 'Inactive'}
                            </Badge>
                            <span className="text-xs text-muted-foreground">
                              {winTabs.length} tab{winTabs.length !== 1 ? 's' : ''}
                            </span>
                          </div>
                          {win.description && (
                            <p className="text-sm text-muted-foreground">{win.description}</p>
                          )}
                        </div>
                      </button>
                      <div className="flex gap-2">
                        <Button
                          size="sm"
                          variant="ghost"
                          className="rounded-none hover:bg-black hover:text-white"
                          onClick={() => { setEditingId(win.sys_window_id); setCreatingNew(false); }}
                        >
                          <Pencil className="h-4 w-4 mr-1" />
                          Edit
                        </Button>
                        <Link to="/admin/tabs" search={{ windowId: win.sys_window_id }}>
                          <Button size="sm" variant="outline" className="rounded-none border-2">
                            View Tabs
                          </Button>
                        </Link>
                      </div>
                    </div>
                  )}

                  {/* Expanded Tabs Preview */}
                  {isExpanded && !isEditing && winTabs.length > 0 && (
                    <div className="px-6 pb-4 bg-muted/10 border-t border-border">
                      <p className="text-xs font-bold uppercase tracking-wider text-muted-foreground my-3">Tabs</p>
                      <div className="space-y-1">
                        {winTabs.map((tab) => (
                          <div key={tab.sys_tab_id} className="flex items-center gap-3 text-sm py-1">
                            <span className="w-8 text-right text-xs text-muted-foreground">{tab.seq_no}</span>
                            <span className={tab.tab_level > 0 ? 'ml-4' : ''}>{tab.name}</span>
                            <Badge variant="outline" className="text-xs">Level {tab.tab_level}</Badge>
                          </div>
                        ))}
                      </div>
                    </div>
                  )}
                </div>
              );
            })}
          </div>
        )}
      </main>
    </div>
  );
}
