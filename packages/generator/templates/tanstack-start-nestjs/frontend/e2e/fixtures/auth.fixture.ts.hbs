/**
 * Authentication Fixture for E2E Tests
 *
 * Provides an authenticated page fixture that logs in before each test.
 *
 * Usage:
 * import { test } from './auth.fixture';
 * test('should perform authenticated action', async ({ authenticatedPage }) => {
 *   // authenticatedPage is already logged in and ready to use
 * });
 *
 * Generated: {{now}}
 */

import { test as base, expect } from '@playwright/test';

export const test = base.extend({
  authenticatedPage: async ({ page }, use) => {
    // Navigate to sign-in page
    await page.goto('/sign-in');

    // Wait for page to load
    await expect(page.locator('button:has-text("Sign In")')).toBeVisible({ timeout: 10000 });

    // Fill in credentials (use test account or from environment)
    const email = process.env.TEST_EMAIL || 'admin@example.com';
    const password = process.env.TEST_PASSWORD || 'password123';

    // Try to find email input by various selectors
    const emailInput = page.locator('input[name="email"]').or(
      page.locator('input[type="email"]').or(
        page.locator('input[data-testid="email"]')
      )
    );
    const passwordInput = page.locator('input[name="password"]').or(
      page.locator('input[type="password"]').or(
        page.locator('input[data-testid="password"]')
      )
    );

    await emailInput.fill(email);
    await passwordInput.fill(password);

    // Click sign in button
    const signInButton = page.locator('button:has-text("Sign In")').or(
      page.locator('button[data-testid="sign-in-button"]')
    );
    await signInButton.click();

    // Wait for redirect to dashboard or home page after successful login
    await expect(page).toHaveURL(/\/(dashboard|home|projects)/, { timeout: 10000 });

    // Verify user is logged in by checking for logout option or user menu
    const userMenu = page.locator('button[data-testid="user-menu"]').or(
      page.locator('text=Sign Out')
    );
    await expect(userMenu).toBeVisible({ timeout: 10000 });

    // Now use the authenticated page
    await use(page);

    // Optional: Clean up (sign out) after test
    // await page.click('text=Sign Out');
  },
});

export { expect };
