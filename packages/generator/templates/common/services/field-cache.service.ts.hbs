/**
 * Field Cache Service
 *
 * Provides in-memory caching for sys_field metadata lookups.
 * Every form render reads sys_field to determine field order, visibility,
 * and display configuration. This cache prevents repeated database queries
 * and invalidates automatically when admin changes are made.
 *
 * Cache Strategy:
 * - Per-table cache entries with TTL (default 5 minutes)
 * - Automatic invalidation on sys_field PATCH/PUT/DELETE
 * - Manual invalidation via cache.clear() or cache.invalidateTable()
 * - LRU eviction when max entries exceeded
 *
 * Generated: {{now}}
 * Project: {{project.name}}
 */

import { Knex } from 'knex';

// ============================================================================
// Types
// ============================================================================

export interface CachedFieldMetadata {
  sys_field_id: string;
  table_name: string;
  column_name: string;
  display_name: string;
  description: string | null;
  seq_no: number;
  seq_no_grid: number;
  is_displayed: boolean;
  is_displayed_grid: boolean;
  is_readonly: boolean;
  is_mandatory: boolean;
  field_length: number | null;
  display_length: number | null;
  field_group: string | null;
  default_value: string | null;
  reference_id: string | null;
  data_type: string;
  is_active: boolean;
}

interface CacheEntry {
  fields: CachedFieldMetadata[];
  timestamp: number;
  accessCount: number;
  lastAccessed: number;
}

interface FieldCacheOptions {
  /** Time-to-live in milliseconds (default: 5 minutes) */
  ttlMs?: number;
  /** Maximum number of table entries in cache (default: 100) */
  maxEntries?: number;
  /** Enable debug logging (default: false) */
  debug?: boolean;
}

// ============================================================================
// Field Cache Service
// ============================================================================

export class FieldCacheService {
  private cache: Map<string, CacheEntry> = new Map();
  private ttlMs: number;
  private maxEntries: number;
  private debug: boolean;
  private db: Knex;

  // Cache statistics
  private stats = {
    hits: 0,
    misses: 0,
    invalidations: 0,
    evictions: 0,
  };

  constructor(db: Knex, options: FieldCacheOptions = {}) {
    this.db = db;
    this.ttlMs = options.ttlMs ?? 5 * 60 * 1000; // 5 minutes default
    this.maxEntries = options.maxEntries ?? 100;
    this.debug = options.debug ?? false;
  }

  /**
   * Get field metadata for a table, using cache when available.
   * Fields are returned sorted by seq_no for form rendering.
   */
  async getFieldsForTable(tableName: string): Promise<CachedFieldMetadata[]> {
    const cacheKey = tableName.toLowerCase();
    const cached = this.cache.get(cacheKey);

    // Check if cache entry exists and is still valid
    if (cached && (Date.now() - cached.timestamp) < this.ttlMs) {
      cached.accessCount++;
      cached.lastAccessed = Date.now();
      this.stats.hits++;

      if (this.debug) {
        console.log(`[FieldCache] HIT: ${tableName} (${cached.fields.length} fields)`);
      }

      return cached.fields;
    }

    // Cache miss - fetch from database
    this.stats.misses++;

    if (this.debug) {
      console.log(`[FieldCache] MISS: ${tableName} - fetching from database`);
    }

    const fields = await this.fetchFieldsFromDb(tableName);

    // Evict LRU entry if cache is full
    if (this.cache.size >= this.maxEntries && !this.cache.has(cacheKey)) {
      this.evictLRU();
    }

    // Store in cache
    this.cache.set(cacheKey, {
      fields,
      timestamp: Date.now(),
      accessCount: 1,
      lastAccessed: Date.now(),
    });

    return fields;
  }

  /**
   * Get field metadata for form rendering (is_displayed = true, sorted by seq_no)
   */
  async getFormFields(tableName: string): Promise<CachedFieldMetadata[]> {
    const allFields = await this.getFieldsForTable(tableName);
    return allFields
      .filter(f => f.is_displayed && f.is_active)
      .sort((a, b) => a.seq_no - b.seq_no);
  }

  /**
   * Get field metadata for grid/table rendering (is_displayed_grid = true, sorted by seq_no_grid)
   */
  async getGridFields(tableName: string): Promise<CachedFieldMetadata[]> {
    const allFields = await this.getFieldsForTable(tableName);
    return allFields
      .filter(f => f.is_displayed_grid && f.is_active)
      .sort((a, b) => a.seq_no_grid - b.seq_no_grid);
  }

  /**
   * Invalidate cache for a specific table.
   * Call this when sys_field records for a table are modified.
   */
  invalidateTable(tableName: string): void {
    const cacheKey = tableName.toLowerCase();
    if (this.cache.has(cacheKey)) {
      this.cache.delete(cacheKey);
      this.stats.invalidations++;

      if (this.debug) {
        console.log(`[FieldCache] INVALIDATED: ${tableName}`);
      }
    }
  }

  /**
   * Clear the entire cache.
   * Call this during admin bulk operations.
   */
  clear(): void {
    const size = this.cache.size;
    this.cache.clear();
    this.stats.invalidations += size;

    if (this.debug) {
      console.log(`[FieldCache] CLEARED: ${size} entries removed`);
    }
  }

  /**
   * Get cache statistics for monitoring.
   */
  getStats(): {
    hits: number;
    misses: number;
    invalidations: number;
    evictions: number;
    hitRate: string;
    size: number;
    maxEntries: number;
  } {
    const total = this.stats.hits + this.stats.misses;
    const hitRate = total > 0 ? ((this.stats.hits / total) * 100).toFixed(1) + '%' : 'N/A';

    return {
      ...this.stats,
      hitRate,
      size: this.cache.size,
      maxEntries: this.maxEntries,
    };
  }

  /**
   * Middleware hook for sys_field mutation endpoints.
   * Call after any PATCH/PUT/DELETE on sys_field to invalidate the cache.
   */
  onFieldMutation(tableName: string): void {
    this.invalidateTable(tableName);
  }

  // ==========================================================================
  // Private Methods
  // ==========================================================================

  private async fetchFieldsFromDb(tableName: string): Promise<CachedFieldMetadata[]> {
    const fields = await this.db('sys_field')
      .where('table_name', tableName)
      .where('is_active', true)
      .orderBy('seq_no', 'asc')
      .select(
        'sys_field_id',
        'table_name',
        'column_name',
        'display_name',
        'description',
        'seq_no',
        'seq_no_grid',
        'is_displayed',
        'is_displayed_grid',
        'is_readonly',
        'is_mandatory',
        'field_length',
        'display_length',
        'field_group',
        'default_value',
        'reference_id',
        'data_type',
        'is_active'
      );

    return fields as CachedFieldMetadata[];
  }

  private evictLRU(): void {
    let oldestKey: string | null = null;
    let oldestAccess = Infinity;

    for (const [key, entry] of this.cache) {
      if (entry.lastAccessed < oldestAccess) {
        oldestAccess = entry.lastAccessed;
        oldestKey = key;
      }
    }

    if (oldestKey) {
      this.cache.delete(oldestKey);
      this.stats.evictions++;

      if (this.debug) {
        console.log(`[FieldCache] EVICTED: ${oldestKey} (LRU)`);
      }
    }
  }
}

// ============================================================================
// Singleton Factory
// ============================================================================

let _fieldCacheInstance: FieldCacheService | null = null;

/**
 * Get the singleton FieldCacheService instance.
 * Creates the instance on first call.
 */
export function getFieldCache(db: Knex, options?: FieldCacheOptions): FieldCacheService {
  if (!_fieldCacheInstance) {
    _fieldCacheInstance = new FieldCacheService(db, options);
  }
  return _fieldCacheInstance;
}
