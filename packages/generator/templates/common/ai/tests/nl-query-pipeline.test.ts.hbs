// Test Helpers
// ============================================================================

function createAdminPermissions(): RolePermissions {
  return {
    userId: 'user-admin',
    roles: ['admin'],
    tablePermissions: new Map([
      {{#each entities}}
      ['{{tableName}}', { canRead: true, canWrite: true }],
      {{/each}}
    ]),
    fieldPermissions: new Map(),
  };
}

function createViewerPermissions(): RolePermissions {
  return {
    userId: 'user-viewer',
    roles: ['viewer'],
    tablePermissions: new Map([
      {{#each entities}}
      ['{{tableName}}', { canRead: true, canWrite: false }],
      {{/each}}
    ]),
    fieldPermissions: new Map(),
  };
}

function createNoAccessPermissions(): RolePermissions {
  return {
    userId: 'user-none',
    roles: [],
    tablePermissions: new Map(),
    fieldPermissions: new Map(),
  };
}

// ============================================================================
// 1. ANTLR4 SQL Validation Tests
// ============================================================================

describe('ANTLR4 SQL Validation', () => {
  let validator: ANTLR4SQLValidator;

  beforeEach(async () => {
    const schemaDefinition = await buildSchemaDefinition(db);
    const permissions = createAdminPermissions();
    validator = new ANTLR4SQLValidator(schemaDefinition, permissions, {
      maxComplexityScore: 80,
    });
  });

  it('should validate a simple SELECT query', () => {
    {{#with (first entities)}}
    const result = validator.validate('SELECT * FROM {{tableName}}');
    expect(result.isValid).toBe(true);
    expect(result.errors).toHaveLength(0);
    {{/with}}
  });

  it('should reject DROP TABLE statements', () => {
    {{#with (first entities)}}
    const result = validator.validate('DROP TABLE {{tableName}}');
    expect(result.isValid).toBe(false);
    expect(result.errors.some(e => e.message.includes('dangerous'))).toBe(true);
    {{/with}}
  });

  it('should reject TRUNCATE statements', () => {
    {{#with (first entities)}}
    const result = validator.validate('TRUNCATE TABLE {{tableName}}');
    expect(result.isValid).toBe(false);
    {{/with}}
  });

  it('should reject DELETE statements', () => {
    {{#with (first entities)}}
    const result = validator.validate('DELETE FROM {{tableName}}');
    expect(result.isValid).toBe(false);
    {{/with}}
  });

  it('should validate query with WHERE clause', () => {
    {{#with (first entities)}}
    const result = validator.validate(
      "SELECT * FROM {{tableName}} WHERE version = 1"
    );
    expect(result.isValid).toBe(true);
    {{/with}}
  });

  it('should validate query with ORDER BY and LIMIT', () => {
    {{#with (first entities)}}
    const result = validator.validate(
      'SELECT * FROM {{tableName}} ORDER BY created_at DESC LIMIT 10'
    );
    expect(result.isValid).toBe(true);
    {{/with}}
  });

  it('should reject queries against non-existent tables', () => {
    const result = validator.validate('SELECT * FROM nonexistent_table');
    expect(result.isValid).toBe(false);
    expect(result.errors.some(e => e.message.includes('table'))).toBe(true);
  });

  it('should enforce role-based table access', () => {
    const noAccessPerms = createNoAccessPermissions();
    const schemaDefinition = {
      tables: new Map([
        {{#with (first entities)}}
        ['{{tableName}}', { name: '{{tableName}}', columns: ['*'], allowedOperations: ['select'] as const }],
        {{/with}}
      ]),
    };

    const restrictedValidator = new ANTLR4SQLValidator(
      schemaDefinition,
      noAccessPerms,
      { maxComplexityScore: 80 }
    );

    {{#with (first entities)}}
    const result = restrictedValidator.validate('SELECT * FROM {{tableName}}');
    expect(result.isValid).toBe(false);
    {{/with}}
  });

  it('should calculate complexity score', () => {
    {{#with (first entities)}}
    const result = validator.validate(
      'SELECT * FROM {{tableName}} WHERE version > 0 ORDER BY created_at LIMIT 100'
    );
    expect(result.isValid).toBe(true);
    expect(result.complexity).toBeDefined();
    expect(result.complexity!.score).toBeGreaterThan(0);
    {{/with}}
  });
});

// ============================================================================
// 2. Knex Query Builder Tests
// ============================================================================

describe('Knex Query Builder', () => {
  let builder: KnexQueryBuilder;

  beforeEach(() => {
    const permissions = createAdminPermissions();
    builder = new KnexQueryBuilder(db, permissions);
  });

  it('should execute a simple list query', async () => {
    {{#with (first entities)}}
    const intent: QueryIntent = {
      entity: '{{name}}',
      operation: 'list',
      fields: ['*'],
      filters: [],
      limit: 10,
    };

    const result = await builder.executeQuery(intent, 'List all {{name}} records');
    expect(result.data).toBeDefined();
    expect(Array.isArray(result.data)).toBe(true);
    expect(result.count).toBeGreaterThanOrEqual(0);
    {{/with}}
  });

  it('should execute a count query', async () => {
    {{#with (first entities)}}
    const intent: QueryIntent = {
      entity: '{{name}}',
      operation: 'count',
      fields: [],
      filters: [],
    };

    const result = await builder.executeQuery(intent, 'Count {{name}} records');
    expect(result.count).toBeGreaterThanOrEqual(0);
    expect(result.displayHint).toBe('number');
    {{/with}}
  });

  it('should apply filters correctly', async () => {
    {{#with (first entities)}}
    const intent: QueryIntent = {
      entity: '{{name}}',
      operation: 'list',
      fields: ['*'],
      filters: [
        { field: 'version', operator: 'eq', value: 1 },
      ],
      limit: 100,
    };

    const result = await builder.executeQuery(intent, 'List {{name}} with version 1');
    expect(result.data).toBeDefined();
    for (const row of result.data) {
      expect(row.version).toBe(1);
    }
    {{/with}}
  });

  it('should respect query timeout', async () => {
    {{#with (first entities)}}
    const intent: QueryIntent = {
      entity: '{{name}}',
      operation: 'list',
      fields: ['*'],
      filters: [],
      limit: 1,
    };

    // Should complete within timeout
    const result = await builder.executeQuery(intent, 'Quick query');
    expect(result.executionTimeMs).toBeDefined();
    expect(result.executionTimeMs).toBeLessThan(30000);
    {{/with}}
  });

  it('should return correct display hint', async () => {
    {{#with (first entities)}}
    // Count query should return 'number' hint
    const countIntent: QueryIntent = {
      entity: '{{name}}',
      operation: 'count',
      fields: [],
      filters: [],
    };
    const countResult = await builder.executeQuery(countIntent, 'Count');
    expect(countResult.displayHint).toBe('number');

    // List query should return 'table' hint
    const listIntent: QueryIntent = {
      entity: '{{name}}',
      operation: 'list',
      fields: ['*'],
      filters: [],
      limit: 10,
    };
    const listResult = await builder.executeQuery(listIntent, 'List');
    expect(listResult.displayHint).toBe('table');
    {{/with}}
  });
});

