  await db('sys_role').insert({ sys_role_id: 'role-viewer', name: 'viewer' });
  await db('sys_user_role').insert({
    sys_user_role_id: 'ur-1',
    sys_user_id: 'user-admin',
    sys_role_id: 'role-admin',
