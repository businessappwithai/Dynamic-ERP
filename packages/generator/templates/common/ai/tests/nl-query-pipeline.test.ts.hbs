// ============================================================================
// 4. Security Validation Tests
// ============================================================================

describe('Security Validation', () => {
  it('should block SQL injection attempts via NL input', async () => {
    const schemaDefinition = await buildSchemaDefinition(db);
    const permissions = createAdminPermissions();
    const validator = new ANTLR4SQLValidator(schemaDefinition, permissions, {
      maxComplexityScore: 80,
    });

    // These SQL strings should be rejected
    const maliciousInputs = [
      "SELECT * FROM bus_user; DROP TABLE bus_user; --",
      "SELECT * FROM bus_user UNION SELECT * FROM sys_role",
      "DELETE FROM bus_user WHERE 1=1",
      "UPDATE bus_user SET version = 999",
      "ALTER TABLE bus_user ADD COLUMN hacked boolean",
    ];

    for (const sql of maliciousInputs) {
      const result = validator.validate(sql);
      expect(result.isValid).toBe(false);
    }
  });

  it('should only allow SELECT operations', () => {
    {{#with (first entities)}}
    const schemaDefinition = {
      tables: new Map([
        ['{{tableName}}', {
          name: '{{tableName}}',
          columns: ['*'],
          allowedOperations: ['select'] as const,
        }],
      ]),
    };

    const permissions = createAdminPermissions();
    const validator = new ANTLR4SQLValidator(schemaDefinition, permissions, {
      maxComplexityScore: 80,
    });

    // SELECT should pass
    expect(validator.validate('SELECT * FROM {{tableName}}').isValid).toBe(true);

    // INSERT should fail
    expect(validator.validate("INSERT INTO {{tableName}} VALUES ('test')").isValid).toBe(false);
    {{/with}}
  });
});

