    };

    const result = await builder.executeQuery(intent, 'Find nonexistent record');
    expect(result.data).toHaveLength(0);
    expect(result.count).toBe(0);
    {{/with}}
  });

  it('should produce consistent results across multiple executions', async () => {
    const permissions = createAdminPermissions();
    const builder = new KnexQueryBuilder(db, permissions);

    {{#with (first entities)}}
    const intent: QueryIntent = {
      entity: '{{name}}',
      operation: 'count',
      fields: [],
      filters: [],
    };

    const result1 = await builder.executeQuery(intent, 'Count records - run 1');
    const result2 = await builder.executeQuery(intent, 'Count records - run 2');

    expect(result1.count).toBe(result2.count);
    {{/with}}
  });
});
