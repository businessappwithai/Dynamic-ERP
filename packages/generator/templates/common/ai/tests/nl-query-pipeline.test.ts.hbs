    const permissions = createAdminPermissions();
    const schemaDefinition = await buildSchemaDefinition(db);
    const validator = new ANTLR4SQLValidator(schemaDefinition, permissions, {
      maxComplexityScore: 80,
    });

    // Step 1: Simulate NL parsing result (QueryIntent)
    const intent: QueryIntent = {
      entity: '{{name}}',
      operation: 'list',
      fields: ['*'],
      filters: [],
      orderBy: [{ field: 'created_at', direction: 'desc' }],
      limit: 10,
    };

    // Step 2: Validate with ANTLR4
    const sql = `SELECT * FROM {{tableName}} ORDER BY created_at DESC LIMIT 10`;
    const validationResult = validator.validate(sql);
    expect(validationResult.isValid).toBe(true);

    // Step 3: Execute via Knex Query Builder
    const builder = new KnexQueryBuilder(db, permissions);
    const queryResult = await builder.executeQuery(intent, 'Show me the latest {{name}} records');

    // Step 4: Verify results
    expect(queryResult.data).toBeDefined();
    expect(Array.isArray(queryResult.data)).toBe(true);
    expect(queryResult.count).toBeGreaterThanOrEqual(0);
    expect(queryResult.executionTimeMs).toBeDefined();
    expect(queryResult.displayHint).toBe('table');
    {{/with}}
  });

  it('should handle empty result sets gracefully', async () => {
    const permissions = createAdminPermissions();
    const builder = new KnexQueryBuilder(db, permissions);

    {{#with (first entities)}}
    const intent: QueryIntent = {
      entity: '{{name}}',
      operation: 'list',
      fields: ['*'],
      filters: [
        { field: '{{tableName}}_id', operator: 'eq', value: 'nonexistent-id' },
      ],
