/**
 * Data Query Agent
 *
 * AI agent that parses natural language queries and converts them
 * to structured QueryIntent for Knex.js Query Builder execution.
 *
 * IMPORTANT: This agent does NOT generate SQL directly.
 * It produces structured intents that are:
 * 1. Validated by ANTLR4 (syntax + permissions)
 * 2. Executed by Knex.js Query Builder
 *
 * Generated: {{now}}
 * Project: {{project.name}}
 */

import { Agent } from '@mastra/core';
import { z } from 'zod';

// ============================================================================
// Schema Definitions
// ============================================================================

const filterSchema = z.object({
  field: z.string(),
  operator: z.enum(['eq', 'ne', 'gt', 'lt', 'gte', 'lte', 'like', 'in', 'between', 'isNull', 'isNotNull']),
  value: z.unknown(),
  connector: z.enum(['AND', 'OR']).optional(),
});

const aggregationSchema = z.object({
  function: z.enum(['count', 'sum', 'avg', 'min', 'max']),
  field: z.string(),
  alias: z.string().optional(),
});

const orderBySchema = z.object({
  field: z.string(),
  direction: z.enum(['asc', 'desc']),
});

const joinSchema = z.object({
  entity: z.string(),
  type: z.enum(['inner', 'left', 'right']),
  on: z.object({
    leftField: z.string(),
    rightField: z.string(),
  }),
});

const queryIntentSchema = z.object({
  entity: z.string().describe('The main entity to query'),
  operation: z.enum(['list', 'count', 'aggregate']).describe('Type of query operation'),
  fields: z.array(z.string()).optional().describe('Specific fields to select'),
  filters: z.array(filterSchema).optional().describe('WHERE conditions'),
  aggregations: z.array(aggregationSchema).optional().describe('Aggregation functions'),
  groupBy: z.array(z.string()).optional().describe('GROUP BY fields'),
  orderBy: z.array(orderBySchema).optional().describe('ORDER BY clauses'),
  limit: z.number().max(100).optional().describe('Maximum records to return'),
  joins: z.array(joinSchema).optional().describe('Related entities to include'),
});

export type QueryIntent = z.infer<typeof queryIntentSchema>;

// ============================================================================
// Data Query Agent
// ============================================================================

export const dataQueryAgent = new Agent({
  name: 'Data Query Agent',
  instructions: `
You are a data query assistant for the {{project.name}} application.

Your job is to parse natural language queries and convert them to structured QueryIntent objects.
You do NOT generate SQL directly - instead you produce structured intents that will be validated
and executed securely by the system.

## Available Entities

{{#each entities}}
### {{pascalCase name}}
{{#if description}}Description: {{description}}{{/if}}
Table: {{tableName}}
Fields:
{{#each attributes}}
  - {{name}} ({{type}}){{#if description}}: {{description}}{{/if}}
{{/each}}

{{/each}}

## Available Relationships

{{#each relationships}}
- {{sourceEntity}} {{cardinality}} {{targetEntity}} (via {{foreignKey}})
{{/each}}

## Query Intent Structure

When the user asks a question, respond with a QueryIntent object:

1. **entity**: The main entity to query (e.g., "Customer", "Order")
2. **operation**: One of "list", "count", or "aggregate"
3. **fields**: Specific fields to return (optional, defaults to all visible fields)
4. **filters**: WHERE conditions with field, operator, and value
5. **aggregations**: For count/sum/avg operations
6. **groupBy**: Fields to group by (for aggregations)
7. **orderBy**: Sorting instructions
8. **limit**: Maximum records (max 100)
9. **joins**: Related entities to include

## Operators

- eq: equals (=)
- ne: not equals (!=)
- gt: greater than (>)
- lt: less than (<)
- gte: greater than or equal (>=)
- lte: less than or equal (<=)
- like: pattern match (use % for wildcards)
- in: value in list
- between: value between two values
- isNull: field is null
- isNotNull: field is not null

## Examples

User: "Show me all customers from New York"
Intent:
{
  "entity": "Customer",
  "operation": "list",
  "filters": [{ "field": "city", "operator": "eq", "value": "New York" }]
}

User: "How many orders were placed last month?"
Intent:
{
  "entity": "Order",
  "operation": "count",
  "filters": [
    { "field": "createdAt", "operator": "gte", "value": "2024-12-01" },
    { "field": "createdAt", "operator": "lt", "value": "2025-01-01" }
  ]
}

User: "What's the average order value by customer?"
Intent:
{
  "entity": "Order",
  "operation": "aggregate",
  "aggregations": [{ "function": "avg", "field": "total", "alias": "avgTotal" }],
  "groupBy": ["customerId"]
}

## SECURITY RULES

1. NEVER include fields the user doesn't have permission to access
2. ALWAYS respect the entity relationships defined above
3. NEVER try to access system tables (sys_*) unless explicitly allowed
4. Limit results to 100 records maximum
5. For sensitive fields (password, etc.), do not include in queries

When unsure about permissions, default to safer options or ask for clarification.
`,
  model: {
    provider: 'ANTHROPIC',
    name: '{{config.aiNlModel}}',
    toolChoice: 'auto',
  },
  tools: {
    parseQuery: {
      description: 'Parse a natural language query into a structured QueryIntent',
      parameters: z.object({
        naturalLanguageQuery: z.string().describe('The user\'s natural language query'),
      }),
      execute: async ({ naturalLanguageQuery }, context) => {
        // The agent will use this tool to structure its response
        // The actual parsing is done by the agent's instructions
        return {
          success: true,
          message: 'Query parsed successfully',
        };
      },
    },
  },
});

// ============================================================================
// Query Intent Parser
// ============================================================================

/**
 * Parse natural language query to structured intent using the agent
 */
export async function parseNaturalLanguageQuery(
  query: string,
  context: { userId: string; sessionId: string }
): Promise<QueryIntent> {
  const result = await dataQueryAgent.generate({
    messages: [
      {
        role: 'user',
        content: `Parse the following natural language query into a QueryIntent JSON object:

"${query}"

Respond with ONLY the JSON object, no explanation.`,
      },
    ],
    context,
  });

  // Extract JSON from response
  const responseText = result.text || '';
  const jsonMatch = responseText.match(/\{[\s\S]*\}/);

  if (!jsonMatch) {
    throw new Error('Failed to parse query intent from agent response');
  }

  const intent = JSON.parse(jsonMatch[0]);

  // Validate against schema
  return queryIntentSchema.parse(intent);
}
