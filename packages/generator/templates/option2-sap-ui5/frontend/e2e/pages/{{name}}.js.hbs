/**
 * {{name}} Page Object
 * Generated by ERDwithAI
 */

sap.ui.define([
  'sap/ui/test/Opa5',
  'sap/ui/test/actions/Press',
  'sap/ui/test/actions/EnterText'
], function (Opa5, Press, EnterText) {
  'use strict';

  Opa5.createPageObjects({
    onThe{{pascalCase name}}Page: {

      actions: {
        iStartMy{{pascalCase name}}App: function () {
          return this.iStartMyApp({
            viewName: '{{pascalCase name}}'
          });
        },

        iTeardownMy{{pascalCase name}}App: function () {
          return this.iTeardownMyApp();
        },

        iLookAtTheScreen: function () {
          return this.waitFor({
            viewName: '{{pascalCase name}}',
            success: function () {
              Opa5.assert.ok(true, 'Looking at {{name}} page');
            }
          });
        },

        iPressCreate: function () {
          return this.waitFor({
            id: 'createButton',
            viewName: '{{pascalCase name}}',
            actions: new Press(),
            errorMessage: 'Did not find create button'
          });
        },

        iPressTheFirstItem: function () {
          return this.waitFor({
            controlType: 'sap.m.ColumnListItem',
            viewName: '{{pascalCase name}}',
            matchers: function (oListItem) {
              return oListItem.getBindingContext() !== null;
            },
            actions: new Press(),
            errorMessage: 'Did not find list item to press'
          });
        },

        iPressEdit: function () {
          return this.waitFor({
            id: 'editButton',
            viewName: '{{pascalCase name}}',
            actions: new Press(),
            errorMessage: 'Did not find edit button'
          });
        },

        iPressDelete: function () {
          return this.waitFor({
            id: 'deleteButton',
            viewName: '{{pascalCase name}}',
            actions: new Press(),
            errorMessage: 'Did not find delete button'
          });
        },

        iConfirmDelete: function () {
          return this.waitFor({
            controlType: 'sap.m.Dialog',
            matchers: new Opa5.Matchers.Properties({
              type: 'Confirmation'
            }),
            actions: new Press(),
            errorMessage: 'Did not find confirmation dialog'
          }).and({
            controlType: 'sap.m.Button',
            matchers: new Opa5.Matchers.Properties({
              text: 'Delete'
            }),
            actions: new Press(),
            errorMessage: 'Did not find delete button in dialog'
          });
        },

        iPressSave: function () {
          return this.waitFor({
            id: 'saveButton',
            viewName: '{{pascalCase name}}',
            actions: new Press(),
            errorMessage: 'Did not find save button'
          });
        },

        iEnter{{pascalCase name}}: function (sFieldName, bIsUpdate = false) {
          return this.waitFor({
            id: sFieldName + 'Input',
            viewName: '{{pascalCase name}}',
            actions: function (oInput) {
              const sValue = bIsUpdate
                ? storage.{{name}}.update[sFieldName]
                : storage.{{name}}.create[sFieldName];
              oInput.setValue(sValue);
            },
            errorMessage: `Did not find input for ${sFieldName}`
          });
        }
      },

      assertions: {
        iShouldSeeTheTable: function () {
          return this.waitFor({
            id: '{{camelCase name}}Table',
            viewName: '{{pascalCase name}}',
            success: function () {
              Opa5.assert.ok(true, 'Found {{name}} table');
            },
            errorMessage: 'Did not find {{name}} table'
          });
        },

        iShouldSeeTheDetailView: function () {
          return this.waitFor({
            id: 'detailPage',
            viewName: '{{pascalCase name}}',
            success: function () {
              Opa5.assert.ok(true, 'Found {{name}} detail view');
            },
            errorMessage: 'Did not find {{name}} detail view'
          });
        },

        iShouldSeeSuccessMessage: function () {
          return this.waitFor({
            controlType: 'sap.m.MessageToast',
            matchers: function (oMessageToast) {
              const sText = oMessageToast.getText();
              return sText && (sText.indexOf('success') > -1 || sText.indexOf('created') > -1 || sText.indexOf('updated') > -1);
            },
            success: function () {
              Opa5.assert.ok(true, 'Found success message');
            },
            errorMessage: 'Did not find success message'
          });
        },

        iShouldSeeTheTableWithOneRowLess: function () {
          return this.waitFor({
            id: '{{camelCase name}}Table',
            viewName: '{{pascalCase name}}',
            success: function (oTable) {
              const iBindingLength = oTable.getBinding('items').getLength();
              Opa5.assert.ok(iBindingLength >= 0, 'Table has items');
            },
            errorMessage: 'Table does not have binding'
          });
        }
      }
    }
  });
});
