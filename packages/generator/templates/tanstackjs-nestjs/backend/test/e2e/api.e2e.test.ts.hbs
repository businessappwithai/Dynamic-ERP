/**
 * Backend E2E API Tests
 *
 * Tests core API functionality:
 * - Health checks and system endpoints
 * - Authentication (sign-up, sign-in, sign-out, session)
 * - Entity CRUD operations
 * - Metadata endpoints
 * - Business rules API
 *
 * Run with: bun --test test/e2e/api.e2e.test.ts
 *
 * Generated: {{now}}
 * Project: {{project.name}}
 */

import { describe, it, expect, beforeAll, afterAll } from 'bun:test';
import type { NestFastifyApplication } from '@nestjs/platform-fastify';

describe('API E2E Tests', () => {
  let app: NestFastifyApplication;
  let sessionToken: string;
  let userId: string;

  beforeAll(async () => {
    const { NestFactory } = await import('@nestjs/core');
    const { FastifyAdapter } = await import('@nestjs/platform-fastify');
    const { AppModule } = await import('../../src/app.module');

    app = await NestFactory.create(
      AppModule,
      new FastifyAdapter({ logger: false })
    );

    await app.listen(3001, '0.0.0.0');
    console.log('Test server started on http://localhost:3001');
  });

  afterAll(async () => {
    await app.close();
  });

  describe('Health & System Endpoints', () => {
    it('should return health status', async () => {
      const response = await fetch('http://localhost:3001/api/me/health');
      expect(response.status).toBe(200);

      const data = await response.json();
      expect(data).toHaveProperty('status');
    });
  });

  describe('Authentication Flow', () => {
    it('should sign up a new user', async () => {
      const email = `test-${Date.now()}@example.com`;
      const response = await fetch('http://localhost:3001/api/auth/sign-up', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email,
          password: 'TestPassword123!',
          name: 'Test User',
        }),
      });

      expect(response.status).toBe(201);
      const data = await response.json();
      expect(data).toHaveProperty('user');
      expect(data.user.email).toBe(email);
    });

    it('should sign in and get session token', async () => {
      const response = await fetch('http://localhost:3001/api/auth/sign-in', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email: 'admin@example.com',
          password: 'password123',
        }),
      });

      expect(response.status).toBe(200);
      const data = await response.json();
      expect(data).toHaveProperty('session');

      if (data.session) {
        sessionToken = data.session.token;
        userId = data.user?.id || '';
      }
    });

    it('should get current session', async () => {
      const response = await fetch('http://localhost:3001/api/auth/session', {
        headers: {
          'Cookie': `authjs.session-token=${sessionToken}`,
        },
      });

      expect(response.status).toBeOneOf([200, 401]);

      if (response.status === 200) {
        const data = await response.json();
        expect(data).toHaveProperty('user');
      }
    });

    it('should sign out', async () => {
      const response = await fetch('http://localhost:3001/api/auth/sign-out', {
        method: 'POST',
        headers: {
          'Cookie': `authjs.session-token=${sessionToken}`,
        },
      });

      expect(response.status).toBeOneOf([200, 401]);
    });
  });

  describe('Entity CRUD Operations', () => {
    {{#each entities}}
    describe('{{name}} Endpoints', () => {
      let {{lowerFirst name}}Id: string;
      const testData = {
        {{#each attributes}}
        {{#unless (eq name "id")}}
        {{#unless (or (includes name "_id") (includes name "created_at") (includes name "updated_at"))}}
        {{name}}: {{mockValue type name}},
        {{/unless}}
        {{/unless}}
        {{/each}}
      };

      it('should get all {{lowerFirst name}}', async () => {
        const response = await fetch(
          'http://localhost:3001/api/bus/{{addBusPrefix tableName}}?page=1&limit=10',
          {
            headers: { 'Authorization': `Bearer ${sessionToken}` },
          }
        );

        expect(response.status).toBeOneOf([200, 401]);
      });

      it('should create a {{lowerFirst name}}', async () => {
        const response = await fetch(
          'http://localhost:3001/api/bus/{{addBusPrefix tableName}}',
          {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Authorization': `Bearer ${sessionToken}`,
            },
            body: JSON.stringify(testData),
          }
        );

        expect(response.status).toBeOneOf([201, 400, 401]);

        if (response.status === 201) {
          const data = await response.json();
          {{lowerFirst name}}Id = data.id || '';
          expect({{lowerFirst name}}Id).toBeTruthy();
        }
      });

      it('should get {{lowerFirst name}} by ID', async () => {
        if (!{{lowerFirst name}}Id) {
          console.log('Skipping: no {{lowerFirst name}}Id available');
          return;
        }

        const response = await fetch(
          `http://localhost:3001/api/bus/{{addBusPrefix tableName}}/${{{lowerFirst name}}Id}`,
          {
            headers: { 'Authorization': `Bearer ${sessionToken}` },
          }
        );

        expect(response.status).toBeOneOf([200, 404, 401]);
      });

      it('should update {{lowerFirst name}}', async () => {
        if (!{{lowerFirst name}}Id) {
          console.log('Skipping: no {{lowerFirst name}}Id available');
          return;
        }

        const response = await fetch(
          `http://localhost:3001/api/bus/{{addBusPrefix tableName}}/${{{lowerFirst name}}Id}`,
          {
            method: 'PATCH',
            headers: {
              'Content-Type': 'application/json',
              'Authorization': `Bearer ${sessionToken}`,
            },
            body: JSON.stringify({
              {{#each attributes}}
              {{#unless (eq name "id")}}
              {{#unless (or (includes name "_id") (includes name "created_at") (includes name "updated_at"))}}
              {{name}}: {{mockValue type (concat name "_updated")}},
              {{/unless}}
              {{/unless}}
              {{/each}}
            }),
          }
        );

        expect(response.status).toBeOneOf([200, 400, 404, 401]);
      });

      it('should delete {{lowerFirst name}}', async () => {
        if (!{{lowerFirst name}}Id) {
          console.log('Skipping: no {{lowerFirst name}}Id available');
          return;
        }

        const response = await fetch(
          `http://localhost:3001/api/bus/{{addBusPrefix tableName}}/${{{lowerFirst name}}Id}`,
          {
            method: 'DELETE',
            headers: { 'Authorization': `Bearer ${sessionToken}` },
          }
        );

        expect(response.status).toBeOneOf([200, 404, 401]);
      });

      it('should get {{lowerFirst name}} metadata', async () => {
        const response = await fetch(
          `http://localhost:3001/api/bus/{{addBusPrefix tableName}}/meta`,
          {
            headers: { 'Authorization': `Bearer ${sessionToken}` },
          }
        );

        expect(response.status).toBeOneOf([200, 401]);

        if (response.status === 200) {
          const data = await response.json();
          expect(data).toHaveProperty('fields');
        }
      });
    });
    {{/each}}
  });

  describe('Business Rules API', () => {
    it('should get all rules', async () => {
      const response = await fetch('http://localhost:3001/api/rules', {
        headers: { 'Authorization': `Bearer ${sessionToken}` },
      });

      expect(response.status).toBeOneOf([200, 401]);

      if (response.status === 200) {
        const data = await response.json();
        expect(Array.isArray(data)).toBe(true);
      }
    });

    it('should validate JDM content', async () => {
      const response = await fetch('http://localhost:3001/api/rules/validate', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${sessionToken}`,
        },
        body: JSON.stringify({
          jdmContent: 'decision table\n  inputs: amount\n  outputs: status\n  rule "Test": true -> "approved"',
        }),
      });

      expect(response.status).toBeOneOf([200, 400, 401]);
    });

    it('should create a business rule', async () => {
      const response = await fetch('http://localhost:3001/api/rules', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${sessionToken}`,
        },
        body: JSON.stringify({
          entityName: 'TestEntity',
          ruleName: 'TestRule',
          operation: 'CREATE',
          jdmContent: 'rule "Test": true -> "valid"',
        }),
      });

      expect(response.status).toBeOneOf([201, 400, 401]);
    });

    it('should evaluate rules for an entity', async () => {
      const response = await fetch('http://localhost:3001/api/rules/evaluate', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${sessionToken}`,
        },
        body: JSON.stringify({
          entityName: 'TestEntity',
          operation: 'CREATE',
          data: { testField: 'testValue' },
        }),
      });

      expect(response.status).toBeOneOf([200, 400, 401]);
    });
  });
});
