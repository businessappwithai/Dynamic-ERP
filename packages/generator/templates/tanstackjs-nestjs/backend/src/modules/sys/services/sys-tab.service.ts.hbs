import { Injectable, NotFoundException } from '@nestjs/common';
import { v4 as uuidv4 } from 'uuid';
import { DatabaseService } from '../../database/database.service';

@Injectable()
export class SysTabService {
  constructor(private readonly db: DatabaseService) {}

  async findAll(options: { page?: number; limit?: number; windowId?: string } = {}) {
    const { page = 1, limit = 100, windowId } = options;
    const offset = (page - 1) * limit;

    const [data, countResult] = await Promise.all([
      this.db.kysely
        .selectFrom('sys_tab')
        .selectAll()
        .where('is_active', '=', true)
        .$if(!!windowId, (qb) => qb.where('sys_window_id', '=', windowId!))
        .orderBy('seq_no', 'asc')
        .limit(limit)
        .offset(offset)
        .execute(),
      this.db.kysely
        .selectFrom('sys_tab')
        .select((eb) => eb.fn.countAll().as('count'))
        .where('is_active', '=', true)
        .$if(!!windowId, (qb) => qb.where('sys_window_id', '=', windowId!))
        .executeTakeFirst(),
    ]);

    return {
      data,
      meta: {
        total: Number(countResult?.count || 0),
        page,
        pageSize: limit,
        totalPages: Math.ceil(Number(countResult?.count || 0) / limit),
      },
    };
  }

  async findById(id: string) {
    const tab = await this.db.kysely
      .selectFrom('sys_tab')
      .selectAll()
      .where('sys_tab_id', '=', id)
      .executeTakeFirst();
    if (!tab) {
      throw new NotFoundException(`SysTab with ID ${id} not found`);
    }
    return tab;
  }

  async create(data: any) {
    const now = new Date();
    const id = uuidv4();

    const newRecord = {
      sys_tab_id: id,
      ...data,
      tab_level: data.tab_level || 0,
      seq_no: data.seq_no || 0,
      is_single_row: data.is_single_row === true,
      has_tree: data.has_tree === true,
      is_info_tab: data.is_info_tab === true,
      is_translation_tab: data.is_translation_tab === true,
      is_read_only: data.is_read_only === true,
      is_insert_record: data.is_insert_record !== false,
      is_advanced_tab: data.is_advanced_tab === true,
      entity_type: data.entity_type || 'D',
      is_active: data.is_active !== false,
      created_at: now,
      updated_at: now,
      created_by: '',
      updated_by: '',
    };

    await this.db.kysely.insertInto('sys_tab').values(newRecord).execute();
    return this.findById(id);
  }

  async update(id: string, data: any) {
    const updated = { ...data, updated_at: new Date(), updated_by: '' };
    await this.db.kysely
      .updateTable('sys_tab')
      .set(updated)
      .where('sys_tab_id', '=', id)
      .execute();
    return this.findById(id);
  }

  async delete(id: string) {
    await this.findById(id);
    await this.db.kysely
      .updateTable('sys_tab')
      .set({ is_active: false, deleted_at: new Date() })
      .where('sys_tab_id', '=', id)
      .execute();
    return { deleted: true };
  }

  async getFields(tabId: string, view?: 'form' | 'grid') {
    let query = this.db.kysely
      .selectFrom('sys_field')
      .leftJoin('sys_column', 'sys_column.sys_column_id', 'sys_field.sys_column_id')
      .selectAll('sys_field')
      .select('sys_column.column_name')
      .where('sys_field.sys_tab_id', '=', tabId)
      .where('sys_field.is_active', '=', true);

    if (view === 'grid') {
      return query
        .where('sys_field.is_displayed_grid', '=', true)
        .orderBy('sys_field.seq_no_grid', 'asc')
        .execute();
    }
    return query
      .where('sys_field.is_displayed', '=', true)
      .orderBy('sys_field.seq_no', 'asc')
      .execute();
  }
}
