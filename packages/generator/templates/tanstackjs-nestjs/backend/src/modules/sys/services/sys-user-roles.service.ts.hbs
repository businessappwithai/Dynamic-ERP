import { Injectable, NotFoundException } from '@nestjs/common';
import { v4 as uuidv4 } from 'uuid';
import { DatabaseService } from '../../database/database.service';

@Injectable()
export class SysUserRolesService {
  constructor(private readonly db: DatabaseService) {}

  async findAll(options: { page?: number; limit?: number; userId?: string; roleId?: string } = {}) {
    const { page = 1, limit = 100, userId, roleId } = options;
    const offset = (page - 1) * limit;

    const [data, countResult] = await Promise.all([
      this.db.kysely
        .selectFrom('sys_user_roles')
        .selectAll()
        .where('is_active', '=', true)
        .$if(!!userId, (qb) => qb.where('sys_user_id', '=', userId!))
        .$if(!!roleId, (qb) => qb.where('sys_role_id', '=', roleId!))
        .orderBy('created_at', 'desc')
        .limit(limit)
        .offset(offset)
        .execute(),
      this.db.kysely
        .selectFrom('sys_user_roles')
        .select((eb) => eb.fn.countAll().as('count'))
        .where('is_active', '=', true)
        .$if(!!userId, (qb) => qb.where('sys_user_id', '=', userId!))
        .$if(!!roleId, (qb) => qb.where('sys_role_id', '=', roleId!))
        .executeTakeFirst(),
    ]);

    return {
      data,
      meta: {
        total: Number(countResult?.count || 0),
        page,
        pageSize: limit,
        totalPages: Math.ceil(Number(countResult?.count || 0) / limit),
      },
    };
  }

  async findById(id: string) {
    const userRole = await this.db.kysely
      .selectFrom('sys_user_roles')
      .selectAll()
      .where('sys_user_roles_id', '=', id)
      .executeTakeFirst();
    if (!userRole) {
      throw new NotFoundException(`SysUserRole with ID ${id} not found`);
    }
    return userRole;
  }

  async create(data: any) {
    const now = new Date();
    const id = uuidv4();

    const newRecord = {
      sys_user_roles_id: id,
      ...data,
      entity_type: data.entity_type || 'D',
      is_active: data.is_active !== false,
      created_at: now,
      updated_at: now,
      created_by: '',
      updated_by: '',
    };

    await this.db.kysely.insertInto('sys_user_roles').values(newRecord).execute();
    return this.findById(id);
  }

  async update(id: string, data: any) {
    const updated = { ...data, updated_at: new Date(), updated_by: '' };
    await this.db.kysely
      .updateTable('sys_user_roles')
      .set(updated)
      .where('sys_user_roles_id', '=', id)
      .execute();
    return this.findById(id);
  }

  async delete(id: string) {
    await this.findById(id);
    await this.db.kysely
      .updateTable('sys_user_roles')
      .set({ is_active: false, deleted_at: new Date() })
      .where('sys_user_roles_id', '=', id)
      .execute();
    return { deleted: true };
  }
}
