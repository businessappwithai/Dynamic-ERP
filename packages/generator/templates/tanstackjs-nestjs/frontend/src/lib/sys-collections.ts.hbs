/**
 * TanStack DB Collections for sys_ Entities
 *
 * Defines typed, in-memory collections backed by the local PGlite
 * database. Collections are kept in sync via ElectricSQL shapes,
 * so reads are always served from memory (fast path).
 *
 * Pattern: TanStack DB collection → PGlite (local) → Electric sync → Postgres (server)
 *
 * Generated: {{now}}
 * Project: {{project.name}}
 */

import { Collection } from '@tanstack/db';
import type { FieldMetadata, ColumnMetadata, SysTable, SysReference } from '@/hooks/use-field-metadata';
import { getDb } from './electric';

/* -------------------------------------------------------------------------- */
/*  Collection factories                                                       */
/* -------------------------------------------------------------------------- */

async function queryPGlite<T>(sql: string, params?: unknown[]): Promise<T[]> {
  const db = await getDb();
  const result = await db.query<T>(sql, params);
  return result.rows;
}

export const sysTableCollection = new Collection<SysTable, string>({
  id: 'sys_table',
  getKey: (item) => item.sys_table_id,
  loader: () => queryPGlite<SysTable>('SELECT * FROM sys_table WHERE is_active = TRUE ORDER BY name'),
});

export const sysColumnCollection = new Collection<ColumnMetadata, string>({
  id: 'sys_column',
  getKey: (item) => item.sys_column_id,
  loader: () => queryPGlite<ColumnMetadata>('SELECT * FROM sys_column ORDER BY seq_no'),
});

export const sysFieldCollection = new Collection<FieldMetadata, string>({
  id: 'sys_field',
  getKey: (item) => item.sys_field_id,
  loader: () => queryPGlite<FieldMetadata>('SELECT * FROM sys_field ORDER BY seq_no'),
});

export const sysReferenceCollection = new Collection<SysReference, string>({
  id: 'sys_reference',
  getKey: (item) => String(item.sys_reference_id),
  loader: () => queryPGlite<SysReference>('SELECT * FROM sys_reference ORDER BY name'),
});

/* -------------------------------------------------------------------------- */
/*  Helpers                                                                   */
/* -------------------------------------------------------------------------- */

/** Reload all collections from PGlite after a sync batch completes. */
export async function reloadSysCollections(): Promise<void> {
  await Promise.all([
    sysTableCollection.load(),
    sysColumnCollection.load(),
    sysFieldCollection.load(),
    sysReferenceCollection.load(),
  ]);
}
