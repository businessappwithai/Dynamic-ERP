/**
 * {{pascalCase entity.name}} List Controller - Entity Table (Column 2)
 *
 * Dedicated list controller for {{entity.displayName}} entity.
 * Dynamically generates table columns from sys_field metadata.
 * Columns are ordered by seq_no_grid for runtime customization.
 * Supports quick search (client-side) and advanced search (server-side).
 *
 * CRITICAL FIXES APPLIED:
 * - onItemPress uses getSelectedItem() for proper navigation (not oEvent.getSource())
 * - Field metadata uses PascalCase property names (backend returns PascalCase)
 * - All cell bindings include targetType to avoid FormatException
 *
 * Generated: {{now}}
 */
sap.ui.define([
  "sap/ui/core/mvc/Controller",
  "sap/ui/model/json/JSONModel",
  "sap/ui/model/Filter",
  "sap/ui/model/FilterOperator",
  "sap/ui/model/Sorter",
  "sap/m/Column",
  "sap/m/ColumnListItem",
  "sap/m/Text",
  "sap/m/Link",
  "sap/m/ObjectNumber",
  "sap/m/ObjectStatus",
  "sap/m/CheckBox",
  "sap/m/MessageToast",
  "sap/m/MessageBox",
  "sap/ui/model/type/Date",
  "sap/ui/model/type/DateTime",
  "sap/ui/model/type/Float"
], function(
  Controller, JSONModel, Filter, FilterOperator, Sorter,
  Column, ColumnListItem, Text, Link, ObjectNumber, ObjectStatus, CheckBox,
  MessageToast, MessageBox, DateType, DateTimeType, FloatType
) {
  "use strict";

  return Controller.extend("{{kebabCase project.name}}.controller.entity.{{pascalCase entity.name}}List", {

    onInit: function() {
      var oViewModel = new JSONModel({
        busy: true,
        itemCount: 0,
        totalCount: 0,
        entityName: "{{entity.tableName}}",
        entityDisplayName: "{{entity.displayName}}",
        entitySetName: "{{tableToEntitySet entity.tableName}}",
        searchQuery: "",
        advancedSearchVisible: false,
        fields: [],
        selectionColumns: []
      });
      this.getView().setModel(oViewModel, "view");

      this.getOwnerComponent().getRouter()
        .getRoute("{{camelCase entity.name}}List")
        .attachPatternMatched(this._onRouteMatched, this);
    },

    _onRouteMatched: function() {
      this._loadEntityData();
    },

    _loadEntityData: function() {
      var oView = this.getView();
      var oViewModel = oView.getModel("view");
      var sEntitySet = oViewModel.getProperty("/entitySetName");

      oViewModel.setProperty("/busy", true);

      // Fetch total count first
      this._fetchTotalCount(sEntitySet);

      // Load field metadata from sys_field
      this._loadFieldMetadata().then(function(aFields) {
        oViewModel.setProperty("/fields", aFields);

        // Extract selection columns for advanced search
        var aSelectionCols = aFields.filter(function(f) { return f.is_selection_column; });
        oViewModel.setProperty("/selectionColumns", aSelectionCols);

        this._buildTableColumns(aFields);
        this._bindTableItems(sEntitySet);
        oViewModel.setProperty("/busy", false);
      }.bind(this)).catch(function() {
        this._buildDefaultColumns();
        this._bindTableItems(sEntitySet);
        oViewModel.setProperty("/busy", false);
      }.bind(this));
    },

    _loadFieldMetadata: function() {
      return new Promise(function(resolve, reject) {
        var oModel = this.getOwnerComponent().getModel();
        var aFilters = [
          new Filter("table_name", FilterOperator.EQ, "{{entity.tableName}}"),
          new Filter("is_displayed_grid", FilterOperator.EQ, true),
          new Filter("is_active", FilterOperator.EQ, true)
        ];

        oModel.bindList("/SysFields", null, [new Sorter("seq_no_grid")], aFilters)
          .requestContexts(0, 100)
          .then(function(aContexts) {
            resolve(aContexts.map(function(oCtx) { return oCtx.getObject(); }));
          })
          .catch(function() {
            resolve(this._getFieldsFromMetadata());
          }.bind(this));
      }.bind(this));
    },

    _getFieldsFromMetadata: function() {
      var aFields = [];
      {{#each entity.attributes}}
      {{#unless (isExcludedField this.name)}}
      aFields.push({
        column_name: "{{this.name}}",
        display_name: "{{this.displayName}}",
        data_type: "{{this.type}}",
        seq_no_grid: {{multiply @index 10}},
        is_displayed_grid: true,
        is_selection_column: {{#if (or (eq this.name "name") (eq this.name "email") (eq this.name "title") this.unique)}}true{{else}}false{{/if}}
      });
      {{/unless}}
      {{/each}}
      return aFields;
    },

    _fetchTotalCount: function(sEntitySet) {
      var oViewModel = this.getView().getModel("view");
      var oModel = this.getOwnerComponent().getModel();
      var sServiceUrl = oModel.sServiceUrl;

      // Use fetch to get the count directly from OData endpoint
      fetch(sServiceUrl + sEntitySet + "/$count", {
        method: "GET",
        headers: {
          "Accept": "text/plain",
          "Content-Type": "application/json"
        }
      })
      .then(function(response) {
        if (!response.ok) {
          throw new Error("Failed to fetch count");
        }
        return response.text();
      })
      .then(function(sCount) {
        var iCount = parseInt(sCount) || 0;
        oViewModel.setProperty("/totalCount", iCount);
      })
      .catch(function(oError) {
        console.error("Error fetching total count:", oError);
        oViewModel.setProperty("/totalCount", 0);
      });
    },

    _buildTableColumns: function(aFields) {
      var oTable = this.byId("entityTable");
      if (!oTable) return;
      oTable.destroyColumns();

      aFields.forEach(function(oField) {
        oTable.addColumn(new Column({
          header: new Text({ text: oField.display_name || oField.column_name }),
          demandPopin: true,
          minScreenWidth: oField.seq_no_grid <= 30 ? "" : "Tablet"
        }));
      }.bind(this));

      this._aFields = aFields;
    },

    _buildDefaultColumns: function() {
      var aDefaults = [
        {{#each entity.attributes}}
        {{#unless (isExcludedField this.name)}}
        { column_name: "{{this.name}}", display_name: "{{this.displayName}}", data_type: "{{this.type}}", seq_no_grid: {{multiply @index 10}} },
        {{/unless}}
        {{/each}}
      ];
      this._buildTableColumns(aDefaults);
    },

    _bindTableItems: function(sEntitySet) {
      var oTable = this.byId("entityTable");
      if (!oTable) return;
      var aFields = this._aFields || [];

      var oCellTemplate = new ColumnListItem({
        type: "Navigation",
        press: this.onItemPress.bind(this)
      });

      aFields.forEach(function(oField) {
        oCellTemplate.addCell(this._createCellControl(oField));
      }.bind(this));

      oTable.bindItems({
        path: "/" + sEntitySet,
        parameters: { $count: true },
        template: oCellTemplate,
        templateShareable: false,
        events: { dataReceived: this.onDataReceived.bind(this) }
      });
    },

    /**
     * CRITICAL FIX: Create cell control with proper binding
     * Uses PascalCase property names and targetType: 'any' to avoid FormatException
     */
    _createCellControl: function(oField) {
      var sCol = oField.column_name;
      var sType = oField.data_type || "string";

      // Convert snake_case column name to PascalCase property name
      var sPascalCol = sCol.replace(/_([a-z])/g, function(g) { return g[1].toUpperCase(); })
                           .replace(/^([a-z])/, function(g) { return g.toUpperCase(); });

      switch (sType) {
        case "boolean":
          return new CheckBox({ selected: { path: sPascalCol, targetType: 'any' }, enabled: false });
        case "integer":
          return new ObjectNumber({ number: { path: sPascalCol, targetType: 'any' } });
        case "decimal":
          return new ObjectNumber({ number: { path: sPascalCol, type: new FloatType({ decimals: 2 }) } });
        case "date":
          return new Text({ text: { path: sPascalCol, type: new DateType() } });
        case "datetime":
          return new Text({ text: { path: sPascalCol, type: new DateTimeType() } });
        default:
          if (sCol === "status" || sCol.endsWith("_status")) {
            return new ObjectStatus({
              text: { path: sPascalCol, targetType: 'any' },
              state: { path: sPascalCol, formatter: this._formatStatusState }
            });
          }
          return new Text({ text: { path: sPascalCol, targetType: 'any' } });
      }
    },

    _formatStatusState: function(sStatus) {
      if (!sStatus) return "None";
      var s = sStatus.toLowerCase();
      if (s === "active" || s === "approved" || s === "complete") return "Success";
      if (s === "pending" || s === "draft") return "Warning";
      if (s === "inactive" || s === "rejected" || s === "error") return "Error";
      return "None";
    },

    onDataReceived: function(oEvent) {
      var nCount = oEvent.getSource().getLength();
      this.getView().getModel("view").setProperty("/itemCount", nCount);
    },

    /**
     * CRITICAL FIX: Handle item press/navigation event
     * For selectionChange event, use getSelectedItem() instead of oEvent.getSource()
     * This ensures we get the correct selected item in SingleSelectMaster mode
     */
    onItemPress: function(oEvent) {
      // For selectionChange event, get the selected item from the table
      var oTable = this.byId("entityTable");
      if (!oTable) {
        console.error("Table not found");
        return;
      }

      // Get the selected item from the table (for SingleSelectMaster mode)
      var oListItem = oTable.getSelectedItem();
      if (!oListItem) {
        console.error("No selected item");
        return;
      }

      console.log("Selected item:", oListItem);

      var oBindingContext = oListItem.getBindingContext();
      if (!oBindingContext) {
        console.error("No binding context found");
        return;
      }

      // Get the object directly from binding context
      var oData = oBindingContext.getObject();
      if (!oData || !oData.{{pascalCase (or entity.primaryKey "Id")}}) {
        console.error("No data or ID found in binding context");
        return;
      }

      var sId = oData.{{pascalCase (or entity.primaryKey "Id")}};
      console.log("Navigating to detail with ID:", sId);

      this.getOwnerComponent().getRouter().navTo("{{camelCase entity.name}}Detail", { id: sId });
    },

    // Quick Search (client-side filtering of loaded data)
    onQuickSearch: function(oEvent) {
      var sQuery = oEvent.getParameter("query") || oEvent.getParameter("newValue") || "";
      var oTable = this.byId("entityTable");
      var oBinding = oTable.getBinding("items");

      if (sQuery && sQuery.length > 0) {
        var aFilters = [];
        (this._aFields || []).forEach(function(f) {
          if (f.data_type === "string" || !f.data_type) {
            aFilters.push(new Filter(f.column_name, FilterOperator.Contains, sQuery));
          }
        });
        if (aFilters.length > 0) {
          oBinding.filter(new Filter({ filters: aFilters, and: false }));
        }
      } else {
        oBinding.filter([]);
      }
    },

    // Toggle advanced search panel visibility
    onToggleAdvancedSearch: function() {
      var oViewModel = this.getView().getModel("view");
      var bVisible = oViewModel.getProperty("/advancedSearchVisible");
      oViewModel.setProperty("/advancedSearchVisible", !bVisible);
    },

    // Advanced Search (server-side via OData $filter)
    onAdvancedSearch: function() {
      var oView = this.getView();
      var sField = oView.byId("advSearchField") ? oView.byId("advSearchField").getSelectedKey() : "";
      var sOperator = oView.byId("advSearchOperator") ? oView.byId("advSearchOperator").getSelectedKey() : "Contains";
      var sValue = oView.byId("advSearchValue") ? oView.byId("advSearchValue").getValue() : "";

      if (!sField || !sValue) {
        MessageToast.show("Please select a field and enter a search value");
        return;
      }

      var oTable = this.byId("entityTable");
      var oBinding = oTable.getBinding("items");
      oBinding.filter([new Filter(sField, FilterOperator[sOperator], sValue)]);
    },

    onClearAdvancedSearch: function() {
      var oTable = this.byId("entityTable");
      var oBinding = oTable.getBinding("items");
      oBinding.filter([]);

      var oView = this.getView();
      if (oView.byId("advSearchValue")) {
        oView.byId("advSearchValue").setValue("");
      }
    },

    onCreatePress: function() {
      this.getOwnerComponent().getRouter().navTo("{{camelCase entity.name}}Create");
    },

    onRefresh: function() {
      var oTable = this.byId("entityTable");
      var oBinding = oTable.getBinding("items");
      if (oBinding) oBinding.refresh();
    },

    onNavBack: function() {
      this.getOwnerComponent().getRouter().navTo("master");
    }
  });
});
