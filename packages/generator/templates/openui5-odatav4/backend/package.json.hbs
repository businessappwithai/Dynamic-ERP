{
  "name": "{{kebabCase project.name}}-odata",
  "version": "{{project.version}}",
  "description": "{{project.description}} - OData V4 Backend",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "start:dev": "npm run generate:all && ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "generate:all": "npm run generate:controllers && npm run generate:server",
    "generate:controllers": "ts-node src/generate-controllers.ts",
    "generate:server": "ts-node src/create-server-class.ts",
    "migrate": "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "seed": "knex seed:run",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "db:setup": "knex migrate:latest && knex seed:run"
  },
  "dependencies": {
    "odata-v4-server": "^0.2.13",
    "reflect-metadata": "^0.1.14",
    "knex": "^3.1.0",
    "pg": "^8.11.0",
    "better-sqlite3": "^12.8.0",
    "sqlite3": "^6.0.1",
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/better-sqlite3": "^7.6.8",
    "typescript": "^5.3.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "vitest": "^1.2.0",
    "@vitest/coverage-v8": "^1.2.0",
    "supertest": "^6.3.0",
    "@types/supertest": "^6.0.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  }
}
