<!--
  App View - Flexible Column Layout Container

  Implements SAP Fiori 3-column layout pattern:
  - Column 1 (Begin): Entity menu navigation
  - Column 2 (Mid): Entity list/table
  - Column 3 (End): Entity detail/object page

  Generated: 2026-05-06T11:42:08.761Z
-->
<mvc:View
  controllerName="q-a-test-project.controller.App"
  xmlns="sap.f"
  xmlns:mvc="sap.ui.core.mvc"
  displayBlock="true">

  <FlexibleColumnLayout
    id="fcl"
    layout="{appView>/layout}"
    stateChange=".onStateChange"
    backgroundDesign="Solid">

    <!-- Column 1: Entity Navigation Menu -->
    <beginColumnPages>
      <mvc:XMLView viewName="q-a-test-project.view.Master" />
    </beginColumnPages>

    <!-- Column 2: Entity List -->
    <midColumnPages>
      <!-- Populated by router -->
    </midColumnPages>

    <!-- Column 3: Entity Detail -->
    <endColumnPages>
      <!-- Populated by router -->
    </endColumnPages>

  </FlexibleColumnLayout>

</mvc:View>
