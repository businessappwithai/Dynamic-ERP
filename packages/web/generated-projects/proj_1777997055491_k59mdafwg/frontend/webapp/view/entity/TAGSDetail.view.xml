<mvc:View
  controllerName="q-a-test-project.controller.entity.TAGSDetail"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:form="sap.ui.layout.form"
  xmlns:core="sap.ui.core">

  <f:DynamicPage
    height="100%"
    headerExpanded="true"
    toggleHeaderOnTitleClick="true"
    busy="{view>/busy}">

    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="Tags: {}" />
        </f:heading>
        <f:actions>
          <Button
            text="Edit"
            type="Emphasized"
            icon="sap-icon://edit"
            press=".onEditPress"
            visible="{= !${view>/editable} }" />
          <Button
            text="Save"
            type="Emphasized"
            icon="sap-icon://save"
            press=".onSavePress"
            visible="{view>/editable}" />
          <Button
            text="Cancel"
            press=".onCancelPress"
            visible="{view>/editable}" />
          <Button
            text="Delete"
            type="Reject"
            icon="sap-icon://delete"
            press=".onDeletePress"
            visible="{= !${view>/editable} }" />
        </f:actions>
        <f:navigationActions>
          <Button
            icon="sap-icon://nav-back"
            press=".onNavBack"
            tooltip="Back to List" />
        </f:navigationActions>
      </f:DynamicPageTitle>
    </f:title>

    <f:content>
      <VBox class="sapUiSmallMargin">
        <Panel headerText="General Information" expandable="true" expanded="true">
          <form:SimpleForm
            editable="{view>/editable}"
            layout="ResponsiveGridLayout"
            labelSpanXL="3"
            labelSpanL="3"
            labelSpanM="3"
            labelSpanS="12"
            adjustLabelSpan="false"
            emptySpanXL="4"
            emptySpanL="4"
            emptySpanM="4"
            emptySpanS="0"
            columnsXL="1"
            columnsL="1"
            columnsM="1">
            <Label text="Name" required="true" />
            <Input
              value="{path: 'Name', targetType: 'any'}"
              editable="{view>/editable}"
               />
                      </form:SimpleForm>
        </Panel>

        <Panel headerText="Audit Information" expandable="true" expanded="false">
          <form:SimpleForm
            editable="false"
            layout="ResponsiveGridLayout"
            labelSpanL="3" labelSpanM="3" labelSpanS="12">
            <Label text="Created At" />
            <Text text="{path: 'CreatedAt', targetType: 'any', formatter: '.formatDate'}" />
            <Label text="Updated At" />
            <Text text="{path: 'UpdatedAt', targetType: 'any', formatter: '.formatDate'}" />
          </form:SimpleForm>
        </Panel>
      </VBox>
    </f:content>

  </f:DynamicPage>
</mvc:View>
